From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai>
Date: Fri, 27 Feb 2026 00:00:00 +0000
Subject: [PATCH 127/127] arm64/cix: fix Kconfig deps and module reachability

Fix CIX option wiring that can produce invalid build combinations in
defconfig/allmodconfig/randconfig, and fix built-in/module reachability
for CIX helper calls used by thermal and SOF code.

Also tighten module reachability for CIX SoC/USB/media drivers so Kconfig
does not permit module combinations that can only resolve against built-in
or unavailable symbols.

For CIX CPU IPA module builds, avoid direct use of non-exported
cpu_logical_map() by using topology cluster IDs instead.

---
--- a/arch/arm64/Kconfig
+++ b/arch/arm64/Kconfig
@@ -1601,7 +1601,6 @@
 
 config ARCH_CIX
 	bool "Cix Technology Group SoC Support"
-	def_bool y
 
 config ARCH_SUPPORTS_CRASH_DUMP
 	def_bool y
--- a/drivers/irqchip/Kconfig
+++ b/drivers/irqchip/Kconfig
@@ -416,7 +416,8 @@
 config SKY1_PDC
 	bool
 	depends on ARM_GIC
-	default y
+	depends on ARCH_CIX || COMPILE_TEST
+	default ARCH_CIX
 	select IRQ_DOMAIN
 	help
 	  Enables the wakeup IRQs for SKY1 platforms with PDC block
--- a/drivers/mailbox/Kconfig
+++ b/drivers/mailbox/Kconfig
@@ -360,7 +360,8 @@
 	  things.
 
 config CIX_MBOX
-        bool "CIX Mailbox"
+        tristate "CIX Mailbox"
+        depends on MAILBOX
         depends on ARCH_CIX || COMPILE_TEST
         depends on OF || ACPI
         help
--- a/drivers/thermal/cpufreq_cooling.c
+++ b/drivers/thermal/cpufreq_cooling.c
@@ -253,7 +253,7 @@
 
 	cpufreq_cdev->last_load = total_load;
 
-	if (IS_ENABLED(CONFIG_CIX_CPU_IPA)) {
+	if (IS_REACHABLE(CONFIG_CIX_CPU_IPA)) {
 		/* Use real measured power from CIX IPA hardware */
 		*power = cix_get_static_power_cpus(policy->cpus) +
 			 cix_get_dynamic_power_cpus(policy->cpus);
@@ -301,7 +301,7 @@
 
 	*power = cpu_freq_to_power(cpufreq_cdev, freq) * num_cpus;
 
-	if (IS_ENABLED(CONFIG_CIX_CPU_IPA))
+	if (IS_REACHABLE(CONFIG_CIX_CPU_IPA))
 		*power += cix_get_static_power_cpus(cpufreq_cdev->policy->cpus);
 
 	return 0;
@@ -334,7 +334,7 @@
 	 * When using real IPA power, subtract static power from the budget
 	 * since only dynamic power can be controlled via frequency scaling.
 	 */
-	if (IS_ENABLED(CONFIG_CIX_CPU_IPA)) {
+	if (IS_REACHABLE(CONFIG_CIX_CPU_IPA)) {
 		u32 static_power = cix_get_static_power_cpus(policy->cpus);
 
 		dynamic_power = (power > static_power) ? power - static_power : 0;
--- a/drivers/thermal/cix/cix_cpu_ipa.c
+++ b/drivers/thermal/cix/cix_cpu_ipa.c
@@ -15,6 +15,6 @@
 #include <linux/of.h>
 #include <linux/platform_device.h>
 #include <linux/cix/cix_cpu_ipa.h>
-#include <asm/cpu.h>
+#include <linux/topology.h>
 
 #define REG_OFFSET 0x40
@@ -41,7 +41,10 @@
 	if (!cix_ipa || !cix_ipa->regs)
 		return 0;
 
-	pcpu = MPIDR_AFFINITY_LEVEL(cpu_logical_map(cpu), 1);
+	pcpu = topology_cluster_id(cpu);
+	if (pcpu < 0)
+		pcpu = cpu;
+
 	info = cix_ipa->regs + pcpu * REG_OFFSET;
 
 	return readl(&info->static_power);
@@ -55,7 +58,10 @@
 	if (!cix_ipa || !cix_ipa->regs)
 		return 0;
 
-	pcpu = MPIDR_AFFINITY_LEVEL(cpu_logical_map(cpu), 1);
+	pcpu = topology_cluster_id(cpu);
+	if (pcpu < 0)
+		pcpu = cpu;
+
 	info = cix_ipa->regs + pcpu * REG_OFFSET;
 
 	return readl(&info->dynamic_power);
--- a/include/linux/cix/cix_cpu_ipa.h
+++ b/include/linux/cix/cix_cpu_ipa.h
@@ -10,7 +10,7 @@
 
 #include <linux/cpumask.h>
 
-#if IS_ENABLED(CONFIG_CIX_CPU_IPA)
+#if IS_REACHABLE(CONFIG_CIX_CPU_IPA)
 
 int cix_get_static_power_cpus(const struct cpumask *cpus);
 int cix_get_dynamic_power_cpus(const struct cpumask *cpus);
--- a/include/linux/firmware/cix/dsp.h
+++ b/include/linux/firmware/cix/dsp.h
@@ -60,7 +60,7 @@
 	return dsp_ipc->private_data;
 }
 
-#if IS_ENABLED(CONFIG_CIX_DSP)
+#if IS_REACHABLE(CONFIG_CIX_DSP)
 
 int cix_dsp_ipc_send(struct cix_dsp_ipc *ipc, unsigned int idx, u32 op);
 int cix_dsp_request_mbox(struct cix_dsp_ipc *dsp_ipc);
--- a/drivers/soc/cix/Kconfig
+++ b/drivers/soc/cix/Kconfig
@@ -1,7 +1,7 @@
 # SPDX-License-Identifier: GPL-2.0-only
 
 config CIX_SKY1_SOCINFO
-	tristate "CIX Sky1 SoC information driver"
+	bool "CIX Sky1 SoC information driver"
 	depends on ARCH_CIX || COMPILE_TEST
 	depends on NVMEM
 	select SOC_BUS
@@ -11,9 +11,6 @@
 	  driver. This provides SoC identification, firmware version
 	  information, and board details via sysfs.
 
-	  This driver can also be built as a module. If so, the module
-	  will be called sky1-socinfo.
-
 config CIX_DDR_LP
 	tristate "CIX DDR Low Power control driver"
 	depends on ARCH_CIX || COMPILE_TEST
--- a/drivers/usb/cdns3/Kconfig
+++ b/drivers/usb/cdns3/Kconfig
@@ -95,6 +95,7 @@
 
 config USB_CDNSP
 	tristate "Cadence USBSSP DRD Platform Driver"
+	depends on USB_GADGET
 	help
 	  Say Y here if your system has a Cadence USBSSP dual-role controller
 	  on a platform bus (not PCI).
@@ -106,6 +107,7 @@
 config USB_CDNSP_PCI
 	tristate "Cadence USBSSP DRD PCI Driver"
 	depends on USB_PCI && ACPI
+	depends on USB_GADGET
 	help
 	  Say Y here if your system has a Cadence CDNSP dual-role controller
 	  on a PCI bus.
--- a/drivers/media/platform/cix/Kbuild
+++ b/drivers/media/platform/cix/Kbuild
@@ -13,8 +13,8 @@
 
 # Amvx module
 # Use obj-m for out-of-tree DKMS builds, CONFIG_VIDEO_LINLON for in-tree
-ifeq ($(CONFIG_VIDEO_LINLON),)
-obj-m := amvx.o
-else
-obj-$(CONFIG_VIDEO_LINLON) := amvx.o
+ifeq ($(KBUILD_EXTMOD),)
+obj-$(CONFIG_VIDEO_LINLON) := amvx.o
+else
+obj-m := amvx.o
 endif
-- 
