+static unsigned long scmi_perf_level_to_freq(struct perf_dom_info *dom,
+					     u32 level)
+{
+	u64 freq;
+
+	if (!dom->sustained_freq_hz || !dom->sustained_perf_level ||
+	    dom->level_indexing_mode) {
+		if (!dom->mult_factor)
+			return 0;
+
+		freq = (u64)level * dom->mult_factor;
+	} else {
+		freq = mul_u64_u32_div(dom->sustained_freq_hz, level,
+				       dom->sustained_perf_level);
+	}
+
+	return min_t(u64, freq, ULONG_MAX);
+}
+
+static u32 scmi_perf_freq_to_level(struct perf_dom_info *dom,
+				   unsigned long freq)
+{
+	u64 level, this_freq, next_freq, this_delta, next_delta;
+
+	if (!dom->sustained_freq_hz || !dom->sustained_perf_level ||
+	    dom->level_indexing_mode) {
+		if (!dom->mult_factor)
+			return 0;
+
+		return freq / dom->mult_factor;
+	}
+
+	level = mul_u64_u64_div_u64(freq, dom->sustained_perf_level,
+				    dom->sustained_freq_hz);
+	if (level >= U32_MAX)
+		return U32_MAX;
+
+	this_freq = scmi_perf_level_to_freq(dom, level);
+	next_freq = scmi_perf_level_to_freq(dom, level + 1);
+	this_delta = this_freq > freq ? this_freq - freq : freq - this_freq;
+	next_delta = next_freq > freq ? next_freq - freq : freq - next_freq;
+
+	if (next_delta < this_delta)
+		level++;
+
+	return level;
+}
+
+static unsigned long scmi_perf_opp_to_freq(struct perf_dom_info *dom,
+					   struct scmi_opp *opp)
+{
+	if (dom->level_indexing_mode)
+		return scmi_perf_level_to_freq(dom, opp->indicative_freq);
+
+	return scmi_perf_level_to_freq(dom, opp->perf);
+}
+
 static const struct scmi_perf_domain_info *
 scmi_perf_info_get(const struct scmi_protocol_handle *ph, u32 domain)
 {
