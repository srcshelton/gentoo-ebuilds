+static const struct file_operations ispmem_dev_fops = {
+	.owner = THIS_MODULE,
+	.open = ispmem_open,
+	.unlocked_ioctl = ispmem_ioctl,
+	.release = ispmem_release,
+	.mmap = ispmem_cma_mmap,
+};
