+#ifndef __ARMCHINA_REGISTER_H__
+#define __ARMCHINA_REGISTER_H__
+
+#include <linux/io.h>
+#include <linux/i2c-dev.h>
+#include <linux/init.h>
+#include <linux/ioctl.h>
+#include <linux/module.h>
+#include <linux/slab.h>
