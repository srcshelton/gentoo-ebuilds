+/* Definitions for peripheral AXI_CDMA_0 */
+#define AXI_REG_CDMA_BASE 0x8E200000
+#define AXI_REG_CDMA_SIZE 0x10000
+#define AXI_REG_CDMA_END 0x8E20FFFF
