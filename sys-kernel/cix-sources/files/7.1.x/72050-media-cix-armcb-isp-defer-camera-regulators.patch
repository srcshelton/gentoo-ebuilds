+static int armcb_imgsens_get_optional_regulator(struct i2c_client *client,
+						struct regulator **supply,
+						const char *name)
+{
+	struct device *dev = &client->dev;
+	struct regulator *regulator;
+	int ret;
+
+	regulator = devm_regulator_get_optional(dev, name);
+	if (!regulator) {
+		*supply = NULL;
+		return 0;
+	}
+
+	if (IS_ERR(regulator)) {
+		ret = PTR_ERR(regulator);
+		if (ret == -ENODEV || ret == -ENOSYS) {
+			dev_dbg(dev, "optional %s regulator not described\n",
+				name);
+			*supply = NULL;
+			return 0;
+		}
+
+		return dev_err_probe(dev, ret,
+				     "failed to get %s regulator\n", name);
+	}
+
+	*supply = regulator;
+	return 0;
+}
+
