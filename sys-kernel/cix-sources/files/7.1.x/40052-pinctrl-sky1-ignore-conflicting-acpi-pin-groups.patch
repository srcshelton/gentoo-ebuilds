+static int pinctrl_acpi_get_group_selector_quiet(struct pinctrl_dev *pctldev,
+						 const char *pin_group)
+{
+	const struct pinctrl_ops *pctlops = pctldev->desc->pctlops;
+	unsigned int ngroups = pctlops->get_groups_count(pctldev);
+	unsigned int group_selector;
+
+	for (group_selector = 0; group_selector < ngroups; group_selector++) {
+		const char *gname = pctlops->get_group_name(pctldev,
+							    group_selector);
+
+		if (gname && !strcmp(gname, pin_group))
+			return group_selector;
+	}
+
+	return -EINVAL;
+}
+
+static bool pinctrl_acpi_sky1_i2s_debug_alias(const char *group,
+					      char *alias,
+					      size_t alias_len)
+{
+	static const char prefix[] = "pinctrl_substrate_i2s";
+	static const char suffix[] = "_dbg";
+	size_t prefix_len = sizeof(prefix) - 1;
+	const char *tail;
+
+	if (!group || strncmp(group, prefix, prefix_len))
+		return false;
+
+	tail = group + prefix_len;
+	if (*tail < '5' || *tail > '9')
+		return false;
+
+	if (strcmp(tail + 1, suffix))
+		return false;
+
+	if (alias) {
+		if (alias_len < prefix_len + 2)
+			return false;
+
+		memcpy(alias, group, prefix_len + 1);
+		alias[prefix_len + 1] = '\0';
+	}
+
+	return true;
+}
