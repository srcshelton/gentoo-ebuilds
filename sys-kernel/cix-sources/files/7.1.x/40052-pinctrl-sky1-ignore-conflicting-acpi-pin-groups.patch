+static bool sky1_acpi_group_is_display_audio_debug(const char *grp)
+{
+	static const char prefix[] = "pinctrl_substrate_i2s";
+	const char *suffix;
+
+	if (!grp || strncmp(grp, prefix, sizeof(prefix) - 1))
+		return false;
+
+	suffix = grp + sizeof(prefix) - 1;
+	if (*suffix < '5' || *suffix > '9')
+		return false;
+
+	suffix++;
+	return !*suffix || !strcmp(suffix, "_dbg");
+}
+
+static bool sky1_acpi_group_pin_is_ignored(const char *grp, unsigned int pin)
+{
+	return grp && !strcmp(grp, "pinctrl_cam1_hw") &&
+		pin == SKY1_ACPI_O6_CAM1_SHARED_MCLK_PIN;
+}
 
