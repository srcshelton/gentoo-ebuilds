--- a/drivers/media/platform/cix/armcb-isp/isp/armcb_v4l2_core.c
+++ b/drivers/media/platform/cix/armcb-isp/isp/armcb_v4l2_core.c
@@ -1897,7 +1897,7 @@ armcb_v4l2_dev_t *armcb_register_instance(struct platform_device *pdev,
 {
 	armcb_v4l2_dev_t *adev = NULL;
 
-	if (cam_id + 1 >= ARMCB_MAX_DEVS) {
+	if (cam_id >= ARMCB_MAX_DEVS) {
 		LOG(LOG_ERR, "too many instance, current is %d.", cam_id);
 		return NULL;
 	}
@@ -1917,23 +1917,45 @@ armcb_v4l2_dev_t *armcb_register_instance(struct platform_device *pdev,
 	return adev;
 }
 
+static void armcb_destroy_instance(unsigned int cam_id, bool cleanup_notifier)
+{
+	armcb_v4l2_dev_t *dev;
+
+	if (cam_id >= ARMCB_MAX_DEVS)
+		return;
+
+	dev = g_isp_v4l2_devs[cam_id];
+	if (!dev)
+		return;
+
+	g_isp_v4l2_devs[cam_id] = NULL;
+
+	if (cleanup_notifier) {
+		v4l2_async_nf_unregister(&dev->dts_notifier);
+#if (KERNEL_VERSION(4, 17, 0) <= LINUX_VERSION_CODE)
+		v4l2_async_nf_cleanup(&dev->dts_notifier);
+#endif
+	}
+
+	video_unregister_device(&dev->vid_cap_dev);
+#if defined(CONFIG_MEDIA_CONTROLLER)
+	media_device_unregister(&dev->mdev);
+#endif
+	v4l2_device_put(&dev->v4l2_dev);
+	LOG(LOG_INFO, "release armcb instance %d (%p)", cam_id, dev);
+}
+
+void armcb_unregister_instance(unsigned int cam_id)
+{
+	armcb_destroy_instance(cam_id, false);
+}
+
 void armcb_cam_instance_destroy(void)
 {
 	int i = 0;
 
 	for (; i < ARMCB_MAX_DEVS; i++) {
-		if (g_isp_v4l2_devs[i] == NULL)
-			continue;
-		v4l2_async_nf_unregister(&g_isp_v4l2_devs[i]->dts_notifier);
-#if (KERNEL_VERSION(4, 17, 0) <= LINUX_VERSION_CODE)
-		v4l2_async_nf_cleanup(&g_isp_v4l2_devs[i]->dts_notifier);
-#endif
-		video_unregister_device(&g_isp_v4l2_devs[i]->vid_cap_dev);
-		v4l2_device_put(&g_isp_v4l2_devs[i]->v4l2_dev);
-		media_device_unregister(&g_isp_v4l2_devs[i]->mdev);
-		LOG(LOG_INFO, "release armcb instance %d (%p)", i,
-			g_isp_v4l2_devs[i]);
-		g_isp_v4l2_devs[i] = NULL;
+		armcb_destroy_instance(i, true);
 	}
 	g_adev_idx = 0;
 }
