+static int armcb_v4l2_s_ext_ctrls(struct file *file, void *fh,
+				  struct v4l2_ext_controls *ctrls)
+{
+	unsigned int i;
+	int rc;
+
+	if (!ctrls || !ctrls->controls)
+		return -EINVAL;
+
+	if (!fh)
+		fh = file->private_data;
+
+	for (i = 0; i < ctrls->count; i++) {
+		struct v4l2_control ctrl = {
+			.id = ctrls->controls[i].id,
+			.value = ctrls->controls[i].value,
+		};
+
+		rc = armcb_v4l2_s_ctrl(file, fh, &ctrl);
+		if (rc) {
+			ctrls->error_idx = i;
+			return rc;
+		}
+
+		ctrls->controls[i].value = ctrl.value;
+	}
+
+	return 0;
+}
