 		return -EINVAL;
 	}
 
+	armcb_cix_diag_subdev("armcb-register-entry", sd);
+
 	if (armcb_fwnode_invalid(sd->fwnode) && sd->dev)
 		sd->fwnode = dev_fwnode(sd->dev);
 
+	armcb_cix_diag_subdev("armcb-register-after-fallback", sd);
+
 	if (armcb_fwnode_invalid(sd->fwnode)) {
 		LOG(LOG_ERR, "Invalid fwnode for %s", sd->name);
 		return -EINVAL;
