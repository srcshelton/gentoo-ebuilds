+		sd ? sd->name : "<null>", sd ? sd->dev : NULL,
+		sd ? sd->fwnode : NULL,
+		sd ? v4l2_async_fwnode_invalid(sd->fwnode) : -1,
+		sd_fwnode, v4l2_async_fwnode_invalid(sd_fwnode), match,
