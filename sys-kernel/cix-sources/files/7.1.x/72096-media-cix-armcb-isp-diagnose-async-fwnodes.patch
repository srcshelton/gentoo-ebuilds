diff --git a/drivers/media/platform/cix/armcb-isp/common/armcb_v4l_sd.c b/drivers/media/platform/cix/armcb-isp/common/armcb_v4l_sd.c
--- a/drivers/media/platform/cix/armcb-isp/common/armcb_v4l_sd.c
+++ b/drivers/media/platform/cix/armcb-isp/common/armcb_v4l_sd.c
@@ -27,11 +27,28 @@
 #define LOG_MODULE LOG_MODULE_COMMON
 #endif
 
+#define ARMCB_CIX_DIAG_TAG "CIX72096"
+
 static bool armcb_fwnode_invalid(struct fwnode_handle *fwnode)
 {
 	return IS_ERR(fwnode) || ZERO_OR_NULL_PTR(fwnode);
 }
 
+static void armcb_cix_diag_subdev(const char *stage, struct v4l2_subdev *sd)
+{
+	static int diag_count;
+
+	if (diag_count >= 32)
+		return;
+
+	diag_count++;
+	pr_warn("%s %s count=%d sd=%px name=%s dev=%px fwnode=%px fwnode_bad=%d\n",
+		ARMCB_CIX_DIAG_TAG, stage, diag_count, sd,
+		sd ? sd->name : "<null>", sd ? sd->dev : NULL,
+		sd ? sd->fwnode : NULL,
+		sd ? armcb_fwnode_invalid(sd->fwnode) : -1);
+}
+
