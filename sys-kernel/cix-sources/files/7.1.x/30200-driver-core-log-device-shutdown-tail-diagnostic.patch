+static void device_shutdown_diag_copy_name(char *buf, size_t size,
+					   const char *name)
+{
+	long ret;
+
+	if (!size)
+		return;
+
+	if (!name) {
+		strscpy(buf, "<unnamed>", size);
+		return;
+	}
+
+	ret = strncpy_from_kernel_nofault(buf, name, size);
+	if (ret < 0)
+		scnprintf(buf, size, "<name-err:%ld>", ret);
+	else
+		buf[size - 1] = '\0';
+}
+
+static void device_shutdown_diag_dump_entry(struct list_head *head,
+					    struct list_head *entry,
+					    const char *tag)
+{
+	struct list_head entry_copy;
+	struct device dev_copy;
+	struct device *dev = list_entry(entry, struct device, kobj.entry);
+	char name[64];
+	int entry_ret, dev_ret;
+
+	entry_ret = copy_from_kernel_nofault(&entry_copy, entry,
+					     sizeof(entry_copy));
+	dev_ret = copy_from_kernel_nofault(&dev_copy, dev, sizeof(dev_copy));
+	if (!dev_ret)
+		device_shutdown_diag_copy_name(name, sizeof(name),
+					       dev_copy.kobj.name);
+	else
+		strscpy(name, "<dev-err>", sizeof(name));
+
+	pr_emerg("device_shutdown diag: %s head=%px head_prev=%px head_next=%px entry=%px entry_ret=%d prev=%px next=%px dev=%px dev_ret=%d name=%s parent=%px bus=%px class=%px driver=%px pm_domain=%px\n",
+		 tag, head, head->prev, head->next, entry, entry_ret,
+		 entry_ret ? NULL : entry_copy.prev,
+		 entry_ret ? NULL : entry_copy.next,
+		 dev, dev_ret, name,
+		 dev_ret ? NULL : dev_copy.parent,
+		 dev_ret ? NULL : dev_copy.bus,
+		 dev_ret ? NULL : dev_copy.class,
+		 dev_ret ? NULL : dev_copy.driver,
+		 dev_ret ? NULL : dev_copy.pm_domain);
+}
+
+static bool device_shutdown_diag_tail_is_sane(struct list_head *head,
+					      struct list_head *entry)
+{
+	struct list_head entry_copy;
+	int ret;
+
+	device_shutdown_diag_dump_entry(head, entry, "tail");
+
+	ret = copy_from_kernel_nofault(&entry_copy, entry, sizeof(entry_copy));
+	if (ret || !entry_copy.prev || entry_copy.next != head) {
+		pr_emerg("device_shutdown diag: corrupt devices_kset tail before shutdown callback; skipping remaining device shutdown walk\n");
+		if (!ret && entry_copy.prev && entry_copy.prev != head)
+			device_shutdown_diag_dump_entry(head, entry_copy.prev,
+						       "tail-prev");
+		return false;
+	}
+
+	return true;
+}
