 };
 
 static int cix_fan_eval_integer(struct cix_fan_data *data, acpi_handle handle,
@@ -109,6 +132,114 @@ static int cix_fan_read_pwm_raw(struct cix_fan_data *data,
 				    data->pwm_get_label, args, duty);
 }
 
+static int cix_fan_read_optional(struct cix_fan_data *data,
+				 acpi_handle handle, const char *label,
+				 unsigned long long *val)
+{
+	if (!handle)
+		return -EOPNOTSUPP;
+
+	return cix_fan_eval_integer(data, handle, NULL, label, NULL, val);
+}
+
+static bool cix_fan_rpm_value_valid(u16 rpm)
+{
+	return rpm <= CIX_FAN_MAX_RPM || rpm == CIX_FAN_RPM_STALLED ||
+	       rpm == CIX_FAN_RPM_NOT_PRESENT;
+}
+
+static enum cix_fan_rpm_encoding cix_fan_detect_rpm_encoding(u16 raw)
+{
+	u16 be = raw;
+	u16 le = swab16(raw);
+	bool be_valid = cix_fan_rpm_value_valid(be);
+	bool le_valid = cix_fan_rpm_value_valid(le);
+
+	if (be_valid && !le_valid)
+		return CIX_FAN_RPM_ENCODING_BE;
+	if (le_valid && !be_valid)
+		return CIX_FAN_RPM_ENCODING_LE;
+	if (be_valid && le_valid && be == le)
+		return CIX_FAN_RPM_ENCODING_BE;
+
+	return CIX_FAN_RPM_ENCODING_UNKNOWN;
+}
+
+static int cix_fan_decode_rpm(struct cix_fan_data *data,
+			      unsigned long long raw_value, u16 *rpm)
+{
+	u16 raw;
+
+	if (raw_value == CIX_FAN_DIAG_UNAVAILABLE || raw_value > U16_MAX)
+		return -ENODATA;
+
+	raw = raw_value;
+	if (data->rpm_encoding == CIX_FAN_RPM_ENCODING_UNKNOWN)
+		data->rpm_encoding = cix_fan_detect_rpm_encoding(raw);
+
+	switch (data->rpm_encoding) {
+	case CIX_FAN_RPM_ENCODING_BE:
+		*rpm = raw;
+		break;
+	case CIX_FAN_RPM_ENCODING_LE:
+		*rpm = swab16(raw);
+		break;
+	default:
+		return -ENODATA;
+	}
+
+	if (!cix_fan_rpm_value_valid(*rpm))
+		return -ENODATA;
+
+	return 0;
+}
+
+static int cix_fan_get_rpm(struct cix_fan_data *data, u16 *rpm)
+{
+	unsigned long long raw;
+	int ret;
+
+	ret = cix_fan_read_optional(data, data->rpm_raw_get_handle,
+				    CIX_FAN_HWMN_GFRB_PATH, &raw);
+	if (ret)
+		return ret;
+
+	return cix_fan_decode_rpm(data, raw, rpm);
+}
+
+static int cix_fan_get_target(struct cix_fan_data *data, long *val)
+{
+	unsigned long long target;
+	int ret;
+
+	ret = cix_fan_read_optional(data, data->target_get_handle,
+				    CIX_FAN_HWMN_GTRP_PATH, &target);
+	if (ret)
+		return ret;
+	if (target == CIX_FAN_DIAG_UNAVAILABLE || target > CIX_FAN_MAX_RPM)
+		return -ENODATA;
+
+	*val = target;
+	return 0;
+}
+
+static int cix_fan_get_mode(struct cix_fan_data *data, long *val)
+{
+	unsigned long long mode;
+	int ret;
+
+	ret = cix_fan_read_optional(data, data->mode_get_handle,
+				    CIX_FAN_HWMN_GFMD_PATH, &mode);
+	if (ret)
+		return ret;
+	if (mode != CIX_FAN_MODE_FULL && mode != CIX_FAN_MODE_AUTO)
+		return -ENODATA;
+
+	data->pwm_enable = mode;
+	*val = mode;
+	return 0;
+}
+
