+#define CIX_FAN_HWMN_GFMV_PATH	"\\_SB.HWMN.GFMV"
+#define CIX_FAN_HWMN_GFMD_PATH	"\\_SB.HWMN.GFMD"
+#define CIX_FAN_DIAG_UNAVAILABLE	U32_MAX
+#define CIX_FAN_RPM_NOT_PRESENT	0xffff
+#define CIX_FAN_RPM_STALLED	0xfffe
+#define CIX_FAN_MAX_RPM		30000
 
 enum cix_fan_mode {
 	CIX_FAN_MODE_OFF = 0,
@@ -34,10 +43,20 @@ enum cix_fan_mode {
 	CIX_FAN_MODE_AUTO = 2,
 };
 
+enum cix_fan_rpm_encoding {
+	CIX_FAN_RPM_ENCODING_UNKNOWN,
+	CIX_FAN_RPM_ENCODING_BE,
+	CIX_FAN_RPM_ENCODING_LE,
