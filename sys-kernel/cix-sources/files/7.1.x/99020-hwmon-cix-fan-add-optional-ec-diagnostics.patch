 struct cix_fan_data {
 	struct device *dev;
 	acpi_handle handle;
 	acpi_handle pwm_get_handle;
+	acpi_handle target_get_handle;
+	acpi_handle rpm_raw_get_handle;
+	acpi_handle mode_versions_handle;
+	acpi_handle mode_get_handle;
 	const char *pwm_get_label;
 	bool pwm_get_needs_args;
 	struct mutex lock;	/* Protects ACPI fan methods and cached state. */
@@ -45,6 +64,10 @@ struct cix_fan_data {
 	unsigned long last_good_pwm_raw;
 	int pwm_enable;
 	bool has_last_good_pwm;
+	bool has_fan_input;
+	bool has_fan_target;
