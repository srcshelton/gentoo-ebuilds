 	mutex_unlock(&parmcb_dev->ordered_sd_mutex);
 
-	return armcb_subdev_register_nodes_async(&armcb_sdreg->sd);
+	ret = armcb_subdev_register_nodes_async(&armcb_sdreg->sd);
