 #define LOG_MODULE LOG_MODULE_COMMON
 #endif
 
+static bool armcb_fwnode_invalid(struct fwnode_handle *fwnode)
+{
+	struct fwnode_handle snapshot;
+
+	if (IS_ERR(fwnode) || ZERO_OR_NULL_PTR(fwnode))
+		return true;
+
+	if (copy_from_kernel_nofault(&snapshot, fwnode, sizeof(snapshot)))
+		return true;
+
+	return IS_ERR(snapshot.ops) || ZERO_OR_NULL_PTR(snapshot.ops);
+}
+
+static bool armcb_list_links_invalid(const struct list_head *list)
+{
+	return !list || ZERO_OR_NULL_PTR(list->next) ||
+	       ZERO_OR_NULL_PTR(list->prev);
+}
+
+static bool armcb_read_list_head(const struct list_head *list,
+				 struct list_head *snapshot)
+{
+	if (!list || ZERO_OR_NULL_PTR(list))
+		return true;
+
+	return copy_from_kernel_nofault(snapshot, list, sizeof(*snapshot));
+}
+
+static bool armcb_list_node_is_linked(struct list_head *node)
+{
+	struct list_head node_snapshot = {};
+	struct list_head next_snapshot = {};
+	struct list_head prev_snapshot = {};
+
+	if (armcb_read_list_head(node, &node_snapshot))
+		return false;
+
+	if (armcb_list_links_invalid(&node_snapshot))
+		return false;
+
+	if (node_snapshot.next == node && node_snapshot.prev == node)
+		return false;
+
+	if (armcb_read_list_head(node_snapshot.next, &next_snapshot) ||
+	    armcb_read_list_head(node_snapshot.prev, &prev_snapshot))
+		return false;
+
+	return next_snapshot.prev == node && prev_snapshot.next == node;
+}
+
