 int armcb_subdev_unregister(struct armcb_sd_subdev *armcb_sdreg)
 {
+	bool linked;
+
 	if (WARN_ON(!armcb_sdreg)) {
 		LOG(LOG_ERR, "Invalid pvdev/dev is NULL");
 		return -EINVAL;
 	}
 
-	v4l2_device_unregister_subdev(&armcb_sdreg->sd);
+	linked = armcb_list_node_is_linked(&armcb_sdreg->list);
+
+	if (linked)
+		list_del_init(&armcb_sdreg->list);
+	else
+		INIT_LIST_HEAD(&armcb_sdreg->list);
+
+	v4l2_async_unregister_subdev(&armcb_sdreg->sd);
 	return 0;
 }
 
