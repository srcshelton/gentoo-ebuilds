cpufreq: cppc: handle CIX OPP and Energy Model failures

Keep CPPC frequency scaling available when the CIX PEFG OPP method is
missing or invalid, but report that the CPU Energy Model cannot be
provided.  Discard partial OPP results, skip EM registration when there
are no discovered states or no CPU device, and report registration
failures instead of silently ignoring them.

diff --git a/drivers/cpufreq/cppc_cpufreq.c b/drivers/cpufreq/cppc_cpufreq.c
--- a/drivers/cpufreq/cppc_cpufreq.c
+++ b/drivers/cpufreq/cppc_cpufreq.c
@@ -632,10 +632,24 @@ static void cix_cppc_cpufreq_register_em(struct cpufreq_policy *policy)
 {
 	struct cppc_cpudata *cpu_data = policy->driver_data;
 	struct em_data_callback em_cb = EM_DATA_CB(cix_cppc_get_cpu_power);
+	struct device *cpu_dev = get_cpu_device(policy->cpu);
+	unsigned int nr_states = cix_get_perf_level_count(policy);
+	int ret;
 
-	em_dev_register_perf_domain(get_cpu_device(policy->cpu),
-				    cix_get_perf_level_count(policy), &em_cb,
-				    cpu_data->shared_cpu_map, 1);
+	if (!nr_states)
+		return;
+
+	if (!cpu_dev) {
+		pr_warn("CPU%u: no device for CIX Energy Model registration\n",
+			policy->cpu);
+		return;
+	}
+
+	ret = em_dev_register_perf_domain(cpu_dev, nr_states, &em_cb,
+					  cpu_data->shared_cpu_map, 1);
+	if (ret)
+		dev_warn(cpu_dev,
+			 "CIX Energy Model registration failed: %d\n", ret);
 }
 
 static void populate_efficiency_class(void)
@@ -816,6 +830,9 @@ static int cppc_cpufreq_cpu_init(struct cpufreq_policy *policy)
 	struct cppc_cpudata *cpu_data;
 	struct cppc_perf_caps *caps;
 	int ret;
+#ifdef CONFIG_CIX_THERMAL
+	int opp_ret;
+#endif
 
 	cpu_data = cppc_cpufreq_get_cpu_data(cpu);
 	if (!cpu_data) {
@@ -887,7 +904,12 @@ static int cppc_cpufreq_cpu_init(struct cpufreq_policy *policy)
 
 	cppc_cpufreq_cpu_fie_init(policy);
 #ifdef CONFIG_CIX_THERMAL
-	cppc_opp_init(policy);
+	opp_ret = cppc_opp_init(policy);
+	if (opp_ret) {
+		cpu_data->opp_level_num = 0;
+		pr_warn("CPU%u: CIX OPP initialization failed (%d); "
+			"Energy Model unavailable\n", cpu, opp_ret);
+	}
 #endif
 	return 0;
 
