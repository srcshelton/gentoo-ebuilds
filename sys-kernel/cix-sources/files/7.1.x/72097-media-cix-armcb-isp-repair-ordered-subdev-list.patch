diff --git a/drivers/media/platform/cix/armcb-isp/common/armcb_v4l_sd.c b/drivers/media/platform/cix/armcb-isp/common/armcb_v4l_sd.c
--- a/drivers/media/platform/cix/armcb-isp/common/armcb_v4l_sd.c
+++ b/drivers/media/platform/cix/armcb-isp/common/armcb_v4l_sd.c
@@ -28,12 +28,19 @@
 #endif
 
 #define ARMCB_CIX_DIAG_TAG "CIX72096"
+#define ARMCB_CIX_LIST_DIAG_TAG "CIX72097"
 
 static bool armcb_fwnode_invalid(struct fwnode_handle *fwnode)
 {
 	return IS_ERR(fwnode) || ZERO_OR_NULL_PTR(fwnode);
 }
 
+static bool armcb_list_links_invalid(const struct list_head *list)
+{
+	return !list || ZERO_OR_NULL_PTR(list->next) ||
+	       ZERO_OR_NULL_PTR(list->prev);
+}
+
 static void armcb_cix_diag_subdev(const char *stage, struct v4l2_subdev *sd)
 {
 	static int diag_count;
@@ -185,6 +192,30 @@ static void armcb_add_sd_in_position(struct armcb_sd_subdev *armcb_sdreg,
 {
 	struct armcb_sd_subdev *temp_sd = NULL;
 
+	if (!armcb_sdreg || !sd_list) {
+		LOG(LOG_ERR, "Invalid subdev/list");
+		return;
+	}
+
+	if (armcb_list_links_invalid(sd_list)) {
+		pr_warn("%s reinitialising ordered subdev list head=%px next=%px prev=%px sdreg=%px name=%s close_seq=0x%x\n",
+			ARMCB_CIX_LIST_DIAG_TAG, sd_list, sd_list->next,
+			sd_list->prev, armcb_sdreg, armcb_sdreg->sd.name,
+			armcb_sdreg->close_seq);
+		INIT_LIST_HEAD(sd_list);
+	}
+
+	if (armcb_list_links_invalid(&armcb_sdreg->list)) {
+		pr_warn("%s initialising subdev list node sdreg=%px name=%s next=%px prev=%px close_seq=0x%x\n",
+			ARMCB_CIX_LIST_DIAG_TAG, armcb_sdreg,
+			armcb_sdreg->sd.name, armcb_sdreg->list.next,
+			armcb_sdreg->list.prev, armcb_sdreg->close_seq);
+		INIT_LIST_HEAD(&armcb_sdreg->list);
+	} else if (!list_empty(&armcb_sdreg->list)) {
+		LOG(LOG_ERR, "failed to add an already listed subdev");
+		return;
+	}
+
 	LOG(LOG_INFO, "+");
 	list_for_each_entry(temp_sd, sd_list, list) {
 		if (temp_sd == armcb_sdreg) {
@@ -224,12 +255,25 @@ int armcb_subdev_register(struct armcb_sd_subdev *armcb_sdreg,
 		return -EINVAL;
 	}
 
+	if (WARN_ON(!armcb_sdreg)) {
+		LOG(LOG_ERR, "Invalid input armcb_sdreg is NULL");
+		return -EINVAL;
+	}
+
 	pvdev = &parmcb_dev->v4l2_dev;
 	if (WARN_ON(!pvdev) || WARN_ON(!pvdev->dev)) {
 		LOG(LOG_ERR, "Invalid pvdev/dev is NULL");
 		return -EIO;
 	}
 
+	pr_warn("%s register cam_id=%u dev=%px sdreg=%px name=%s close_seq=0x%x ordered_next=%px ordered_prev=%px node_next=%px node_prev=%px\n",
+		ARMCB_CIX_LIST_DIAG_TAG, cam_id, parmcb_dev, armcb_sdreg,
+		armcb_sdreg ? armcb_sdreg->sd.name : "<null>",
+		armcb_sdreg ? armcb_sdreg->close_seq : 0,
+		parmcb_dev->ordered_sd_list.next, parmcb_dev->ordered_sd_list.prev,
+		armcb_sdreg ? armcb_sdreg->list.next : NULL,
+		armcb_sdreg ? armcb_sdreg->list.prev : NULL);
+
 	mutex_lock(&parmcb_dev->ordered_sd_mutex);
 	armcb_add_sd_in_position(armcb_sdreg, &parmcb_dev->ordered_sd_list);
 	mutex_unlock(&parmcb_dev->ordered_sd_mutex);
