diff --git a/drivers/media/platform/cix/armcb-isp/common/armcb_v4l_sd.c b/drivers/media/platform/cix/armcb-isp/common/armcb_v4l_sd.c
--- a/drivers/media/platform/cix/armcb-isp/common/armcb_v4l_sd.c
+++ b/drivers/media/platform/cix/armcb-isp/common/armcb_v4l_sd.c
@@ -60,6 +60,28 @@ static bool armcb_read_list_head(const struct list_head *list,
 	return copy_from_kernel_nofault(snapshot, list, sizeof(*snapshot));
 }
 
+static bool armcb_list_node_is_linked(struct list_head *node)
+{
+	struct list_head node_snapshot = {};
+	struct list_head next_snapshot = {};
+	struct list_head prev_snapshot = {};
+
+	if (armcb_read_list_head(node, &node_snapshot))
+		return false;
+
+	if (armcb_list_links_invalid(&node_snapshot))
+		return false;
+
+	if (node_snapshot.next == node && node_snapshot.prev == node)
+		return false;
+
+	if (armcb_read_list_head(node_snapshot.next, &next_snapshot) ||
+	    armcb_read_list_head(node_snapshot.prev, &prev_snapshot))
+		return false;
+
+	return next_snapshot.prev == node && prev_snapshot.next == node;
+}
+
 static void armcb_cix_diag_subdev(const char *stage, struct v4l2_subdev *sd)
 {
 	static int diag_count;
@@ -322,6 +344,7 @@ int armcb_subdev_register(struct armcb_sd_subdev *armcb_sdreg,
 	char sdreg_name[64];
 	unsigned int close_seq;
 	int retry_count = 0;
+	int ret;
 	bool node_fault;
 	bool ordered_fault;
 
@@ -369,17 +392,43 @@ int armcb_subdev_register(struct armcb_sd_subdev *armcb_sdreg,
 	armcb_add_sd_in_position(armcb_sdreg, &parmcb_dev->ordered_sd_list);
 	mutex_unlock(&parmcb_dev->ordered_sd_mutex);
 
-	return armcb_subdev_register_nodes_async(&armcb_sdreg->sd);
+	ret = armcb_subdev_register_nodes_async(&armcb_sdreg->sd);
+	if (ret)
+		armcb_subdev_unregister(armcb_sdreg);
+
+	return ret;
 }
 
 int armcb_subdev_unregister(struct armcb_sd_subdev *armcb_sdreg)
 {
+	struct list_head node_snapshot = {};
+	char sdreg_name[64];
+	bool node_fault;
+	bool linked;
+
 	if (WARN_ON(!armcb_sdreg)) {
 		LOG(LOG_ERR, "Invalid pvdev/dev is NULL");
 		return -EINVAL;
 	}
 
-	v4l2_device_unregister_subdev(&armcb_sdreg->sd);
+	armcb_cix_read_sdreg_name(armcb_sdreg, sdreg_name,
+				  sizeof(sdreg_name));
+	node_fault = armcb_read_list_head(&armcb_sdreg->list,
+					  &node_snapshot);
+	linked = armcb_list_node_is_linked(&armcb_sdreg->list);
+	pr_emerg("%s unregister sdreg=%px name=%s node_fault=%d node_next=%px node_prev=%px linked=%d async_next=%px async_prev=%px\n",
+		 ARMCB_CIX_LIST_DIAG_TAG, armcb_sdreg, sdreg_name,
+		 node_fault, node_fault ? NULL : node_snapshot.next,
+		 node_fault ? NULL : node_snapshot.prev, linked,
+		 armcb_sdreg->sd.async_list.next,
+		 armcb_sdreg->sd.async_list.prev);
+
+	if (linked)
+		list_del_init(&armcb_sdreg->list);
+	else
+		INIT_LIST_HEAD(&armcb_sdreg->list);
+
+	v4l2_async_unregister_subdev(&armcb_sdreg->sd);
 	return 0;
 }
 
