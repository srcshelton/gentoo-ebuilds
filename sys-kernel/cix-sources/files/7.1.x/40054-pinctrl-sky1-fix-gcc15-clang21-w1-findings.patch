+		if (ret)
+			continue;
 		if (npins_in != num_pins)
 			continue;
 		for (j = 0; j < num_pins; j++) {
@@ -427,6 +432,7 @@ static void sky1_pinconf_group_dbg_show(struct pinctrl_dev *pctldev,
 
