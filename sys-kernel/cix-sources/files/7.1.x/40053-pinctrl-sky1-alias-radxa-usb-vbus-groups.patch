 	kfree(acpi_grp_desc);
 }
 
+static const char *sky1_acpi_group_compat_alias(const char *group)
+{
+	static const struct {
+		const char *canonical;
+		const char *alias;
+	} aliases[] = {
+		{ "pinctrl_usb0", "usb_drive_vbus0" },
+		{ "pinctrl_usb4", "usb_drive_vbus4" },
+		{ "pinctrl_usb5", "usb_drive_vbus5" },
+	};
+	int i;
+
+	for (i = 0; i < ARRAY_SIZE(aliases); i++)
+		if (!strcmp(group, aliases[i].canonical))
+			return aliases[i].alias;
+
+	return NULL;
+}
+
 static int
 sky1_pinctrl_parse_groups_acpi(struct pinctrl_acpi_group_desc *acpi_grp,
 			       struct sky1_pinctrl *spctl)
 {
+	const char *compat_alias;
+	char *group_name;
 	struct sky1_pin *pin_data;
 	unsigned int *pin_array;
 	__be16 *vendor;
@@ -710,11 +731,31 @@ sky1_pinctrl_parse_groups_acpi(struct pinctrl_acpi_group_desc *acpi_grp,
 	if (!pin_count)
 		return 0;
 
-	ret = pinctrl_generic_add_group(spctl->pctl, devm_kstrdup(spctl->dev, acpi_grp->name, GFP_KERNEL),
+	group_name = devm_kstrdup(spctl->dev, acpi_grp->name, GFP_KERNEL);
+	if (!group_name)
+		return -ENOMEM;
+
+	ret = pinctrl_generic_add_group(spctl->pctl, group_name,
 					 pin_array, pin_count, pin_data);
 	if (ret < 0)
 		dev_err(spctl->dev, "failed to add group %s: %d\n",
 			acpi_grp->name, ret);
+	if (ret < 0)
+		return ret;
+
+	compat_alias = sky1_acpi_group_compat_alias(acpi_grp->name);
+	if (!compat_alias)
+		return 0;
+
+	group_name = devm_kstrdup(spctl->dev, compat_alias, GFP_KERNEL);
+	if (!group_name)
+		return -ENOMEM;
+
+	ret = pinctrl_generic_add_group(spctl->pctl, group_name,
+					 pin_array, pin_count, pin_data);
+	if (ret < 0)
+		dev_err(spctl->dev, "failed to add compatibility group %s: %d\n",
+			compat_alias, ret);
 
 	return ret;
 }
