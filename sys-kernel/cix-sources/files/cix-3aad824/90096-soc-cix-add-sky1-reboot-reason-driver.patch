diff --git a/drivers/soc/cix/sky1-reboot-reason.c b/drivers/soc/cix/sky1-reboot-reason.c
new file mode 100644
--- /dev/null
+++ b/drivers/soc/cix/sky1-reboot-reason.c
@@ -0,0 +1,195 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * CIX Sky1 reboot reason register driver
+ */
+
+#include <linux/errno.h>
+#include <linux/io.h>
+#include <linux/mod_devicetable.h>
+#include <linux/module.h>
+#include <linux/platform_device.h>
+#include <linux/slab.h>
+
+#define SKY1_REBOOT_REASON_MASK		0xff
+#define SKY1_HW_REBOOT_REASON_MASK	0xff
+
+struct sky1_reboot_reason {
+	void __iomem *base;
+	void __iomem *hw_base;
+};
+
+static unsigned int sky1_reboot_reason_read(void __iomem *base, u32 mask)
+{
+	return readl_relaxed(base) & mask;
+}
+
+static const char *sky1_reboot_reason_name(unsigned int reason)
+{
+	switch (reason) {
+	case 0x00:
+		return "power-on-or-unknown";
+	case 0x01:
+		return "default-exception";
+	case 0x02:
+		return "watchdog-interrupt";
+	case 0x04:
+		return "warm-reset";
+	case 0xff:
+		return "invalid";
+	default:
+		return "unknown";
+	}
+}
+
+static const char *sky1_hw_reboot_reason_name(unsigned int reason)
+{
+	switch (reason) {
+	case 0x00:
+		return "rsmrst";
+	case 0x01:
+		return "str";
+	case 0x02:
+		return "sd";
+	case 0x03:
+		return "watchdog-second-timeout";
+	case 0x04:
+		return "warm-reset";
+	case 0x05:
+		return "external-reset";
+	case 0x06:
+		return "power-button-override";
+	case 0x07:
+		return "csu-se-watchdog-second-timeout";
+	default:
+		return "unknown";
+	}
+}
+
+static ssize_t raw_reason_show(struct device *dev,
+			       struct device_attribute *attr, char *buf)
+{
+	struct sky1_reboot_reason *rr = dev_get_drvdata(dev);
+
+	return sysfs_emit(buf, "0x%02x\n",
+			  sky1_reboot_reason_read(rr->base,
+						  SKY1_REBOOT_REASON_MASK));
+}
+static DEVICE_ATTR_RO(raw_reason);
+
+static ssize_t reason_show(struct device *dev,
+			   struct device_attribute *attr, char *buf)
+{
+	struct sky1_reboot_reason *rr = dev_get_drvdata(dev);
+	unsigned int reason;
+
+	reason = sky1_reboot_reason_read(rr->base, SKY1_REBOOT_REASON_MASK);
+
+	return sysfs_emit(buf, "%s\n", sky1_reboot_reason_name(reason));
+}
+static DEVICE_ATTR_RO(reason);
+
+static ssize_t raw_hw_reason_show(struct device *dev,
+				  struct device_attribute *attr, char *buf)
+{
+	struct sky1_reboot_reason *rr = dev_get_drvdata(dev);
+
+	if (!rr->hw_base)
+		return -ENODEV;
+
+	return sysfs_emit(buf, "0x%02x\n",
+			  sky1_reboot_reason_read(rr->hw_base,
+						  SKY1_HW_REBOOT_REASON_MASK));
+}
+static DEVICE_ATTR_RO(raw_hw_reason);
+
+static ssize_t hw_reason_show(struct device *dev,
+			      struct device_attribute *attr, char *buf)
+{
+	struct sky1_reboot_reason *rr = dev_get_drvdata(dev);
+	unsigned int reason;
+
+	if (!rr->hw_base)
+		return -ENODEV;
+
+	reason = sky1_reboot_reason_read(rr->hw_base,
+					 SKY1_HW_REBOOT_REASON_MASK);
+
+	return sysfs_emit(buf, "%s\n", sky1_hw_reboot_reason_name(reason));
+}
+static DEVICE_ATTR_RO(hw_reason);
+
+static struct attribute *sky1_reboot_reason_attrs[] = {
+	&dev_attr_raw_reason.attr,
+	&dev_attr_reason.attr,
+	&dev_attr_raw_hw_reason.attr,
+	&dev_attr_hw_reason.attr,
+	NULL
+};
+ATTRIBUTE_GROUPS(sky1_reboot_reason);
+
+static int sky1_reboot_reason_probe(struct platform_device *pdev)
+{
+	struct resource *res;
+	struct sky1_reboot_reason *rr;
+	unsigned int reason;
+
+	rr = devm_kzalloc(&pdev->dev, sizeof(*rr), GFP_KERNEL);
+	if (!rr)
+		return -ENOMEM;
+
+	res = platform_get_resource(pdev, IORESOURCE_MEM, 0);
+	if (!res)
+		return -EINVAL;
+
+	/*
+	 * Firmware may already reserve these always-on diagnostic registers as
+	 * system resources. Map them read-only for reporting without claiming
+	 * the regions a second time.
+	 */
+	rr->base = devm_ioremap(&pdev->dev, res->start, resource_size(res));
+	if (!rr->base)
+		return -ENOMEM;
+
+	res = platform_get_resource(pdev, IORESOURCE_MEM, 1);
+	if (res) {
+		rr->hw_base = devm_ioremap(&pdev->dev, res->start,
+					   resource_size(res));
+		if (!rr->hw_base)
+			return -ENOMEM;
+	}
+
+	platform_set_drvdata(pdev, rr);
+
+	reason = sky1_reboot_reason_read(rr->base, SKY1_REBOOT_REASON_MASK);
+	dev_info(&pdev->dev, "last reboot reason: %s (0x%02x)\n",
+		 sky1_reboot_reason_name(reason), reason);
+
+	if (rr->hw_base) {
+		reason = sky1_reboot_reason_read(rr->hw_base,
+						 SKY1_HW_REBOOT_REASON_MASK);
+		dev_info(&pdev->dev,
+			 "last hardware reboot reason: %s (0x%02x)\n",
+			 sky1_hw_reboot_reason_name(reason), reason);
+	}
+
+	return 0;
+}
+
+static const struct of_device_id sky1_reboot_reason_of_match[] = {
+	{ .compatible = "cix,sky1-reboot-reason" },
+	{ }
+};
+MODULE_DEVICE_TABLE(of, sky1_reboot_reason_of_match);
+
+static struct platform_driver sky1_reboot_reason_driver = {
+	.probe = sky1_reboot_reason_probe,
+	.driver = {
+		.name = "sky1-reboot-reason",
+		.of_match_table = sky1_reboot_reason_of_match,
+		.dev_groups = sky1_reboot_reason_groups,
+	},
+};
+module_platform_driver(sky1_reboot_reason_driver);
+
+MODULE_DESCRIPTION("CIX Sky1 reboot reason register driver");
+MODULE_LICENSE("GPL");
