arm64: cix: tighten Radxa hardware profile selections

The Radxa optional platform preset should pull in the RTS5453 controller
driver as well as the Type-C core. Select the CIX USB-DP PHY when Type-C
is enabled so a built-in profile cannot leave the mux/orientation provider
as an unavailable module, while modular profiles still resolve to module
state through Kconfig tristate propagation.

The current Orion ACPI USB host-controller model uses generic PNP0D10 xHCI
nodes and keeps CIXH2033 as the USB-DP Type-C PHY companion. Do not pull in
the Cadence CDNSP host-controller stack, gadget path, or the overlapping
CIX PCIe/USB2/USB3 PHY presets for ACPI profiles; keep them available for
DT profiles where the recovered DTB describes the vendor controller model.

The recovered Radxa O6 DTB also describes the onboard Hym8563 RTC, so let
DT profiles select that upstream RTC driver while ACPI profiles continue to
use the EFI RTC path.

---
diff --git a/drivers/platform/arm64/Kconfig.radxa b/drivers/platform/arm64/Kconfig.radxa
--- a/drivers/platform/arm64/Kconfig.radxa
+++ b/drivers/platform/arm64/Kconfig.radxa
@@ -22,6 +22,7 @@ config CIX_RADXA_ESSENTIAL
 	imply ACPI_BUTTON if CIX_RADXA_ORION_ACPI
 	imply ACPI_FAN if CIX_RADXA_ORION_ACPI
 	imply ACPI_THERMAL if CIX_RADXA_ORION_ACPI
+	imply RTC_DRV_HYM8563 if CIX_RADXA_ORION_DT
 	help
 	  Keep the smallest always-on set that is useful on current
 	  Orion O6/O6N systems.
@@ -48,16 +49,19 @@ config CIX_RADXA_OPTIONAL_PLATFORM
 	default m if MODULES && (CIX_RADXA_ORION_O6 || CIX_RADXA_ORION_O6N)
 	default y if !MODULES && (CIX_RADXA_ORION_O6 || CIX_RADXA_ORION_O6N)
 	imply TYPEC
+	imply TYPEC_RTS5453
 	imply CIX_DDR_LP
 	imply CIX_CPU_IPA
-	imply USB_CDNS_SUPPORT
-	imply USB_CDNSP
-	imply USB_CDNSP_HOST
-	imply USB_CDNSP_SKY1
-	imply PHY_CIX_PCIE
-	imply PHY_CIX_USB2
-	imply PHY_CIX_USB3
-	imply PHY_CIX_USBDP
+	imply USB_CDNS_SUPPORT if CIX_RADXA_ORION_DT
+	imply USB_CDNSP if CIX_RADXA_ORION_DT
+	imply USB_CDNSP_HOST if CIX_RADXA_ORION_DT
+	imply USB_GADGET if CIX_RADXA_ORION_DT
+	imply USB_CDNSP_GADGET if CIX_RADXA_ORION_DT
+	imply USB_CDNSP_SKY1 if CIX_RADXA_ORION_DT
+	imply PHY_CIX_PCIE if CIX_RADXA_ORION_DT
+	imply PHY_CIX_USB2 if CIX_RADXA_ORION_DT
+	imply PHY_CIX_USB3 if CIX_RADXA_ORION_DT
+	select PHY_CIX_USBDP if TYPEC && (ACPI || OF)
 	imply SKY1_PDC
 	imply I2C_CADENCE
 	imply GPIO_CADENCE
@@ -72,6 +76,8 @@ config CIX_RADXA_OPTIONAL_PLATFORM
 	imply CLK_SKY1_ACPI if CIX_RADXA_ORION_ACPI
 	imply CIX_ACPI_RESOURCE_LOOKUP if CIX_RADXA_ORION_ACPI
 	imply CIX_BUS_PERF if CIX_RADXA_ORION_ACPI
+	imply SENSORS_CIX_FAN if CIX_RADXA_ORION_ACPI
+	imply CIX_SKY1_REBOOT_REASON if CIX_RADXA_ORION_ACPI
 	help
 	  Enable the vendor Sky1 platform-resource plumbing used by
 	  the CIX ACPI and DT driver stack. CIX_SKY1_SOCINFO is
