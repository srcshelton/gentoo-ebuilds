ACPI thermal: expose zone _STR labels through hwmon

ACPI thermal zones may provide a human-readable _STR description, but the generic thermal hwmon bridge currently exposes only numbered temp inputs. Preserve an optional thermal-zone label in thermal_zone_params, let thermal_hwmon expose it as tempN_label, and populate it from ACPI thermal-zone _STR buffers.

This lets table-upgrade firmware attach useful labels to acpitz sensors without userspace lm-sensors configuration.

---
diff --git a/drivers/acpi/thermal.c b/drivers/acpi/thermal.c
--- a/drivers/acpi/thermal.c
+++ b/drivers/acpi/thermal.c
@@ -23,6 +23,7 @@
 #include <linux/types.h>
 #include <linux/jiffies.h>
 #include <linux/kmod.h>
+#include <linux/nls.h>
 #include <linux/reboot.h>
 #include <linux/sched.h>
 #include <linux/device.h>
@@ -121,6 +122,7 @@ struct acpi_thermal {
 	volatile u8 zombie;
 	bool has_last_good_temp;
 	bool orion_o6_ectz;
+	char *label;
 	struct acpi_thermal_trips trips;
 	struct thermal_zone_device *thermal_zone;
 	int kelvin_offset;	/* in millidegrees */
@@ -170,6 +172,46 @@ static int acpi_thermal_read_tmp(struct acpi_thermal *tz,
 	return 0;
 }
 
+static char *acpi_thermal_get_label(struct acpi_device *device)
+{
+	struct acpi_buffer buffer = { ACPI_ALLOCATE_BUFFER, NULL };
+	union acpi_object *str_obj;
+	acpi_status status;
+	char *label = NULL;
+	int label_len;
+	int maxout;
+
+	status = acpi_evaluate_object_typed(device->handle, "_STR", NULL,
+					    &buffer, ACPI_TYPE_BUFFER);
+	if (ACPI_FAILURE(status))
+		return NULL;
+
+	str_obj = buffer.pointer;
+	if (!str_obj->buffer.pointer || !str_obj->buffer.length)
+		goto out_free;
+
+	if (str_obj->buffer.length > (INT_MAX - 1) / 2)
+		goto out_free;
+
+	maxout = str_obj->buffer.length * 2 + 1;
+	label = kzalloc(maxout, GFP_KERNEL);
+	if (!label)
+		goto out_free;
+
+	label_len = utf16s_to_utf8s((wchar_t *)str_obj->buffer.pointer,
+				    str_obj->buffer.length / sizeof(wchar_t),
+				    UTF16_LITTLE_ENDIAN, label, maxout - 1);
+	if (label_len <= 0) {
+		kfree(label);
+		label = NULL;
+	}
+
+out_free:
+	ACPI_FREE(buffer.pointer);
+
+	return label;
+}
+
 static void acpi_thermal_save_last_good_tmp(struct acpi_thermal *tz,
 					    unsigned long long tmp)
 {
@@ -759,16 +801,20 @@ static int acpi_thermal_register_thermal_zone(struct acpi_thermal *tz,
 					      unsigned int trip_count,
 					      int passive_delay)
 {
+	struct thermal_zone_params tzp = {
+		.label = tz->label,
+	};
+	const struct thermal_zone_params *tzp_ptr = tz->label ? &tzp : NULL;
 	int result;
 
 	if (trip_count)
 		tz->thermal_zone = thermal_zone_device_register_with_trips(
 					"acpitz", trip_table, trip_count, tz,
-					&acpi_thermal_zone_ops, NULL, passive_delay,
+					&acpi_thermal_zone_ops, tzp_ptr, passive_delay,
 					tz->polling_frequency * 100);
 	else
 		tz->thermal_zone = thermal_tripless_zone_device_register(
-					"acpitz", tz, &acpi_thermal_zone_ops, NULL);
+					"acpitz", tz, &acpi_thermal_zone_ops, tzp_ptr);
 
 	if (IS_ERR(tz->thermal_zone))
 		return PTR_ERR(tz->thermal_zone);
@@ -913,6 +959,7 @@ static void acpi_thermal_free_thermal_zone(struct acpi_thermal *tz)
 	for (i = 0; i < ACPI_THERMAL_MAX_ACTIVE; i++)
 		acpi_handle_list_free(&tz->trips.active[i].trip.devices);
 
+	kfree(tz->label);
 	kfree(tz);
 }
 
@@ -936,6 +983,7 @@ static int acpi_thermal_add(struct acpi_device *device)
 
 	tz->device = device;
 	tz->orion_o6_ectz = acpi_thermal_is_radxa_orion_o6_ectz(tz);
+	tz->label = acpi_thermal_get_label(device);
 	strscpy(tz->name, device->pnp.bus_id);
 	strscpy(acpi_device_name(device), ACPI_THERMAL_DEVICE_NAME);
 	strscpy(acpi_device_class(device), ACPI_THERMAL_CLASS);
diff --git a/drivers/thermal/thermal_hwmon.c b/drivers/thermal/thermal_hwmon.c
--- a/drivers/thermal/thermal_hwmon.c
+++ b/drivers/thermal/thermal_hwmon.c
@@ -39,6 +39,7 @@ struct thermal_hwmon_temp {
 	struct list_head hwmon_node;
 	struct thermal_zone_device *tz;
 	struct thermal_hwmon_attr temp_input;	/* hwmon sys attr */
+	struct thermal_hwmon_attr temp_label;	/* hwmon sys attr */
 	struct thermal_hwmon_attr temp_crit;	/* hwmon sys attr */
 };
 
@@ -66,6 +67,23 @@ temp_input_show(struct device *dev, struct device_attribute *attr, char *buf)
 	return sprintf(buf, "%d\n", temperature);
 }
 
+static ssize_t
+temp_label_show(struct device *dev, struct device_attribute *attr, char *buf)
+{
+	struct thermal_hwmon_attr *hwmon_attr
+			= container_of(attr, struct thermal_hwmon_attr, attr);
+	struct thermal_hwmon_temp *temp
+			= container_of(hwmon_attr, struct thermal_hwmon_temp,
+				       temp_label);
+	struct thermal_zone_device *tz = temp->tz;
+	const char *label = tz->tzp ? tz->tzp->label : NULL;
+
+	if (!label)
+		return -ENODATA;
+
+	return sysfs_emit(buf, "%s\n", label);
+}
+
 static ssize_t
 temp_crit_show(struct device *dev, struct device_attribute *attr, char *buf)
 {
@@ -132,6 +150,11 @@ static bool thermal_zone_crit_temp_valid(struct thermal_zone_device *tz)
 	return tz->ops.get_crit_temp && !tz->ops.get_crit_temp(tz, &temp);
 }
 
+static bool thermal_zone_hwmon_label_valid(struct thermal_zone_device *tz)
+{
+	return tz->tzp && tz->tzp->label && tz->tzp->label[0];
+}
+
 int thermal_add_hwmon_sysfs(struct thermal_zone_device *tz)
 {
 	struct thermal_hwmon_device *hwmon;
@@ -179,6 +202,20 @@ int thermal_add_hwmon_sysfs(struct thermal_zone_device *tz)
 	if (result)
 		goto free_temp_mem;
 
+	if (thermal_zone_hwmon_label_valid(tz)) {
+		snprintf(temp->temp_label.name,
+			 sizeof(temp->temp_label.name),
+			 "temp%d_label", hwmon->count);
+		temp->temp_label.attr.attr.name = temp->temp_label.name;
+		temp->temp_label.attr.attr.mode = 0444;
+		temp->temp_label.attr.show = temp_label_show;
+		sysfs_attr_init(&temp->temp_label.attr.attr);
+		result = device_create_file(hwmon->device,
+					    &temp->temp_label.attr);
+		if (result)
+			goto unregister_input;
+	}
+
 	if (thermal_zone_crit_temp_valid(tz)) {
 		snprintf(temp->temp_crit.name,
 				sizeof(temp->temp_crit.name),
@@ -190,7 +227,7 @@ int thermal_add_hwmon_sysfs(struct thermal_zone_device *tz)
 		result = device_create_file(hwmon->device,
 					    &temp->temp_crit.attr);
 		if (result)
-			goto unregister_input;
+			goto unregister_label;
 	}
 
 	mutex_lock(&thermal_hwmon_list_lock);
@@ -201,6 +238,9 @@ int thermal_add_hwmon_sysfs(struct thermal_zone_device *tz)
 
 	return 0;
 
+ unregister_label:
+	if (thermal_zone_hwmon_label_valid(tz))
+		device_remove_file(hwmon->device, &temp->temp_label.attr);
  unregister_input:
 	device_remove_file(hwmon->device, &temp->temp_input.attr);
  free_temp_mem:
@@ -235,6 +275,8 @@ void thermal_remove_hwmon_sysfs(struct thermal_zone_device *tz)
 	}
 
 	device_remove_file(hwmon->device, &temp->temp_input.attr);
+	if (thermal_zone_hwmon_label_valid(tz))
+		device_remove_file(hwmon->device, &temp->temp_label.attr);
 	if (thermal_zone_crit_temp_valid(tz))
 		device_remove_file(hwmon->device, &temp->temp_crit.attr);
 
diff --git a/include/linux/thermal.h b/include/linux/thermal.h
--- a/include/linux/thermal.h
+++ b/include/linux/thermal.h
@@ -152,6 +152,11 @@ struct thermal_zone_params {
 	 */
 	bool no_hwmon;
 
+	/*
+	 * Optional human-readable label for the thermal zone's hwmon input.
+	 */
+	const char *label;
+
 	/*
 	 * Sustainable power (heat) that this thermal zone can dissipate in
 	 * mW
