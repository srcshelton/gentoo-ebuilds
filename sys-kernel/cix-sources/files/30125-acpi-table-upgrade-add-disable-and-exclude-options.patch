+		file = find_cpio_data(ACPI_TABLE_UPGRADE_PATH, data, size,
+				      &offset);
 		if (!file.data)
 			break;
 
 		data += offset;
 		size -= offset;
+		excluded = acpi_table_upgrade_is_excluded(ACPI_TABLE_UPGRADE_PATH,
+							  file.name);
 
 		if (file.size < sizeof(struct acpi_table_header)) {
+			if (excluded) {
+				pr_info("Table Upgrade: skip [????-??????-????????] (%s%s): excluded by acpi_table_upgrade.exclude\n",
+					ACPI_TABLE_UPGRADE_PATH, file.name);
+				continue;
+			}
 			pr_err("ACPI OVERRIDE: Table smaller than ACPI header [%s%s]\n",
-				cpio_path, file.name);
+				ACPI_TABLE_UPGRADE_PATH, file.name);
 			continue;
 		}
 
 		table = file.data;
 
+		if (excluded) {
+			pr_info("%4.4s ACPI table found in initrd [%s%s][0x%x] excluded by acpi_table_upgrade.exclude\n",
+				table->signature, ACPI_TABLE_UPGRADE_PATH,
+				file.name, table->length);
+			pr_info("Table Upgrade: skip [%4.4s-%6.6s-%8.8s] (%s%s)\n",
+				table->signature, table->oem_id,
+				table->oem_table_id, ACPI_TABLE_UPGRADE_PATH,
+				file.name);
+			continue;
+		}
+
 		for (sig = 0; sig < ARRAY_SIZE(table_sigs); sig++)
 			if (!memcmp(table->signature, table_sigs[sig], 4))
 				break;
 
 		if (sig >= ARRAY_SIZE(table_sigs)) {
 			pr_err("ACPI OVERRIDE: Unknown signature [%s%s]\n",
-				cpio_path, file.name);
+				ACPI_TABLE_UPGRADE_PATH, file.name);
 			continue;
 		}
 		if (file.size != table->length) {
 			pr_err("ACPI OVERRIDE: File length does not match table length [%s%s]\n",
-				cpio_path, file.name);
+				ACPI_TABLE_UPGRADE_PATH, file.name);
 			continue;
 		}
 		if (acpi_table_checksum(file.data, table->length)) {
 			pr_err("ACPI OVERRIDE: Bad table checksum [%s%s]\n",
-				cpio_path, file.name);
+				ACPI_TABLE_UPGRADE_PATH, file.name);
 			continue;
 		}
 
-		pr_info("%4.4s ACPI table found in initrd [%s%s][0x%x]\n",
-			table->signature, cpio_path, file.name, table->length);
+		pr_info("%4.4s ACPI table found in initrd [%s%s][0x%x] [%4.4s-%6.6s-%8.8s]\n",
+			table->signature, ACPI_TABLE_UPGRADE_PATH, file.name,
+			table->length, table->signature, table->oem_id,
+			table->oem_table_id);
 
 		all_tables_size += table->length;
 		acpi_initrd_files[table_nr].data = file.data;
