 drivers/clk/cix/Makefile        |   1 +
 drivers/clk/cix/clk-sky1-acpi.c | 173 ++++++++++++++++++++++++++++++++
 drivers/clk/clk-scmi.c          |  32 +++++-
 4 files changed, 220 insertions(+), 2 deletions(-)
 create mode 100644 drivers/clk/cix/clk-sky1-acpi.c

