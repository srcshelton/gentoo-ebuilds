+#ifndef __V3_2_H__
+#define __V3_2_H__
+
+/**************************************************************************************
+ *                             Cluster [N] Registers
+ *************************************************************************************/
+/**
+ * Cluster Range Base Address
+ *
+ * 0xC00 ~ 0xC1F    Cluster 0
+ * 0xC20 ~ 0xC3F    Cluster 1
+ * 0xC40 ~ 0xC5F    Cluster 2
+ * ...
+ * 0xCE0 ~ 0xCFF    Cluster 7
+ */
+#define _GET_CLUSTER_OFFSET_V3_2(id)                     (0xC00 + 0x20 * (id))
+#define MAX_CLUSTER_NUM_V3_2                             8
+
+#define _GET_CLUSTER_FETR_V3_2(id)                     (0x2800 + 0x70 * (id))
+
+/**
+ * A1.1.1 Cluster Configuration Register (Read-Only)
+ * [31-13]  Reserved
+ * [12]     set if cluster is present
+ * [11:8]   number of available AIPU cores
+ * [7:4]    number of available AIFF in every core
+ * [3:0]    number of available TEC in every core
+ */
+#define IS_CLUSTER_PRESENT_V3_2(config_32)               (((config_32) >> 12) & 0x1)
+#define GET_AIPU_CORE_NUM_V3_2(config_32)                (((config_32) >> 8) & 0xF)
+#define GET_AIFF_NUM_V3_2(config_32)                     (((config_32) >> 4) & 0xF)
+#define GET_TEC_NUM_V3_2(config_32)                      ((config_32) & 0xF)
+#define GET_NUMS_V3_2(config_32)                         ((config_32) & 0xFFF)
+#define CLUSTER_CONFIG_REG_V3_2(id)                      (_GET_CLUSTER_OFFSET_V3_2(id) + 0x0)
+
+/*
+ * A1.1.2 Cluster Control Register
+ * [31:24] core enable bits (27:24: core 3 - core 0; )
+ * [23:13] reserved (RO)
+ * [12]    cluster enable (RO)
+ * [11:8]  Core enable number (RO)
+ * [7:4]   AIFF enable number (RO)
+ * [3:0]   TEC enable number (RO)
+ * [3:0] number of TEC enabled in every core (RO)
+ */
+#define _ENABLE_CORE_V3_2(core_en)                      ((core_en) << 24)
+#define _ENABLE_CLUSTER_V3_2                             (0x1 << 12)
+#define _DISABLE_CLUSTER_V3_2                            (0x0 << 12)
+#define _EN_CORE_NUM_V3_2(num)                           (((num) & 0xF) << 8)
+#define _EN_AIFF_NUM_V3_2(num)                           (((num) & 0xF) << 4)
+#define _EN_TEC_NUM_V3_2(num)                            ((num) & 0xF)
+#define EN_NUMS_V3_2(nums)                               ((nums) & 0xFFF)
+#define ENABLE_CLUSTER_V3_2(partition, nums) \
+	(EN_NUMS_V3_2(nums) | _ENABLE_CLUSTER_V3_2)
+#define DISABLE_CLUSTER_V3_2                             _DISABLE_CLUSTER_V3_2
+#define CONFIG_CLUSTER_V3_2(core_en, en_core_num, en_aiff, en_tec, par_mode) \
+	(_ENABLE_CORE_V3_2(core_en) | \
+	 _EN_CORE_NUM_V3_2(en_core_num) | \
+	 _EN_AIFF_NUM_V3_2(en_aiff) | \
+	 _EN_TEC_NUM_V3_2(en_tec) | \
+	 _ENABLE_CLUSTER_V3_2 | (par_mode))
+
+#define CLUSTER_CONTROL_REG_V3_2(id)                     (_GET_CLUSTER_OFFSET_V3_2(id) + 0x4)
+
+/*
+ * A.3.41 Cluster Global Memory Feature Register
+ * [31:12] reserved (RO)
+ * [11:8]  Banks (RO)
+ * [7:4]   Width (RO)
+ * [3:0]   Size (RO) 512k * 2^size
+ */
+#define CLUSTER_GM_FEATURE_V3_2(id)                     (_GET_CLUSTER_FETR_V3_2(id) + 0x58)
+
+/*****************************************************************************
+ *                             TSM Registers
+ *****************************************************************************/
+/**
+ * TSM Command Schedule Control Handle Register
+ *
+ * [31:28] Write to select a cluster for direct dispatching
+ * [27:24] Write to select a core for direct dispatching
+ * [23:20] Reserved (RO)
+ * [19]    Command pool type
+ *         0: PCP
+ * [18:16] Write to select a command pool
+ *         0 command pool 0 sellected
+ * [15:13] Reserved (RO)
+ * [12]    0 to map one cluster to this command pool (RO)
+ *         1) Only works for command pool creation
+ *         2) R/O for single cluster TSM
+ * [11:10] Reserved (RO)
+ * [9:8]   QOS 0 slow, 1 Media, 2 fast (reserved in LIN), 3 reserved
+ * [7:4]   Reserved (RO)
+ * [3:0]   command tpye:0 none, 1 create, 2 destroy, 3 Abortion,
+ *                      4 Dispatch,5 direct dispatch, 6 Others.
+ */
+#define _TSM_DIRECT_CLUSTER_V3_2(cluser)                  ((cluster) << 28)
+#define _TSM_DIRECT_CORE_V3_2(core)                       ((core) << 24)
+#define _TSM_POOL_V3_2(pool)                              ((pool) << 16)
+#define _TSM_MAP_V3_2(map)                                ((map) << 12)
+#define _TSM_QOS_V3_2(qos)                                ((qos) << 8)
+#define _TSM_CREATE_V3_2                                  0x1
+#define _TSM_DESTROY_V3_2                                 0x2
+#define _TSM_ABORT_V3_2                                   0x3
+#define _TSM_DISPATCH_V3_2                                0x4
+#define _TSM_BIND_DISPATCH_V3_2                           0x5
+
+#define TSM_MAP_SINGLE_V3_2                              _TSM_MAP_V3_2(0x0)
+#define TSM_MAP_ALL_V3_2                                 _TSM_MAP_V3_2(0x1)
+#define TSM_CREATE_CMD_POOL_V3_2(pool, map)              (_TSM_CREATE_V3_2 | _TSM_POOL_V3_2(pool) | (map))
+#define TSM_DESTROY_CMD_POOL_V3_2(pool)                  (_TSM_DESTROY_V3_2 | _TSM_POOL_V3_2(pool))
+#define TSM_ABORT_CMD_POOL_V3_2(pool)                    (_TSM_ABORT_V3_2 | _TSM_POOL_V3_2(pool))
+#define TSM_BIND_DISPATCH_CMD_POOL_V3_2(pool, qos, core)  (_TSM_BIND_DISPATCH_V3_2 | (qos) | \
+						     _TSM_POOL_V3_2(pool) | _TSM_DIRECT_CORE_V3_2(core))
+
+#define TSM_CMD_SCHD_CTRL_HANDLE_REG_V3_2             0x0
+#define TSM_DISPATCH_CMD_POOL_V3_2(pool, qos)         (_TSM_DISPATCH_V3_2 | (qos) | (pool))
+
+/**
+ * A1.1.6 TSM Command Schedule Address High Register
+ *
+ * [31:0] Write to set the address[63:32] of head of a TCB chain to be dispatched
+ */
+#define TSM_CMD_SCHD_ADDR_HIGH_REG_V3_2               0x8
+
+/**
+ * A1.1.7 TSM Command Schedule Address Low Register
+ *
+ * [31:12] Write to set the address[31:12] of head of a TCB chain to
+ *         be dispatched
+ *         1) this address shall be 4k page aligned
+ */
+#define TSM_CMD_SCHD_ADDR_LOW_REG_V3_2                0xC
+
+/**
+ * A1.1.9 TSM Configuration Register
+ * [31:4] Reserved (RO)
+ * [3:0]  TSM scheduling policy
+ */
+#define TSM_CONFIG_REG_V3_2                           0x10
+
+/**
+ * TSM Build Info Register (Read-Only)
+ *
+ * [25:24] Partition mode: 0
+ * [19:16] Supported command pool number: 1/2
+ *
+ * other fields are the same as v3
+ */
+#define TSM_BUILD_INFO_REG_V3_2                       0x14
+#define GET_CMD_POOL_NUM_V3_2(build_info_32)          ((((build_info_32) >> 16) & 0xF) + 1)
+
+/**
+ * TSM Status Register
+ * [31]    scheduling cmd fail
+ * [30:24] Reserved (RO)
+ * [23:16] TSM abort command pool done
+ * [15:12] Reserved
+ * [11:8]  TSM PCP (QoS high) is full
+ * [7:4]   Reserved
+ * [3:0]   TSM PCP (QoS low) is full
+ */
+#define PCP_ABORT_DONE_BIT                          16
+#define IS_ABORT_DONE(status_32, done_bit)          (((status_32) >> (done_bit)) & 0x1)
+#define CLEAR_ABORT(done_bit)                       ((~(1 << (done_bit))) & (0x7FFFFFFF))
+#define IS_PCP_FULL(status, high)                   (((status) >> ((high) ? 8 : 0)) & 0x1)
+#define IS_CMD_FAIL_V3_2(status_32)                   ((status_32) >> 31)
+#define IS_CMD_POOL_FULL_V3_2(status_32)              ((status_32) & 0xFF)
+#define CLEAR_CMD_FAIL_V3_2(status_32)                ((status_32) & 0x7FFFFFFF)
+#define TSM_STATUS_REG_V3_2                           0x18
+
+/**
+ * A1.1.8 TSM Command Schedule TCB Number Register
+ *
+ * [31:0] TCB number of chain
+ */
+#define TSM_COMMAND_SCHEDULE_TCB_NUM_REG_V3_2         0x1C
+
+/**************************************************************************************
+ *                             Debug Link Access Registers
+ *************************************************************************************/
+/**
+ * A1.1.28 AHB Internal CSR Selection Control Register
+ *
+ * [12]   debug enable
+ * [11:4] cluster selection
+ * [3:0]  core selection
+ */
+#define _ENABLE_DEBUG_V3_2                            BIT(12)
+#define _SET_DBG_CLUSTER_V3_2(id)                     (((id) & 0xFF) << 4)
+#define _SET_DBG_CORE_V3_2(id)                        ((id) & 0xF)
+#define SELECT_DEBUG_CORE_V3_2(cluster, core)         (_ENABLE_DEBUG_V3_2 | \
+			_SET_DBG_CLUSTER_V3_2(cluster) | _SET_DBG_CORE_V3_2(core))
+#define DISABLE_DEBUG_V3_2                            0
+#define AHB_INTERNAL_CSR_SELECTION_CTRL_REG         0x1F00
+#define CLUSTER_MMR_WIN_BASE                        (0x2000)
+#define CORE_MMR_WIN_BASE                           (0x3000)
+
+/**
+ * A1.1.8 TSM Revision Register (Read-Only)
+ *
+ * [27:24] implementation ID
+ * [23:16] primary part number
+ * [15:8]  secondary part number
+ * [7:4]   major revision ID
+ * [3:0]   minor number
+ */
+#define _IS_TSM_ARCH_V3_2(rev_32)                     (((rev_32) >> 16) & 0x1)
+#define _IS_V3_2_ARCH(rev_32)                         ((((rev_32) >> 8) & 0x1))
+
+#define TSM_REVISION_REG_V3_2                         0x50
+
+/**
+ * A1.1.22 Tick Counter Control Status Register
+ *
+ * [8] counter overflow flag
+ * [1] clear
+ * [0] enable
+ */
+#define IS_COUNTER_OVERFLOW_V3_2(status_32)           (((status_32) >> 8) & 0x1)
+#define CLEAR_COUNTER_V3_2                            BIT(1)
+#define ENABLE_COUNTER_V3_2                           0x1
+#define DISABLE_COUNTER_V3_2                          ((CLEAR_COUNTER_V3_2))
+
+#define TICK_COUNTER_CONTROL_STATUS_REG_V3_2          0x68
+
+/**
+ * TSM Interrupt Status Register
+ *
+ * Bit 0 - 15: TSM interrupt 0 - 15
+ */
+#define TSM_CLEAR_INTERRUPT_V3_2(i)                   BIT(i)
+#define GET_V3_2_IRQS_BITS(status)                    ((status) & 0xFFFF)
+#define IS_ALL_CLEAR_IDLE(status)		    (status&0xFFFF0000)
+
+#define TSM_INTERRUPT_STATUS_REG                    0x80
+#define TSM_IRQ_MAX_NUM                             16
+
+/**************************************************************************************
+ *                             TSM Command Pool (PCP) Registers
+ *************************************************************************************/
+#define _TSM_PCP_REGISTERS_BASE                     0x800
+
+/**************************************************************************************
+ *                             HOST TSM PMU Register
+ *************************************************************************************/
+/**
+ * A1.1.32 PMU TOP Soft Reset
+ *
+ * [1] soft reset status bit
+ *     1) host write 0 to launch AIPU soft reset
+ *     2) AIPU write 1 when a soft reset is done
+ * [0] soft reset config bit
+ *     1) host write 1 to launch AIPU soft reset
+ *     2) AIPU write 0 when a soft reset is done
+ */
+#define PMU_TOP_SOFT_RESET_REG                      (0x20)
+
+/**
+ * A1.1.33 PMU Cluster Soft Reset
+ *
+ * [7:4] soft reset status bit
+ *     1) host write 0 to clear it after reading
+ *     2) AIPU write 1 when a soft reset is done
+ * [3:0] cluster soft reset config bit
+ *     1) host write 1 to launch AIPU soft reset
+ *     2) AIPU write 0 when a soft reset is done
+ */
+#define CONFIG_PMU_CLUSTER_RESET(cluster)           (1 << ((cluster) & 0xF))
+#define PMU_CLUSTER_RESET_DONE(cluster)			(1 << (((cluster) & 0xF) + 4))
+#define PMU_CLUSTER_RESET_REG                       (0x24)
+
+/**
+ * A1.1.34 PMU Core Soft Reset
+ *
+ * [31:16] soft reset status bit
+ *     1) host write 0 to clear it after reading
+ *     2) AIPU write 1 when a soft reset is done
+ * [15:0] cluster soft reset config bit
+ *     1) host write 1 to launch AIPU soft reset
+ *     2) AIPU write 0 when a soft reset is done
+ */
+#define CONFIG_PMU_CORE_RESET(cluster, core)	(1 << (((core) & 0xFF) + \
+								((cluster) & 0xF) * 4))
+#define PMU_CORE_RESET_DONE(cluster, core)		(1 << (((core) & 0xFF) + \
+								(((cluster) & 0xF) * 4) + 16))
+#define PMU_CORE_RESET_REG                          (0x28)
+
+/**
+ * A1.1.35 PMU Reset Timeout
+ *
+ * [31:16] core reset timeout flag bit
+ *     1) host write 0 to clear it after reading
+ *     2) AIPU write 1 when there is reset request.
+ * [3:0] Cluster reset timeout flag
+ *     1) host write 0 to clear it after reading
+ *     2) AIPU write 1 when there is reset request.
+ */
+#define PMU_RESET_TIMEOUT_REG                       (0x2c)
+
+/**
+ * A1.1.36 PMU Top Clock and Power Control Register
+ *
+ * [31:3] reserved
+ * [2]    secure/non-secure mode (0/1)
+ * [1]    clock gating disabled/enabled (0/1)
+ * [0]    PMU disabled/enabled (0/1)
+ */
+#define PMU_SECURE_MODE                             BIT(2)
+#define PMU_NONSECURE_MODE                          0
+#define PMU_ENABLE_CLOCK_GATING                     BIT(1)
+#define PMU_DISABLE_CLOCK_GATING                    0
+#define PMU_ENABLE                                  BIT(0)
+#define PMU_DISABLE                                 0
+#define PMU_TOP_CLOCK_POWER_CTRL_REG                0x30
+
+/**
+ * TSM Command Pool [N] Status PCP Register
+ *
+ * [31:24]: cluster physical ID
+ * [6]: idle (0: busy; 1: idle)
+ * [5]: timeout (0: none; 1: MIF timeout)
+ * [4]: error (0: none; 1: pool error)
+ * [0]: done (0: none; 1: pool done)
+ */
+#define IS_POOL_DONE(val)                           ((val) & 0x1)
+#define IS_POOL_ERROR(val)                          (((val) >> 4) & 0x1)
+#define IS_POOL_TIMEOUT(val)                        (((val) >> 5) & 0x1)
+#define IS_POOL_BUSY(val)                           (!(((val) >> 6) & 0x1))
+#define IS_POOL_CID(val)                            ((val) >> 24)
+#define CLEAR_POOL_DONE                             BIT(0)
+
+#define COMMAND_POOL_PCP_STATUS_REG                 (_TSM_PCP_REGISTERS_BASE + 0x4)
+
+/**
+ * A1.1.20 TSM Command Pool [N] Interrupt Control PCP Register
+ * [31:12] Reserved (RO)
+ * [11] command pool interrupt enable
+ * [10] cluster interrupt enable
+ * [9]  core interrupt enable
+ * [8]  tec interrupt enable
+ * [6]  timeout interrupt enable
+ * [5]  signal interrupt enable
+ * [4]  error interrupt enable
+ * [3]  fault interrupt enable
+ * [2]  exception interrupt enable
+ * [0]  done interrupt enable
+ */
+#define EN_CMD_POOL_INTR_V3_2                         BIT(11)
+#define EN_CLUSTER_INTR_V3_2                          BIT(10)
+#define EN_CORE_INTR_V3_2                             BIT(9)
+#define EN_TEC_INTR_V3_2                              BIT(8)
+#define EN_TIMEOUT_INTR_V3_2                          BIT(5)
+#define EN_ERROR_INTR_V3_2                            BIT(4)
+#define EN_FAULT_INTR_V3_2                            BIT(3)
+#define EN_EXCEPTION_INTR_V3_2                        BIT(2)
+#define EN_SIGNAL_INTR_V3_2                           BIT(1)
+#define EN_DONE_INTR_V3_2                             BIT(0)
+
+#define EN_ALL_TYPE_INTRS_V3_2 \
+						(EN_SIGNAL_INTR_V3_2 | EN_ERROR_INTR_V3_2 | \
+						EN_FAULT_INTR_V3_2 | EN_EXCEPTION_INTR_V3_2 | \
+						EN_DONE_INTR_V3_2 | EN_TIMEOUT_INTR_V3_2)
+
+#define EN_ALL_LEVEL_INTRS_V3_2 \
+						(EN_CMD_POOL_INTR_V3_2 | EN_CLUSTER_INTR_V3_2 | \
+						 EN_CORE_INTR_V3_2 | EN_TEC_INTR_V3_2)
+#define EN_CMD_POOL_ALL_INTRS_V3_2  (EN_CMD_POOL_INTR_V3_2 | EN_ALL_TYPE_INTRS_V3_2)
+#define EN_ALL_INTRS_V3_2           (EN_ALL_LEVEL_INTRS_V3_2 | EN_ALL_TYPE_INTRS_V3_2)
+#define DISABLE_ALL_INTRS_V3_2                           0
+
+#define COMMAND_POOL_PCP_INTERRUPT_CONTROL_REG      (_TSM_PCP_REGISTERS_BASE + 0x8)
+
+/**************************************************************************************
+ *                             Interrupt Registers (Per Interrupt)
+ *************************************************************************************/
+/**
+ * Per interrupt registers
+ *
+ * 0xA00: interrupt 0
+ * 0xA10: interrupt 1
+ * 0xA20: interrupt 2
+ * ...
+ * 0xAf0: interrupt 15
+ */
+
+#define _GET_PER_INTERRUPT_REGISTER_OFFSET(id)      (0xA00 + 0x10 * (id))
+
+/**
+ * A1.1.14 TSM Interrupt Type Info Register [N]
+ * [31:28] cmd pool ID
+ * [27:24] Cluster physical ID
+ * [23:20] core physical ID
+ * [19:16] TEC physical ID
+ * [11]    pool interrupt status
+ * [10]    cluster interrupt status
+ * [9]     core interrupt status
+ * [8]     TEC interrupt status
+ * [5]     timeout bit
+ * [4]     pool error bit
+ * [3]     fault bit
+ * [2]     exception bit
+ * [1]     irq_signal bit
+ * [0]     done bit
+ */
+#define IS_RESET(status_32)                           (((status_32) >> 4) & 0x3)
+#define GET_INTR_CLUSTER_ID_V3_2(status_32)           (((status_32) >> 24) & 0xFF)
+#define GET_INTR_CORE_ID_V3_2(status_32)              (((status_32) >> 20) & 0xF)
+#define GET_INTR_TEC_ID_V3_2(status_32)               (((status_32) >> 16) & 0xF)
+#define GET_INTR_GROUP_ID_V3_2(status_32)             ((status_32) & 0xFF)
+#define IS_POOL_IRQ_V3_2(status_32)                   (((status_32) >> 11) & 0x1)
+#define IS_CLUSTER_IRQ_V3_2(status_32)                (((status_32) >> 10) & 0x1)
+#define IS_CORE_IRQ_V3_2(status_32)                   (((status_32) >> 9) & 0x1)
+#define IS_TEC_IRQ_V3_2(status_32)                    (((status_32) >> 8) & 0x1)
+#define IS_TIMEOUT_IRQ_V3_2(status_32)                (((status_32) >> 5) & 0x1)
+#define IS_ERROR_IRQ_V3_2(status_32)                  (((status_32) >> 4) & 0x1)
+#define IS_FAULT_IRQ_V3_2(status_32)                  (((status_32) >> 3) & 0x1)
+#define IS_EXCEPTION_IRQ_V3_2(status_32)              (((status_32) >> 2) & 0x1)
+#define IS_SIGNAL_IRQ_V3_2(status_32)                 (((status_32) >> 1) & 0x1)
+#define IS_DONE_IRQ_V3_2(status_32)                   ((status_32) & 0x1)
+#define IS_ABNORMAL_V3_2(status_32)                   (((status_32) >> 2) & 0xF)
+#define IS_SERIOUS_ERR_V3_2(status_32)                (((status_32) >> 3) & 0x7)
+#define GET_INTR_TYPE_V3_2(status_32)                 ((status_32) & 0x3F)
+#define IS_IRQ_TO_HANDLE_V3_2(status_32)              ((status_32) & 0xF1F)
+#define IS_COREDUMP_IRQ_V3_2(status_32)               (IS_EXCEPTION_IRQ_V3_2(status_32))
+
+#define INTERRUPT_TYPE_INFO_REG(id)                 (_GET_PER_INTERRUPT_REGISTER_OFFSET(id) + 0x0)
+
+/**
+ * TSM Interrupt TCB Pointer Register [N]
+ *
+ * [31:0] TCBP (RO)
+ */
+#define INTERRUPT_TCB_PTR_REG(id)                   (_GET_PER_INTERRUPT_REGISTER_OFFSET(id) + 0x4)
+
+/**
+ * TSM Interrupt Signal Register [N]
+ *
+ * [31:15]   reserved
+ * [14:0]    irq signal id
+ */
+#define INTERRUPT_SIGNAL_REG(id)                    (_GET_PER_INTERRUPT_REGISTER_OFFSET(id) + 0x8)
+
+/**
+ * TSM Interrupt Signal flag Register [N]
+ *
+ * [31:0]    irq signal flag
+ */
+#define IS_HW_EXCEPTION_SIGNAL_V3_2(flag)             ((flag) >> 31)
+#define IS_SW_EXCEPTION_SIGNAL_V3_2(flag)             (((flag) >> 30) & 0x1)
+#define IS_EXCEPTION_SIGNAL_V3_2(flag)                ((flag) >> 30)
+#define IS_PRINTF_SIGNAL_V3_2(flag)                   (((flag) >> 29) & 0x1)
+#define IS_PROFILER_SIGNAL_V3_2(flag)                 (((flag) >> 28) & 0x1)
+#define IS_COREDUMP_SIGNAL_V3_2(flag)                 (((flag) >> 27) & 0x1)
+#define GET_ERR_CODE_V3_2(flag)                       ((flag) & 0xFFFF)
+#define GET_PRINF_SIZE_V3_2(flag)                     ((flag) & 0xFFFF)
+#define GET_PROFILER_BUF_PA_V3_2(flag)                (((flag) & 0xFFFFF) << 12)
+
+#define INTERRUPT_GROUP_ID_REG(id)               (_GET_PER_INTERRUPT_REGISTER_OFFSET(id) + 0x8)
+#define INTERRUPT_SIGNAL_FLAG_REG(id)               (_GET_PER_INTERRUPT_REGISTER_OFFSET(id) + 0xc)
+
+#define ZHOUYI_V3_2_MAX_REG_OFFSET                    0x322C
+#define DEBUG_CLUSTER_STATUS_V3_2                    0x2004
+#define DEBUG_CORE_STATUS_V3_2                    0x3004
+
+u64 get_gm_size(u32 val);
+struct aipu_operations *get_zhouyi_v3_2_ops(void);
+struct aipu_priv_operations *get_v3_2_priv_ops(void);
+
+#endif /* __V3_2_H__ */
diff --git a/drivers/misc/armchina-npu/zhouyi/v3_2_priv.c b/drivers/misc/armchina-npu/zhouyi/v3_2_priv.c
new file mode 100755
--- /dev/null
+++ b/drivers/misc/armchina-npu/zhouyi/v3_2_priv.c
@@ -0,0 +1,252 @@
+// SPDX-License-Identifier: GPL-2.0
+/* Copyright (c) 2023-2025 Arm Technology (China) Co. Ltd. */
+
+#include <linux/platform_device.h>
+#include <linux/of.h>
+#include <linux/delay.h>
+#include <linux/gpio/consumer.h>
+#include "aipu_priv.h"
+#include "aipu_partition.h"
+#include "aipu_common.h"
+#include "zhouyi.h"
+#include "v3_2.h"
+
+extern void gpiod_set_value(struct gpio_desc *desc, int value);
+extern int gpiod_get_value(const struct gpio_desc *desc);
+
+static int aipu_init_debugger_reg_v3_2(struct platform_device *p_dev, struct io_region *reg)
+{
+	int ret = 0;
+	struct resource *res = NULL;
+	u64 base = 0;
+	u64 size = 0;
+
+	if (!p_dev || !reg)
+		return -EINVAL;
+
+	res = platform_get_resource(p_dev, IORESOURCE_MEM, 1);
+	if (!res)
+		return -EINVAL;
+	dev_dbg(&p_dev->dev, "init aipu debugger IO region: [0x%llx, 0x%llx]\n",
+		res->start, res->end - res->start + 1);
+
+	base = res->start;
+	size = res->end - res->start + 1;
+
+	ret = init_aipu_ioregion(reg, base, size);
+	if (ret) {
+		dev_err(&p_dev->dev, "create aipu IO region failed.\n");
+		return ret;
+	}
+	dev_dbg(&p_dev->dev, "init aipu IO region done: [0x%llx, 0x%llx]\n",
+		base, res->end);
+	return ret;
+}
+
+static u32 aipu_get_gm_size(u32 val)
+{
+    val &= 0x7;
+    return val ? SZ_1M << (val - 1) : 0;
+}
+
+static int init_aipu_cluster(struct aipu_partition *cluster, struct aipu_priv *aipu,
+			     struct platform_device *p_dev, int version)
+{
+	int ret = 0;
+	u32 val = 0;
+	u32 config = 0;
+
+	if (!cluster || !aipu || !p_dev)
+		return -EINVAL;
+
+	cluster->id = 0;
+	cluster->priv = aipu;
+	cluster->version = version;
+	cluster->arch = AIPU_ARCH_ZHOUYI;
+	cluster->dev = &p_dev->dev;
+	cluster->reg = &cluster->priv->reg;
+	cluster->dbg_reg = &cluster->priv->dbg_reg;
+	cluster->irq_obj = cluster->priv->irq_obj;
+	cluster->partition_mode = PARTITION_MODE_NONE;
+	mutex_init(&cluster->reset_lock);
+	spin_lock_init(&cluster->io_lock);
+	cluster->ops = get_zhouyi_v3_2_ops();
+
+	/* unused fields */
+	cluster->reg_attr = NULL;
+	cluster->clk_attr = NULL;
+	cluster->disable_attr = NULL;
+	cluster->max_sched_num = 0;
+	cluster->dtcm_base = 0;
+	cluster->dtcm_size = 0;
+	atomic_set(&cluster->disable, 0);
+
+	cluster->cluster_cnt = 1;
+	val = aipu_read32(cluster->reg, CLUSTER_CONFIG_REG_V3_2(0));
+	cluster->clusters[0].core_cnt = GET_AIPU_CORE_NUM_V3_2(val);
+	atomic_set(&cluster->clusters[0].en_core_cnt, GET_AIPU_CORE_NUM_V3_2(val));
+	config = GET_AIFF_NUM_V3_2(val);
+	if (config == 2)
+		cluster->config = 1304;
+	else if (config == 1)
+		cluster->config = 1204;
+	else
+		cluster->config = 0;
+	cluster->clusters[0].tec_cnt = GET_TEC_NUM_V3_2(val);
+
+	if (version >= AIPU_ISA_VERSION_ZHOUYI_V3_2_0) {
+		aipu_write32(&aipu->reg, AHB_INTERNAL_CSR_SELECTION_CTRL_REG,
+		     SELECT_DEBUG_CORE_V3_2(0, 0));
+		val = aipu_read32(cluster->reg, CLUSTER_GM_FEATURE_V3_2(0));
+		cluster->clusters[0].gm_bytes = aipu_get_gm_size(val);
+		aipu_write32(&aipu->reg, AHB_INTERNAL_CSR_SELECTION_CTRL_REG, DISABLE_DEBUG_V3_2);
+		ret = aipu_mm_init_gm(&cluster->priv->mm, cluster->clusters[0].gm_bytes);
+	}
+
+	cluster->ops->initialize(cluster);
+
+#ifdef CONFIG_SYSFS
+	if (IS_ERR(aipu_common_create_attr(cluster->dev, &cluster->reg_attr, "ext_registers",
+					   0644, aipu_common_ext_register_sysfs_show,
+					   aipu_common_ext_register_sysfs_store)))
+		dev_err(cluster->dev, "[init_cluster] init sysfs <ext_registers> failed");
+
+#endif
+
+	cluster->is_init = true;
+	return ret;
+}
+
+static struct aipu_partition *v3_2_create_cluster(struct aipu_priv *aipu,
+						  int id,
+						  struct platform_device *p_dev)
+{
+	int ret = 0;
+	int version = 0;
+	int config = 0;
+	struct aipu_partition *cluster = NULL;
+
+	if (!aipu || !p_dev)
+		return ERR_PTR(-EINVAL);
+
+	ret = zhouyi_detect_aipu_version(p_dev, &version, &config, NULL);
+	if (ret)
+		return ERR_PTR(ret);
+
+	dev_info(&p_dev->dev, "AIPU detected: zhouyi%s\n",
+		 version == AIPU_ISA_VERSION_ZHOUYI_V3_2_0 ? "-v3_2_0":
+		 version == AIPU_ISA_VERSION_ZHOUYI_V3_2_1 ? "-v3_2_1":"");
+
+	WARN_ON(!aipu->is_init);
+
+	cluster = devm_kzalloc(&p_dev->dev, sizeof(*cluster), GFP_KERNEL);
+	if (!cluster)
+		return ERR_PTR(-ENOMEM);
+
+	/* do this before calling init_aipu_cluster() */
+	ret = aipu_common_init_reg_irq(p_dev, cluster, &aipu->reg, &aipu->irq_obj);
+	if (ret)
+		return ERR_PTR(ret);
+
+	/*for debugger io region */
+	ret = aipu_init_debugger_reg_v3_2(p_dev, &aipu->dbg_reg);
+	if (ret) {
+		dev_err(&p_dev->dev, "[init debugger] failed, please update fpga and dts.");
+		//return ERR_PTR(ret);
+	}
+
+	if (aipu->reset_gpio) {
+		aipu->ops->global_hw_reset(aipu);
+	} else {
+		ret = aipu->ops->global_soft_reset(aipu);
+		if (ret) {
+			dev_err(&p_dev->dev, "[init partition] global soft reset failed");
+			return ERR_PTR(ret);
+		}
+	}
+
+	ret = init_aipu_cluster(cluster, aipu, p_dev, version);
+	if (ret)
+		goto init_cluster_fail;
+
+	aipu->partitions = cluster;
+	aipu->partition_cnt = 1;
+	aipu->cluster_cnt = 1;
+	aipu_job_manager_set_partitions_info(&aipu->job_manager, aipu->partition_cnt, cluster);
+	cluster->ops->print_hw_id_info(cluster);
+	goto finish;
+
+init_cluster_fail:
+	aipu_destroy_irq_object(aipu->irq_obj);
+	aipu->irq_obj = NULL;
+	deinit_aipu_ioregion(&aipu->reg);
+	deinit_aipu_ioregion(&aipu->dbg_reg);
+	aipu->reg.phys = 0;
+	aipu->reg.kern = NULL;
+	aipu->reg.size = 0;
+	devm_kfree(&p_dev->dev, cluster);
+	cluster = ERR_PTR(ret);
+
+finish:
+	return cluster;
+}
+
+static void v3_2_destroy_cluster(struct aipu_priv *aipu)
+{
+	int i = 0;
+
+	if (aipu) {
+		if (aipu->irq_obj)
+			aipu_destroy_irq_object(aipu->irq_obj);
+		aipu->irq_obj = NULL;
+
+		if (aipu->reg.kern)
+			deinit_aipu_ioregion(&aipu->reg);
+		aipu->reg.kern = NULL;
+		aipu->reg.phys = 0;
+		aipu->reg.size = 0;
+
+		if (aipu->dbg_reg.kern)
+			deinit_aipu_ioregion(&aipu->dbg_reg);
+		aipu->dbg_reg.kern = NULL;
+		aipu->dbg_reg.phys = 0;
+		aipu->dbg_reg.size = 0;
+
+		for (i = 0; i < aipu->partition_cnt; i++) {
+			if (!aipu->partitions[i].is_init)
+				return;
+			aipu_common_destroy_attr(aipu->partitions[i].dev,
+						 &aipu->partitions[i].reg_attr);
+		}
+	}
+}
+
+static int v3_2_global_soft_reset(struct aipu_priv *aipu)
+{
+	return zhouyi_soft_reset(&aipu->reg, PMU_TOP_SOFT_RESET_REG, aipu->reset_delay_us);
+}
+
+static void v3_2_global_hw_reset(struct aipu_priv *aipu)
+{
+	if (aipu && aipu->reset_gpio) {
+		gpiod_set_value(aipu->reset_gpio, 0);
+		udelay(1);
+		gpiod_set_value(aipu->reset_gpio, 1);
+		udelay(20);
+		gpiod_set_value(aipu->reset_gpio, 0);
+		udelay(20);
+		dev_dbg(aipu->dev, "v3_2 global hw reset finished.\n");
+	}
+}
+
+static struct aipu_priv_operations v3_2_priv_ops = {
+	.create_partitions = v3_2_create_cluster,
+	.destroy_partitions = v3_2_destroy_cluster,
+	.global_soft_reset = v3_2_global_soft_reset,
+	.global_hw_reset = v3_2_global_hw_reset,
+};
+
+struct aipu_priv_operations *get_v3_2_priv_ops(void)
+{
+	return &v3_2_priv_ops;
+}
