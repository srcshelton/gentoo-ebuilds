The Orion O6 ACPI tables describe the HDA codec power-down GPIO via a
GpioIo resource that references a CIXH1003 GPIO controller. The Cadence
GPIO driver already has CIXH1002/CIXH1003 ACPI IDs, but its Kconfig entry
still depends on OF_GPIO, so ACPI-only configurations cannot enable the
driver. In that configuration the HDA controller defers forever waiting for
the pdb GPIO supplier.

Allow GPIO_CADENCE to be built for ACPI systems and softly imply it from the
CIX IPBLOQ HDA driver. Use dev_err_probe() for the GPIO lookups so an
expected supplier defer is reported through the deferred-probe machinery
rather than as a hard probe error.

---
 drivers/gpio/Kconfig                   | 2 +-
 sound/hda/controllers/Kconfig          | 1 +
 sound/hda/controllers/hda_cix_ipbloq.c | 8 ++++----
 3 files changed, 6 insertions(+), 5 deletions(-)

diff --git a/drivers/gpio/Kconfig b/drivers/gpio/Kconfig
--- a/drivers/gpio/Kconfig
+++ b/drivers/gpio/Kconfig
@@ -248,7 +248,7 @@ config GPIO_BRCMSTB
 
 config GPIO_CADENCE
 	tristate "Cadence GPIO support"
-	depends on OF_GPIO
+	depends on OF_GPIO || ACPI || COMPILE_TEST
 	select GPIO_GENERIC
 	select GPIOLIB_IRQCHIP
 	help
diff --git a/sound/hda/controllers/Kconfig b/sound/hda/controllers/Kconfig
--- a/sound/hda/controllers/Kconfig
+++ b/sound/hda/controllers/Kconfig
@@ -46,6 +46,7 @@ config SND_HDA_CIX_IPBLOQ
 	depends on ARCH_CIX || COMPILE_TEST
 	select SND_HDA
 	select SND_HDA_ALIGNED_MMIO
+	imply GPIO_CADENCE
 	help
 	  Say Y here to support the HDA controller present in CIX Sky1 SoCs
 	  (used in boards like the Radxa Orion O6).
diff --git a/sound/hda/controllers/hda_cix_ipbloq.c b/sound/hda/controllers/hda_cix_ipbloq.c
--- a/sound/hda/controllers/hda_cix_ipbloq.c
+++ b/sound/hda/controllers/hda_cix_ipbloq.c
@@ -839,16 +839,16 @@ static int cix_ipbloq_hda_probe(struct platform_device *pdev)
 
 	hda->pdb_gpiod = devm_gpiod_get_optional(&pdev->dev, "pdb", GPIOD_OUT_HIGH);
 	if (IS_ERR(hda->pdb_gpiod)) {
-		err = PTR_ERR(hda->pdb_gpiod);
-		dev_err(&pdev->dev, "failed to get pdb gpio, err: %d\n", err);
+		err = dev_err_probe(&pdev->dev, PTR_ERR(hda->pdb_gpiod),
+				    "failed to get pdb gpio\n");
 		goto out_free;
 	}
 	msleep(20);
 
 	hda->depop_mute_gpiod = devm_gpiod_get_optional(&pdev->dev, "depop-mute", GPIOD_OUT_HIGH);
 	if (IS_ERR(hda->depop_mute_gpiod)) {
-		err = PTR_ERR(hda->depop_mute_gpiod);
-		dev_err(&pdev->dev, "failed to get depop gpio, err: %d\n", err);
+		err = dev_err_probe(&pdev->dev, PTR_ERR(hda->depop_mute_gpiod),
+				    "failed to get depop gpio\n");
 		goto out_free;
 	}
 	gpiod_set_value_cansleep(hda->depop_mute_gpiod, 1);
