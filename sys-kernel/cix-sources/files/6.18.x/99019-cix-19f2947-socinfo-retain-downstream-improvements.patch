+}
+
+static u32 sky1_opn_roadmap(const struct sky1_socinfo *info)
+{
+	return FIELD_GET(OPN_ROADMAP_MASK, info->opn);
+}
+
+static u32 sky1_opn_model(const struct sky1_socinfo *info)
