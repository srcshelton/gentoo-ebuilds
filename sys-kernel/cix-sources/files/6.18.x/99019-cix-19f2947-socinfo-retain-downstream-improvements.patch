+/* OPN (Ordering Part Number) field masks, matching the 6.6 BSP decoder. */
+#define OPN_PART_DEFINITION_MASK	GENMASK_ULL(7, 0)
+#define OPN_REVISION_MASK		GENMASK_ULL(13, 8)
+#define OPN_CORES_MASK			GENMASK_ULL(18, 14)
+#define OPN_PACKAGE_MASK		GENMASK_ULL(23, 19)
+#define OPN_ROADMAP_MASK		GENMASK_ULL(35, 24)
+#define OPN_MODEL_MASK			GENMASK_ULL(51, 36)
+#define OPN_SEGMENT_MASK		GENMASK_ULL(56, 52)
+#define OPN_PRODUCT_BRAND_MASK		GENMASK_ULL(60, 57)
+
+/* Part definition codes */
+#define PART_DEFINITION_GENERAL		0x01
+#define PART_DEFINITION_KMS		0x02
+
+/* Revision codes */
+#define REVISION_A0			0x08
+#define REVISION_A1			0x09
+#define REVISION_B0			0x10
+#define REVISION_B1			0x11
+#define REVISION_B2			0x12
+#define REVISION_C0			0x18
+#define REVISION_C1			0x19
+
+/* Core-count codes */
+#define CORES_1				0x01
+#define CORES_2				0x02
+#define CORES_3				0x03
+#define CORES_4				0x04
+#define CORES_5				0x05
+#define CORES_6				0x06
+#define CORES_7				0x07
+
+/* Package codes */
+#define PACKAGE_A			0x01
+
+/* Roadmap codes */
+#define ROADMAP_A11			0x111
+#define ROADMAP_A12			0x112
+#define ROADMAP_B11			0x211
+#define ROADMAP_B12			0x212
+#define ROADMAP_C11			0x311
+#define ROADMAP_C12			0x312
+
+/* Model codes */
+#define MODEL_8180			0x8180
+#define MODEL_8160			0x8160
+#define MODEL_6180			0x6180
+
+/* Segment codes */
+#define SEGMENT_A			0x01
+#define SEGMENT_P			0x02
+#define SEGMENT_E			0x03
+#define SEGMENT_F			0x04
+#define SEGMENT_H			0x05
+#define SEGMENT_G			0x06
+#define SEGMENT_D			0x07
+#define SEGMENT_S			0x08
+#define SEGMENT_X			0x09
+#define SEGMENT_W			0x10
+#define SEGMENT_C			0x11
+
+/* Product brand codes */
+#define PRODUCT_BRAND_CIX		0x01
+
+/* Firmware version offsets in SRAM */
+#define FW_SE_OFFSET			0x000
+#define FW_PBL_OFFSET			0x080
+#define FW_ATF_OFFSET			0x100
+#define FW_PM_OFFSET			0x180
+#define FW_TEE_OFFSET			0x200
+#define FW_UEFI_OFFSET			0x280
+#define FW_EC_OFFSET			0x300
+#define FW_BOARD_ID_OFFSET		0x380
+#define FW_PD_OFFSET			0x400
+
+#define FW_VERSION_MAX_LEN		0x7f
+
+/* Firmware SRAM aperture used by the vendor DT cix,sky1-top node. */
+#define SKY1_FW_SRAM_BASE		0x83e01000
+#define SKY1_FW_SRAM_SIZE		0x2000
+
+/* Board ID field masks */
+#define BOARD_ID_PCB_SKU_MASK		(BIT(0) | BIT(1) | BIT(2) | BIT(6))
+#define BOARD_ID_MEM_TYPE_MASK		(BIT(3) | BIT(4) | BIT(5) | BIT(7))
+#define BOARD_ID_REVISION_MASK		GENMASK(9, 8)
+
+/* PCB SKU codes */
+#define PCB_SKU_MERAK			0x0
+#define PCB_SKU_MIZAR			0x1
+#define PCB_SKU_MERAK_DAP		0x2
+#define PCB_SKU_PHECDA_SLT		0x3
+#define PCB_SKU_PHECDA			0x4
+#define PCB_SKU_MEGREZ			0x5
+#define PCB_SKU_PHECDA_DAP		0x6
+
+/* Memory type codes */
+#define MEM_SAMSUNG_LP5_315B_4G_SR	0x0
+#define MEM_HYNIX_LP4X_200B_4G_DR	0x1
+#define MEM_SAMSUNG_LP5X_315B_8G_DR	0x2
+#define MEM_SAMSUNG_LP5_315B_8G_DR	0x3
+#define MEM_SAMSUNG_LP5X_441B_8G_SR_OLD	0x4
+#define MEM_SAMSUNG_LP5_441B_4G_SR	0x5
+#define MEM_SAMSUNG_LP5X_441B_8G_SR_NEW	0x6
+
+struct sky1_socinfo {
+	struct device *dev;
+	void __iomem *sram_base;
+	struct soc_device *soc_dev;
+	u64 opn;
+
+	/* Firmware versions */
+	char *fw_se;
+	char *fw_pbl;
+	char *fw_atf;
+	char *fw_pm;
+	char *fw_tee;
+	char *fw_uefi;
+	char *fw_ec;
+	char *fw_pd;
+
+	/* Board info */
+	u16 board_id_raw;
+	char *pcb_sku;
+	char *pmic;
+	char *memory_type;
+	char *board_revision;
+
+	/* OPN info */
+	char *opn_string;
+};
+
+static struct platform_device *sky1_socinfo_acpi_pdev;
+static struct sky1_socinfo *sky1_socinfo_sysfs;
+
+static struct resource sky1_socinfo_acpi_resources[] = {
+	DEFINE_RES_MEM(SKY1_FW_SRAM_BASE, SKY1_FW_SRAM_SIZE),
+};
+
+static bool sky1_acpi_platform_present(void)
+{
+	if (!IS_ENABLED(CONFIG_ACPI) || acpi_disabled || of_have_populated_dt())
+		return false;
+
+	return acpi_dev_found("CIXHA010") || acpi_dev_found("CIXH4000") ||
+	       acpi_dev_found("CIXH2020");
+}
+
+static const char *sky1_part_definition_str(u32 part_definition)
+{
+	switch (part_definition) {
+	case PART_DEFINITION_GENERAL:	return "0A";
+	case PART_DEFINITION_KMS:	return "1A";
+	default:			return "Unknown";
+	}
+}
+
+static const char *sky1_revision_str(u32 rev)
+{
+	switch (rev) {
+	case REVISION_A0:	return "A0";
+	case REVISION_A1:	return "A1";
+	case REVISION_B0:	return "B0";
+	case REVISION_B1:	return "B1";
+	case REVISION_B2:	return "B2";
+	case REVISION_C0:	return "C0";
+	case REVISION_C1:	return "C1";
+	default:		return "Unknown";
+	}
+}
+
+static const char *sky1_cores_str(u32 cores)
+{
+	switch (cores) {
+	case CORES_1:		return "1";
+	case CORES_2:		return "2";
+	case CORES_3:		return "3";
+	case CORES_4:		return "4";
+	case CORES_5:		return "5";
+	case CORES_6:		return "6";
+	case CORES_7:		return "7";
+	default:		return "Unknown";
+	}
+}
+
+static const char *sky1_package_str(u32 package)
+{
+	switch (package) {
+	case PACKAGE_A:		return "A";
+	default:		return "Unknown";
+	}
+}
+
+static const char *sky1_roadmap_str(u32 roadmap)
+{
+	switch (roadmap) {
+	case ROADMAP_A11:	return "A11";
+	case ROADMAP_A12:	return "A12";
+	case ROADMAP_B11:	return "B11";
+	case ROADMAP_B12:	return "B12";
+	case ROADMAP_C11:	return "C11";
+	case ROADMAP_C12:	return "C12";
+	default:		return "Unknown";
+	}
+}
+
+static const char *sky1_model_str(u32 model)
+{
+	switch (model) {
+	case MODEL_8180:	return "8180";
+	case MODEL_8160:	return "8160";
+	case MODEL_6180:	return "6180";
+	default:		return "Unknown";
+	}
+}
+
+static const char *sky1_segment_str(u32 segment)
+{
+	switch (segment) {
+	case SEGMENT_A:		return "A";
+	case SEGMENT_P:		return "P";
+	case SEGMENT_E:		return "E";
+	case SEGMENT_F:		return "F";
+	case SEGMENT_H:		return "H";
+	case SEGMENT_G:		return "G";
+	case SEGMENT_D:		return "D";
+	case SEGMENT_S:		return "S";
+	case SEGMENT_X:		return "X";
+	case SEGMENT_W:		return "W";
+	case SEGMENT_C:		return "C";
+	default:		return "Unknown";
+	}
+}
+
+static const char *sky1_product_brand_str(u32 product_brand)
+{
+	switch (product_brand) {
+	case PRODUCT_BRAND_CIX:	return "C";
+	default:		return "Unknown";
+	}
+}
+
+static char *sky1_read_fw_version(struct device *dev, void __iomem *base)
+{
+	char buf[FW_VERSION_MAX_LEN + 1];
+	int i;
+
+	for (i = 0; i < FW_VERSION_MAX_LEN; i++) {
+		buf[i] = readb(base + i);
+		if (!buf[i])
+			break;
+	}
+	buf[i] = '\0';
+
+	if (i > 0 && i < FW_VERSION_MAX_LEN)
+		return devm_kasprintf(dev, GFP_KERNEL, "Version %s", buf);
+
+	return devm_kstrdup(dev, "Unknown", GFP_KERNEL);
+}
+
+static char *sky1_read_pd_version(struct device *dev, void __iomem *base)
+{
+	u8 pd1_maj, pd1_min, pd2_maj, pd2_min;
+
+	pd1_maj = readb(base);
+	pd1_min = readb(base + 1);
+	pd2_maj = readb(base + 2);
+	pd2_min = readb(base + 3);
+
+	return devm_kasprintf(dev, GFP_KERNEL,
+			      "PD1 major: 0x%x minor: 0x%x; PD2 major: 0x%x minor: 0x%x",
+			      pd1_maj, pd1_min, pd2_maj, pd2_min);
+}
+
+static void sky1_parse_board_id(struct sky1_socinfo *info)
+{
+	u16 board_id = info->board_id_raw;
+	u32 pcb_sku, mem_type, board_rev;
+
+	/* Extract PCB SKU: bits 0-2, 6 -> remap bit 6 to bit 3 */
+	pcb_sku = (board_id & 0x7) | ((board_id & BIT(6)) >> 3);
+
+	switch (pcb_sku) {
+	case PCB_SKU_MERAK:
+		info->pcb_sku = "MERAK";
+		info->pmic = "MPS5475x3";
+		break;
+	case PCB_SKU_MIZAR:
+		info->pcb_sku = "MIZAR";
+		info->pmic = "MPS5475x3";
+		break;
+	case PCB_SKU_MERAK_DAP:
+		info->pcb_sku = "MERAK_DAP";
+		info->pmic = "MPS5475x3";
+		break;
+	case PCB_SKU_PHECDA_SLT:
+		info->pcb_sku = "PHECDA_SLT";
+		info->pmic = "MP2845x2+DRMOS";
+		break;
+	case PCB_SKU_PHECDA:
+		info->pcb_sku = "PHECDA";
+		info->pmic = "MP2845x2+DRMOS";
+		break;
+	case PCB_SKU_MEGREZ:
+		info->pcb_sku = "MEGREZ";
+		info->pmic = "MPS5475x2+Buckx1";
+		break;
+	case PCB_SKU_PHECDA_DAP:
+		info->pcb_sku = "PHECDA_DAP";
+		info->pmic = "MP2845x2+DRMOS";
+		break;
+	default:
+		info->pcb_sku = "Reserved";
+		info->pmic = "Reserved";
+		break;
+	}
+
+	/* Extract memory type: bits 3-5, 7 -> remap bit 7 to bit 3 */
+	mem_type = ((board_id >> 3) & 0x7) | ((board_id & BIT(7)) >> 4);
+
+	switch (mem_type) {
+	case MEM_SAMSUNG_LP5_315B_4G_SR:
+		info->memory_type = "Samsung LP5 315b 4G Single Rank (K3LKBKB0BM-MGCP)";
+		break;
+	case MEM_HYNIX_LP4X_200B_4G_DR:
+		info->memory_type = "Hynix LP4x 200b 4G Dual Rank (H9HCNNNCPMMLXR-NEE)";
+		break;
+	case MEM_SAMSUNG_LP5X_315B_8G_DR:
+		info->memory_type = "Samsung LP5x 315b 8G Dual Rank (K3KL9L90QM-MGCT)";
+		break;
+	case MEM_SAMSUNG_LP5_315B_8G_DR:
+		info->memory_type = "Samsung LP5 315b 8G Dual Rank (K3LKCKC0BM-MGCP)";
+		break;
+	case MEM_SAMSUNG_LP5X_441B_8G_SR_OLD:
+		info->memory_type = "Samsung LP5x 441b 8G Single Rank (K3KL3L30QM-JGCT 1z nm)";
+		break;
+	case MEM_SAMSUNG_LP5_441B_4G_SR:
+		info->memory_type = "Samsung LP5 441b 4G Single Rank (K3KL1L10GM-JGCT 1a nm)";
+		break;
+	case MEM_SAMSUNG_LP5X_441B_8G_SR_NEW:
+		info->memory_type = "Samsung LP5x 441b 8G Single Rank (K3KL3L30QM-JGCT 1a nm)";
+		break;
+	default:
+		info->memory_type = "Reserved";
+		break;
+	}
+
+	/* Extract board revision: bits 8-9 */
+	board_rev = FIELD_GET(BOARD_ID_REVISION_MASK, board_id);
+
+	switch (board_rev) {
+	case 0:
+		info->board_revision = "Rev A";
+		break;
+	case 1:
+		info->board_revision = "Rev B";
+		break;
+	case 2:
+		info->board_revision = "Rev C";
+		break;
+	case 3:
+		info->board_revision = "Rev D";
+		break;
+	default:
+		info->board_revision = "Unknown";
+		break;
+	}
+}
+
+static void sky1_parse_opn(struct sky1_socinfo *info)
+{
+	u32 part_definition = FIELD_GET(OPN_PART_DEFINITION_MASK, info->opn);
+	u32 revision = FIELD_GET(OPN_REVISION_MASK, info->opn);
+	u32 cores = FIELD_GET(OPN_CORES_MASK, info->opn);
+	u32 package = FIELD_GET(OPN_PACKAGE_MASK, info->opn);
+	u32 roadmap = FIELD_GET(OPN_ROADMAP_MASK, info->opn);
+	u32 model = FIELD_GET(OPN_MODEL_MASK, info->opn);
+	u32 segment = FIELD_GET(OPN_SEGMENT_MASK, info->opn);
+	u32 product_brand = FIELD_GET(OPN_PRODUCT_BRAND_MASK, info->opn);
+
+	info->opn_string = devm_kasprintf(info->dev, GFP_KERNEL, "%s%s%s%s%s%s%s%s",
+					  sky1_product_brand_str(product_brand),
+					  sky1_segment_str(segment),
+					  sky1_model_str(model),
+					  sky1_roadmap_str(roadmap),
+					  sky1_package_str(package),
+					  sky1_cores_str(cores),
+					  sky1_revision_str(revision),
+					  sky1_part_definition_str(part_definition));
+}
+
+static u32 sky1_opn_part_definition(const struct sky1_socinfo *info)
+{
+	return FIELD_GET(OPN_PART_DEFINITION_MASK, info->opn);
+}
+
+static u32 sky1_opn_revision(const struct sky1_socinfo *info)
