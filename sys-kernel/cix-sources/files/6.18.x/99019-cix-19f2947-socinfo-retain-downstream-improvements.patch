+static int sky1_socinfo_probe(struct platform_device *pdev)
+{
+	struct soc_device_attribute *soc_attr;
+	struct device_node *root;
+	struct sky1_socinfo *info;
+	const char *machine = NULL;
+	int ret;
+
+	info = devm_kzalloc(&pdev->dev, sizeof(*info), GFP_KERNEL);
+	if (!info)
+		return -ENOMEM;
+
+	info->dev = &pdev->dev;
+	platform_set_drvdata(pdev, info);
+
+	/* Map SRAM region containing firmware versions and board info */
+	info->sram_base = devm_platform_ioremap_resource(pdev, 0);
+	if (IS_ERR(info->sram_base))
+		return PTR_ERR(info->sram_base);
+
+	/* Read firmware versions from SRAM */
+	info->fw_se = sky1_read_fw_version(&pdev->dev,
+					   info->sram_base + FW_SE_OFFSET);
+	info->fw_pbl = sky1_read_fw_version(&pdev->dev,
+					    info->sram_base + FW_PBL_OFFSET);
+	info->fw_atf = sky1_read_fw_version(&pdev->dev,
+					    info->sram_base + FW_ATF_OFFSET);
+	info->fw_pm = sky1_read_fw_version(&pdev->dev,
+					   info->sram_base + FW_PM_OFFSET);
+	info->fw_tee = sky1_read_fw_version(&pdev->dev,
+					    info->sram_base + FW_TEE_OFFSET);
+	info->fw_uefi = sky1_read_fw_version(&pdev->dev,
+					     info->sram_base + FW_UEFI_OFFSET);
+	info->fw_ec = sky1_read_fw_version(&pdev->dev,
+					   info->sram_base + FW_EC_OFFSET);
+	info->fw_pd = sky1_read_pd_version(&pdev->dev,
+					   info->sram_base + FW_PD_OFFSET);
+
+	/* Read and parse board ID */
+	info->board_id_raw = readw(info->sram_base + FW_BOARD_ID_OFFSET);
+	sky1_parse_board_id(info);
+
+	/* Read OPN from NVMEM */
+	ret = nvmem_cell_read_u64(&pdev->dev, "opn", &info->opn);
+	if (ret)
+		return dev_err_probe(&pdev->dev, ret, "Failed to read OPN\n");
+
+	sky1_parse_opn(info);
+	dev_info(&pdev->dev,
+		 "raw OPN=0x%016llx brand=0x%x segment=0x%x model=0x%x roadmap=0x%x package=0x%x cores=0x%x revision=0x%x part=0x%x board_id=0x%04x\n",
+		 (unsigned long long)info->opn, sky1_opn_product_brand(info),
+		 sky1_opn_segment(info), sky1_opn_model(info),
+		 sky1_opn_roadmap(info), sky1_opn_package(info),
+		 sky1_opn_cores(info), sky1_opn_revision(info),
+		 sky1_opn_part_definition(info), info->board_id_raw);
+
+	/* Set up soc_device attributes */
+	soc_attr = devm_kzalloc(&pdev->dev, sizeof(*soc_attr), GFP_KERNEL);
+	if (!soc_attr)
+		return -ENOMEM;
+
+	soc_attr->family = "CIX Sky1";
+
+	/* Get machine name from root DT node */
+	root = of_find_node_by_path("/");
+	if (root) {
+		of_property_read_string(root, "model", &machine);
+		of_node_put(root);
+	}
+	if (!machine)
+		machine = dmi_get_system_info(DMI_PRODUCT_NAME);
+	if (machine)
+		soc_attr->machine = devm_kstrdup(&pdev->dev, machine, GFP_KERNEL);
+
+	soc_attr->soc_id = info->opn_string;
+	soc_attr->revision = sky1_revision_str(FIELD_GET(OPN_REVISION_MASK, info->opn));
+	soc_attr->custom_attr_group = sky1_socinfo_groups[0];
+
+	sky1_socinfo_sysfs = info;
+	info->soc_dev = soc_device_register(soc_attr);
+	if (IS_ERR(info->soc_dev)) {
+		sky1_socinfo_sysfs = NULL;
+		return dev_err_probe(&pdev->dev, PTR_ERR(info->soc_dev),
+				     "Failed to register SoC device\n");
+	}
+
+	dev_info(&pdev->dev, "CIX Sky1 %s detected (%s, %s)\n",
+		 info->opn_string, info->pcb_sku, info->board_revision);
+
+	return 0;
+}
+
+static void sky1_socinfo_remove(struct platform_device *pdev)
+{
+	struct sky1_socinfo *info = platform_get_drvdata(pdev);
+
+	soc_device_unregister(info->soc_dev);
+	if (sky1_socinfo_sysfs == info)
+		sky1_socinfo_sysfs = NULL;
+}
+
+static const struct of_device_id sky1_socinfo_of_match[] = {
+	{ .compatible = "cix,sky1-socinfo" },
+	{ .compatible = "cix,sky1-top" },
+	{ /* sentinel */ }
+};
+MODULE_DEVICE_TABLE(of, sky1_socinfo_of_match);
+
+static struct platform_driver sky1_socinfo_driver = {
+	.probe = sky1_socinfo_probe,
+	.remove = sky1_socinfo_remove,
+	.driver = {
+		.name = "sky1-socinfo",
+		.of_match_table = sky1_socinfo_of_match,
+	},
+};
+
+static int __init sky1_socinfo_init(void)
+{
+	int ret;
+
+	ret = platform_driver_register(&sky1_socinfo_driver);
+	if (ret)
+		return ret;
+
+	if (sky1_acpi_platform_present()) {
+		sky1_socinfo_acpi_pdev =
+			platform_device_register_simple("sky1-socinfo",
+							PLATFORM_DEVID_NONE,
+							sky1_socinfo_acpi_resources,
+							ARRAY_SIZE(sky1_socinfo_acpi_resources));
+		if (IS_ERR(sky1_socinfo_acpi_pdev)) {
+			ret = PTR_ERR(sky1_socinfo_acpi_pdev);
+			sky1_socinfo_acpi_pdev = NULL;
+			platform_driver_unregister(&sky1_socinfo_driver);
+			return ret;
+		}
+	}
+
+	return 0;
+}
+module_init(sky1_socinfo_init);
+
+static void __exit sky1_socinfo_exit(void)
+{
+	platform_device_unregister(sky1_socinfo_acpi_pdev);
+	platform_driver_unregister(&sky1_socinfo_driver);
+}
+module_exit(sky1_socinfo_exit);
+
+MODULE_AUTHOR("Cix Technology Group Co., Ltd.");
+MODULE_DESCRIPTION("CIX Sky1 SoC information driver");
+MODULE_LICENSE("GPL");
