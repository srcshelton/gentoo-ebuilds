CIX Sky1 ACPI: arbitrate duplicate PCIe/USB models at scan time

diff --git a/drivers/pci/controller/cadence/pci-sky1-acpi.c b/drivers/pci/controller/cadence/pci-sky1-acpi.c
--- a/drivers/pci/controller/cadence/pci-sky1-acpi.c
+++ b/drivers/pci/controller/cadence/pci-sky1-acpi.c
@@ -30,6 +30,24 @@
 
 static bool sky1_acpi_detected;
 
+static acpi_status sky1_pcie_match_handle(acpi_handle handle, u32 level,
+					  void *context, void **ret)
+{
+	bool *present = context;
+
+	*present = true;
+	return AE_CTRL_TERMINATE;
+}
+
+static bool sky1_pcie_acpi_id_present(const char *hid)
+{
+	bool present = false;
+
+	acpi_get_devices(hid, sky1_pcie_match_handle, &present, NULL);
+
+	return present;
+}
+
 /*
  * Resource filter for CIXH2020 _CRS.
  *
@@ -139,7 +157,10 @@ static int sky1_cixh2020_create_pdev(struct acpi_device *adev)
 }
 
 /*
- * Combined scan handler for PNP0A08 (deny) and CIXH2020 (filtered create).
+ * Combined scan handler for PNP0A08/CIXH2020 ACPI model arbitration.
+ *
+ * On Sky1, prefer PNP0A08 when both models are present; create CIXH2020
+ * only when firmware exposes the vendor model alone.
  *
  * On non-Sky1 platforms, returns 0 for both — PNP0A08 falls through to
  * the built-in PCI root handler (via PNP0A03 compat ID), and CIXH2020
@@ -152,8 +173,17 @@ static int sky1_acpi_scan_attach(struct acpi_device *adev,
 		return 0;
 
 	if (!strcmp(id->id, "PNP0A08")) {
+		if (!sky1_pcie_acpi_id_present("CIXH2020"))
+			return 0;
+
+		dev_info(&adev->dev,
+			 "Sky1 PCIe: keeping PNP0A08, suppressing CIXH2020 instead\n");
+		return 0;
+	}
+
+	if (sky1_pcie_acpi_id_present("PNP0A08")) {
 		dev_info(&adev->dev,
-			 "Sky1: blocking PNP0A08, CIXH2020 will handle\n");
+			 "Sky1 PCIe: suppressing CIXH2020 because PNP0A08 is present\n");
 		return 1;
 	}
 
@@ -193,7 +223,7 @@ static int __init sky1_pcie_acpi_init(void)
 	if (!sky1_acpi_detected)
 		return 0;
 
-	pr_info("Sky1 PCIe: registering ACPI scan handler\n");
+	pr_info("Sky1 PCIe: registering ACPI PCIe arbitration handler\n");
 	return acpi_scan_add_handler(&sky1_scan_handler);
 }
 /* Must run before subsys_initcall(acpi_init) which registers PCI root handler */
diff --git a/drivers/soc/cix/Kconfig b/drivers/soc/cix/Kconfig
