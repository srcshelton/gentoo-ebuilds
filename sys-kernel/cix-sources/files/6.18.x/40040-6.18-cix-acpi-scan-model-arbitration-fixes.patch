@@ -43,19 +43,21 @@ config CIX_ACPI_RESOURCE_LOOKUP
 	  platform_get_resource_byname() or devm_reset_control_get().
 
 config CIX_ACPI_USB_SCAN
-	bool "CIX ACPI USB scan handler"
+	bool
 	depends on ARCH_CIX || COMPILE_TEST
 	depends on ACPI
 	default ARCH_CIX
 	help
-	  Block PNP0D10 (generic xHCI) platform device creation on CIX Sky1
-	  so the vendor USB driver chain (cdnsp-sky1 + cdnsp-plat) can own
-	  the hardware instead of xhci-plat.
-
-	  Required for proper USB controller initialization under ACPI boot.
+	  Internal ACPI arbitration helper for vendor firmware that exposes both
+	  generic upstream PNP0D10 and vendor CIXH2030-CIXH2034 USB devices for
+	  the same Sky1 controller. When both models are present, the runtime
+	  arbiter prefers the generic upstream PNP0D10 path and suppresses the
+	  overlapping vendor USB devices. With custom firmware that exposes only
+	  one model, the helper either stands down or allows the vendor-only
+	  devices to enumerate unchanged.
 
 config CIX_ACPI_GPU_SCAN
-	bool "CIX ACPI GPU coherency scan handler"
+	bool
 	depends on ARCH_CIX || COMPILE_TEST
 	depends on ACPI
 	default ARCH_CIX
diff --git a/drivers/soc/cix/cix-acpi-gpu-scan.c b/drivers/soc/cix/cix-acpi-gpu-scan.c
