+config CIX_SKY1_SOCINFO
+	tristate "CIX Sky1 SoC information"
+	depends on ARCH_CIX || COMPILE_TEST
+	depends on HAS_IOMEM
+	depends on HAVE_ARM_SMCCC
+	depends on OF || ACPI
+	depends on NVMEM
+	select NVMEM_SKY1
+	select SOC_BUS
+	help
+	  Enable the CIX Sky1 SoC information driver. The driver reports
