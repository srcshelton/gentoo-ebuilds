+
+static bool rts5453h_uses_same_irq(struct rts5453h *a, struct rts5453h *b,
+				   int irq)
+{
+	struct i2c_client *aclient = to_i2c_client(a->dev);
+	struct i2c_client *bclient = to_i2c_client(b->dev);
+
+	return a != b && aclient->adapter == bclient->adapter &&
+	       bclient->irq == irq;
+}
+
+static enum rts5453h_irq_peer_state
+rts5453h_shared_irq_peer_state(struct rts5453h *rts, int irq)
+{
+	struct rts5453h *rt;
+
+	list_for_each_entry(rt, &rts_list, list) {
+		if (!rts5453h_uses_same_irq(rts, rt, irq))
+			continue;
+
+		if (rt->irq_requested)
+			return RTS5453H_IRQ_PEER_REQUESTED;
+		if (rt->irq_requesting)
+			return RTS5453H_IRQ_PEER_REQUESTING;
+	}
+
+	return RTS5453H_IRQ_PEER_NONE;
+}
