 	.driver = {
 		.name = "cdns-i3c-master",
 		.of_match_table = cdns_i3c_master_of_ids,
+		.acpi_match_table = ACPI_PTR(cdns_i3c_master_acpi_ids),
 	},
 };
 module_platform_driver(cdns_i3c_master);
