+static int genpd_get_acpi_power_domain_args(struct device *dev,
+					    unsigned int index,
+					    struct fwnode_reference_args *args)
+{
+	struct fwnode_reference_args onecell_args = {};
+	int ret;
+
+	/*
+	 * Prefer the provider-advertised cell count when present.  Some ACPI
+	 * firmware, including Sky1's SCMI DVFS node, omits the DT-style
+	 * #power-domain-cells property but still encodes a onecell reference as
+	 * Package () { REF, INT }; retry explicitly in that form when the first
+	 * parse found a provider but no arguments.
+	 */
+	ret = fwnode_property_get_reference_args(dev_fwnode(dev),
+			"power-domains", "#power-domain-cells", 0, index, args);
+	if (ret || args->nargs)
+		return ret;
+
+	ret = fwnode_property_get_reference_args(dev_fwnode(dev),
+			"power-domains", NULL, 1, index, &onecell_args);
+	if (ret)
+		return 0;
+
+	fwnode_handle_put(args->fwnode);
+	*args = onecell_args;
+
+	return 0;
+}
 
