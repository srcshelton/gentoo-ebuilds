diff --git a/drivers/pci/controller/cadence/Kconfig b/drivers/pci/controller/cadence/Kconfig
--- a/drivers/pci/controller/cadence/Kconfig
+++ b/drivers/pci/controller/cadence/Kconfig
@@ -77,6 +77,22 @@ config PCI_J721E_EP
 	  controller in endpoint mode. TI J721E PCIe controller uses Cadence PCIe
 	  core.
 
+config CIX_ACPI_PCIE_SCAN
+	bool
+	depends on ACPI
+	depends on ARCH_CIX || COMPILE_TEST
+	default ARCH_CIX
+	help
+	  Say Y here to register the CIX Sky1 ACPI scan handler that arbitrates
+	  firmware which exposes both standard PNP0A08 PCI root bridges and
+	  vendor CIXH2020 PCIe controller devices for the same physical PCIe
+	  ports.
+
+	  On firmware that exposes both ACPI models, this keeps the standard
+	  PNP0A08 root bridges and suppresses duplicate CIXH2020 platform
+	  devices before the generic ACPI platform bus tries to claim their PCI
+	  window resources as platform IO resources.
+
 config PCI_SKY1
 	bool "CIX Sky1 PCIe controller (host mode)"
 	depends on OF && (ARCH_CIX || COMPILE_TEST)
diff --git a/drivers/pci/controller/cadence/Makefile b/drivers/pci/controller/cadence/Makefile
--- a/drivers/pci/controller/cadence/Makefile
+++ b/drivers/pci/controller/cadence/Makefile
@@ -7,4 +7,4 @@ obj-$(CONFIG_PCI_J721E) += pci-j721e.o
 obj-$(CONFIG_PCIE_SG2042_HOST) += pcie-sg2042.o
 pcie-sky1-objs := pci-sky1.o pci-sky1-debugfs.o
 obj-$(CONFIG_PCI_SKY1) += pcie-sky1.o
-obj-$(CONFIG_PCI_SKY1) += pci-sky1-acpi.o
+obj-$(CONFIG_CIX_ACPI_PCIE_SCAN) += pci-sky1-acpi.o
diff --git a/drivers/pci/controller/cadence/pci-sky1-acpi.c b/drivers/pci/controller/cadence/pci-sky1-acpi.c
--- a/drivers/pci/controller/cadence/pci-sky1-acpi.c
+++ b/drivers/pci/controller/cadence/pci-sky1-acpi.c
@@ -3,10 +3,11 @@
  * ACPI scan handlers for CIX Sky1 PCIe controllers.
  *
  * The DSDT defines both PNP0A08 (standard PCI root bridge) and CIXH2020
- * (vendor PCIe controller companion) for each PCIe port.  Only one should
- * create a PCI host bridge.  Block PNP0A08 so pci-sky1.c can probe
- * CIXH2020 with full controller initialization (PHY, reset, PERST#, etc).
+ * (vendor PCIe controller companion) for each PCIe port on stock firmware.
+ * Only one should create a PCI host bridge; when both are present, keep the
+ * upstream PNP0A08 path and suppress duplicate CIXH2020 platform devices.
  *
+ * Vendor-only firmware can still use CIXH2020 when PCI_SKY1 is enabled.
  * CIXH2020 _CRS contains both controller register resources (Memory32Fixed)
  * and PCI address windows (DWordMemory, DWordIO).  The PCI windows get
  * IORESOURCE_WINDOW from ACPI resource translation.  platform_device_add()
@@ -22,6 +23,7 @@
 
 #include <linux/acpi.h>
 #include <linux/init.h>
+#include <linux/kconfig.h>
 #include <linux/platform_device.h>
 
 #include "pci-sky1-acpi.h"
@@ -155,7 +157,10 @@ static int sky1_acpi_scan_attach(struct acpi_device *adev,
 		return 1;
 	}
 
-	/* CIXH2020 — create platform device with filtered resources */
+	if (!IS_ENABLED(CONFIG_PCI_SKY1))
+		return 0;
+
+	/* CIXH2020: create platform device with filtered resources */
 	return sky1_cixh2020_create_pdev(adev);
 }
 
