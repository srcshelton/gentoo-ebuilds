diff --git a/drivers/phy/cix/Kconfig b/drivers/phy/cix/Kconfig
--- a/drivers/phy/cix/Kconfig
+++ b/drivers/phy/cix/Kconfig
@@ -4,6 +4,7 @@ config PHY_CIX_PCIE
 	bool "CIX Sky1 PCIe PHY driver"
 	depends on ARCH_CIX || COMPILE_TEST
 	depends on OF
+	select REGMAP
 	select GENERIC_PHY
 	help
 	  Enable this to support the PCIe PHY on CIX Sky1 SoCs.
@@ -22,6 +23,7 @@ config PHY_CIX_USB3
 	bool "CIX Sky1 USB3 PHY driver"
 	depends on ARCH_CIX || COMPILE_TEST
 	depends on OF
+	select REGMAP
 	select GENERIC_PHY
 	help
 	  Enable this to support the USB3 PHY on CIX Sky1 SoCs.
@@ -30,7 +32,8 @@ config PHY_CIX_USBDP
 	tristate "CIX Sky1 USB-DP combo PHY driver"
 	depends on ARCH_CIX || COMPILE_TEST
 	depends on OF
-	depends on TYPEC
+	depends on TYPEC || TYPEC=n
+	select REGMAP
 	select GENERIC_PHY
 	help
 	  Enable this to support the USB-DP combo PHY on CIX Sky1 SoCs.
diff --git a/drivers/phy/cix/phy-cix-pcie.c b/drivers/phy/cix/phy-cix-pcie.c
--- a/drivers/phy/cix/phy-cix-pcie.c
+++ b/drivers/phy/cix/phy-cix-pcie.c
@@ -349,7 +349,7 @@ static const struct regmap_config cix_udphy_regmap_cfg = {
 
 static int pcie_phy_common_init(struct cix_pcie_phy *pcie_phy)
 {
-	int ret;
+	int ret = -EINVAL;
 
 	if (pcie_phy->num_lanes == X8) {
 		ret = regmap_multi_reg_write(pcie_phy->phy_regmap, pcie_x8, ARRAY_SIZE(pcie_x8));
@@ -359,6 +359,7 @@ static int pcie_phy_common_init(struct cix_pcie_phy *pcie_phy)
 		ret = regmap_multi_reg_write(pcie_phy->phy_regmap, pcie_x211, ARRAY_SIZE(pcie_x211));
 	} else {
 		dev_err(pcie_phy->dev, "Invalid Phy Config\n");
+		return ret;
 	}
 
 	if (ret) {
diff --git a/drivers/phy/cix/phy-cix-usbdp.c b/drivers/phy/cix/phy-cix-usbdp.c
--- a/drivers/phy/cix/phy-cix-usbdp.c
+++ b/drivers/phy/cix/phy-cix-usbdp.c
@@ -815,6 +815,12 @@ static int udphy_setup_orien_switch(struct cix_udphy *udphy)
 {
 	struct typec_switch_desc sw_desc = { };
 
+	if (!IS_REACHABLE(CONFIG_TYPEC)) {
+		dev_dbg(udphy->dev,
+			"Type-C support is not reachable; skipping orientation switch\n");
+		return 0;
+	}
+
 	sw_desc.drvdata = udphy;
 	sw_desc.fwnode = dev_fwnode(udphy->dev);
 	sw_desc.set = udphy_orien_sw_set;
@@ -888,6 +894,12 @@ static int udphy_setup_typec_mux(struct cix_udphy *udphy)
 {
 	struct typec_mux_desc mux_desc = {};
 
+	if (!IS_REACHABLE(CONFIG_TYPEC)) {
+		dev_dbg(udphy->dev,
+			"Type-C support is not reachable; skipping mux registration\n");
+		return 0;
+	}
+
 	mux_desc.drvdata = udphy;
 	mux_desc.fwnode = dev_fwnode(udphy->dev);
 	mux_desc.set = usbdp_typec_mux_set;
