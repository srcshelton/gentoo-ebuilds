misc: armchina-npu: split 6.18 ACPI DMA API fixes

Split the ArmChina NPU ACPI DMA/API runtime fixes out of the old aggregate 6.18 Sky1 runtime patch.

---
diff --git a/drivers/misc/armchina-npu/aipu_irq.c b/drivers/misc/armchina-npu/aipu_irq.c
--- a/drivers/misc/armchina-npu/aipu_irq.c
+++ b/drivers/misc/armchina-npu/aipu_irq.c
@@ -63,12 +63,8 @@ struct aipu_irq_object *aipu_create_irq_object(struct device *dev, u32 irqnum, v
 
 	INIT_WORK(&irq_obj->work, aipu_irq_handler_bottom_half);
 
-	/**
-	 * Flag IRQF_ONESHOT is used when sharing interrupts with other devices using thread_irq.
-	 * Remove it if you have no such a usage scenario.
-	 */
 	ret = request_irq(irqnum, aipu_irq_handler_upper_half,
-			  IRQF_ONESHOT | IRQF_SHARED | IRQF_PROBE_SHARED,
+			  IRQF_SHARED | IRQF_PROBE_SHARED,
 			  description, irq_obj->dev);
 	if (ret) {
 		dev_err(dev, "request_irq failed: irqnum %u, ret %d", irqnum, ret);
diff --git a/drivers/misc/armchina-npu/aipu_mm.c b/drivers/misc/armchina-npu/aipu_mm.c
--- a/drivers/misc/armchina-npu/aipu_mm.c
+++ b/drivers/misc/armchina-npu/aipu_mm.c
@@ -15,6 +15,7 @@
 #include <linux/iommu.h>
 #include <linux/bitmap.h>
 #include <linux/version.h>
+#include <linux/moduleparam.h>
 #include <linux/iova.h>
 #include <linux/dma-mapping.h>
 #include <linux/acpi.h>
@@ -29,6 +30,11 @@
 #define IOVA_FREE  false
 #define IOVA_ALLOC true
 
+static bool aipu_acpi_prealloc_iova_regions;
+module_param_named(acpi_prealloc_iova_regions, aipu_acpi_prealloc_iova_regions, bool, 0644);
+MODULE_PARM_DESC(acpi_prealloc_iova_regions,
+		 "Use legacy preallocated IOVA regions on ACPI systems");
+
 /*
  * Partial redefinition of the kernel-private struct iommu_dma_cookie
  * (defined in drivers/iommu/dma-iommu.c). Only the iovad field is accessed
@@ -522,7 +528,14 @@ static struct aipu_mem_region *aipu_mm_create_region(struct aipu_memory_manager
 		return reg;
 
 	if (reserved && !mm->has_iommu) {
-		ret = of_reserved_mem_device_init_by_idx(reg->dev, mm->dev->of_node, idx);
+		if (!dev_of_node(mm->dev)) {
+			dev_err(reg->dev,
+				"reserved memory requires OF memory-region data without IOMMU\n");
+			ret = -ENODEV;
+			goto err;
+		}
+
+		ret = of_reserved_mem_device_init_by_idx(reg->dev, dev_of_node(mm->dev), idx);
 		if (ret) {
 			dev_err(reg->dev, "init reserved mem failed: idx %d (%d)\n",
 				idx, ret);
@@ -864,6 +877,16 @@ static void add_region_list(struct aipu_memory_manager *mm, int asid,
 	mm->ase[asid].cnt++;
 }
 
+static void aipu_mm_set_safe_dma_api_range(struct aipu_memory_manager *mm)
+{
+	mm->dma_mask = 32;
+#if (KERNEL_VERSION(5, 5, 0) <= LINUX_VERSION_CODE)
+	mm->dev->bus_dma_limit = 0xc0000000;
+#elif (KERNEL_VERSION(4, 19, 0) <= LINUX_VERSION_CODE)
+	mm->dev->bus_dma_mask = 0xc0000000;
+#endif
+}
+
 static int aipu_mm_reserved_iova_for_never_map(struct aipu_memory_manager *mm, bool flag)
 {
 	struct iommu_domain *iommu_domain = NULL;
@@ -879,6 +902,12 @@ static int aipu_mm_reserved_iova_for_never_map(struct aipu_memory_manager *mm, b
 		return -EINVAL;
 
 	iommu_domain = mm->iommu_domain;
+	if (!iommu_domain || !iommu_domain->iova_cookie) {
+		dev_warn(mm->dev, "IOMMU DMA cookie unavailable; skipping IOVA %s\n",
+			 flag ? "reservation" : "release");
+		return -ENODEV;
+	}
+
 	cookie = iommu_domain->iova_cookie;
 	iovad = &cookie->iovad;
 #if (KERNEL_VERSION(5, 5, 0) <= LINUX_VERSION_CODE)
@@ -894,6 +923,9 @@ static int aipu_mm_reserved_iova_for_never_map(struct aipu_memory_manager *mm, b
 		lo = iova_start >> PAGE_SHIFT;
 		hi = (iova_start + iova_len) >> PAGE_SHIFT;
 		iova = reserve_iova(iovad, lo, hi - 1);
+		if (!iova)
+			return -ENOMEM;
+
 		if (!flag)
 			__free_iova(iovad, iova);
 		bus_dma_limit -= 0x100000000;
@@ -949,12 +981,7 @@ static int aipu_mm_add_iova_region(struct aipu_memory_manager *mm)
 
 	if (aipu_mm_reserved_iova_for_never_map(mm, IOVA_ALLOC)) {
 		dev_err(mm->dev, "fail to reserve iova region for never map.");
-		mm->dma_mask = 32;
-#if (KERNEL_VERSION(5, 5, 0) <= LINUX_VERSION_CODE)
-		mm->dev->bus_dma_limit = 0xc0000000;
-#elif (KERNEL_VERSION(4, 19, 0) <= LINUX_VERSION_CODE)
-		mm->dev->bus_dma_mask = 0xc0000000;
-#endif
+		aipu_mm_set_safe_dma_api_range(mm);
 		goto FINISH;
 	}
 
@@ -963,12 +990,7 @@ static int aipu_mm_add_iova_region(struct aipu_memory_manager *mm)
 						   iova_region_size - 1, 0, asid_idx, NULL, true);
 		if (!obj) {
 			dev_err(mm->dev, "create iova region failed (ret = %ld)", PTR_ERR(reg));
-			mm->dma_mask = 32;
-#if (KERNEL_VERSION(5, 5, 0) <= LINUX_VERSION_CODE)
-			mm->dev->bus_dma_limit = 0xc0000000;
-#elif (KERNEL_VERSION(4, 19, 0) <= LINUX_VERSION_CODE)
-			mm->dev->bus_dma_mask = 0xc0000000;
-#endif
+			aipu_mm_set_safe_dma_api_range(mm);
 			break;
 		}
 
@@ -1005,10 +1027,15 @@ static int aipu_mm_add_reserved_regions(struct aipu_memory_manager *mm)
 	u64 offset = 0;
 	u32 res_cnt = 0;
 
+	if (!dev_of_node(mm->dev)) {
+		dev_info(mm->dev, "reserved-memory regions require OF data; skipping\n");
+		return 0;
+	}
+
 	do {
 		u64 size = 0;
 
-		np = of_parse_phandle(mm->dev->of_node, "memory-region", idx);
+		np = of_parse_phandle(dev_of_node(mm->dev), "memory-region", idx);
 		if (!np)
 			break;
 
@@ -1021,23 +1048,27 @@ static int aipu_mm_add_reserved_regions(struct aipu_memory_manager *mm)
 			type = AIPU_MEM_REGION_TYPE_DTCM;
 		} else {
 			dev_err(mm->dev, "invalid memory region name: %s\n", np->name);
+			of_node_put(np);
 			continue;
 		}
 
 		/* bypass mapping SoC SRAM if CPU cannot access it */
 		if (type == AIPU_MEM_REGION_TYPE_SRAM && !AIPU_CONFIG_HOST_MAP_SRAM) {
 			dev_info(mm->dev, "dts: bypass this sram region (cpu cannot access it)\n");
+			of_node_put(np);
 			continue;
 		}
 
 		if (type == AIPU_MEM_REGION_TYPE_DTCM && dtcm_cnt == mm->dtcm_max_cnt) {
 			dev_err(mm->dev, "dts: bypass this dtcm region for the max_cnt limit\n");
+			of_node_put(np);
 			continue;
 		}
 
 		if (type == AIPU_MEM_REGION_TYPE_DTCM &&
 		    mm->version == AIPU_ISA_VERSION_ZHOUYI_V1) {
 			dev_err(mm->dev, "dts: bypass because v1 does not support dtcm\n");
+			of_node_put(np);
 			continue;
 		}
 
@@ -1061,6 +1092,7 @@ static int aipu_mm_add_reserved_regions(struct aipu_memory_manager *mm)
 		obj = aipu_mm_create_region_object(mm, type, size, offset, idx, NULL, true);
 		if (!obj) {
 			dev_err(mm->dev, "create new region failed (ret = %ld)", PTR_ERR(reg));
+			of_node_put(np);
 			continue;
 		}
 
@@ -1275,10 +1307,16 @@ int aipu_init_mm(struct aipu_memory_manager *mm, struct platform_device *p_dev,
 	 *
 	 * KMD can accept multiple DRAM regions and/or multiple SRAM regions;
 	 */
-	if (!mm->has_iommu)
+	if (mm->has_iommu && has_acpi_companion(mm->dev) &&
+	    !aipu_acpi_prealloc_iova_regions) {
+		aipu_mm_set_safe_dma_api_range(mm);
+		mm->res_cnt = 0;
+		dev_info(mm->dev, "using DMA API allocation path on ACPI\n");
+	} else if (!mm->has_iommu) {
 		mm->res_cnt = aipu_mm_add_reserved_regions(mm);
-	else
+	} else {
 		mm->res_cnt = aipu_mm_add_iova_region(mm);
+	}
 
 	if (version > AIPU_ISA_VERSION_ZHOUYI_V1 && mm->res_cnt)
 		aipu_mm_set_asid_base(mm);
diff --git a/drivers/misc/armchina-npu/sky1/sky1.c b/drivers/misc/armchina-npu/sky1/sky1.c
--- a/drivers/misc/armchina-npu/sky1/sky1.c
+++ b/drivers/misc/armchina-npu/sky1/sky1.c
@@ -145,10 +145,14 @@ static int sky1_npu_devfreq_init(struct device *dev, struct cix_aipu_priv *cix_a
         cix_aipu_priv->opp_pmdomain = dev_pm_domain_attach_by_name(dev, "perf");
     }
 
-    if (IS_ERR_OR_NULL(cix_aipu_priv->opp_pmdomain)) {
-        dev_err(dev, "Failed to get perf domain\n");
-        return -EFAULT;
+    if (IS_ERR(cix_aipu_priv->opp_pmdomain)) {
+        ret = PTR_ERR(cix_aipu_priv->opp_pmdomain);
+        return dev_err_probe(dev, ret, "Failed to get perf domain\n");
     }
+
+    if (!cix_aipu_priv->opp_pmdomain)
+        return dev_err_probe(dev, -EPROBE_DEFER,
+                             "Failed to get perf domain\n");
     cix_aipu_priv->opp_dl = device_link_add(dev, cix_aipu_priv->opp_pmdomain,
                             DL_FLAG_RPM_ACTIVE |
                             DL_FLAG_PM_RUNTIME |
@@ -436,11 +440,6 @@ static int sky1_npu_probe(struct platform_device *p_dev)
 npu_probe_failed:
 	pm_runtime_put(&p_dev->dev);
 
-    if (has_acpi_companion(&p_dev->dev)) {
-		for (i = 0; i < CIX_NPU_PD_NUM; i++) {
-			pm_runtime_disable(cix_aipu_priv->pd_core[i]);
-		}
-	}
 	pm_runtime_disable(&p_dev->dev);
 
 #ifdef CONFIG_ENABLE_DEVFREQ
@@ -449,6 +448,12 @@ static int sky1_npu_probe(struct platform_device *p_dev)
 
 devfreq_init_failed:
 	for (i=0; i < CIX_NPU_PD_NUM; i++) {
+		if (!cix_aipu_priv->pd_core[i])
+			continue;
+
+		if (has_acpi_companion(&p_dev->dev))
+			pm_runtime_disable(cix_aipu_priv->pd_core[i]);
+
 		dev_pm_domain_detach(cix_aipu_priv->pd_core[i], true);
 	}
 
