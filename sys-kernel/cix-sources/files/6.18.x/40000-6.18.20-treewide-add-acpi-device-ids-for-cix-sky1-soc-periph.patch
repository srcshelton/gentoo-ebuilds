From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Fri, 6 Feb 2026 02:06:53 +1100
Subject: [PATCH] treewide: Add ACPI device IDs for CIX Sky1 SoC peripherals

Add ACPI device IDs to existing drivers to support ACPI enumeration
on CIX Sky1 SoC systems:

  I2C/I3C:
  - i2c-cadence: CIXH200B
  - i3c-master-cdns: CIXH200C
  - rts5453 USB-PD: CIXH200D

  SPI:
  - spi-cadence: CIXH2001
  - spi-cadence-quadspi: CIXH2002

  DMA:
  - arm-dma350: CIXH1006, CIXHA014

  Network:
  - macb: CIXH7020

  Display:
  - pwm_bl: CIXH5041

  Audio:
  - clk-sky1-audss: CIXH6061
  - reset-sky1-audss: CIXH6062

These additions allow the respective hardware blocks to be enumerated
and probed when booting with ACPI firmware.
---
 drivers/clk/cix/clk-sky1-audss.c         | 10 ++++++++++
 drivers/dma/arm-dma350.c                 | 11 +++++++++++
 drivers/i2c/busses/i2c-cadence.c         | 10 ++++++++++
 drivers/i3c/master/i3c-master-cdns.c     | 10 ++++++++++
 drivers/net/ethernet/cadence/macb_main.c | 10 ++++++++++
 drivers/reset/reset-sky1-audss.c         | 10 ++++++++++
 drivers/spi/spi-cadence-quadspi.c        | 10 ++++++++++
 drivers/spi/spi-cadence.c                | 10 ++++++++++
 drivers/usb/typec/rts5453.c              | 10 ++++++++++
 drivers/video/backlight/pwm_bl.c         | 11 ++++++++++-
 10 files changed, 101 insertions(+), 1 deletion(-)

diff --git a/drivers/clk/cix/clk-sky1-audss.c b/drivers/clk/cix/clk-sky1-audss.c
--- a/drivers/clk/cix/clk-sky1-audss.c
+++ b/drivers/clk/cix/clk-sky1-audss.c
@@ -5,6 +5,7 @@
  * Copyright 2024 Cix Technology Group Co., Ltd.
  */
 
+#include <linux/acpi.h>
 #include <linux/clk.h>
 #include <linux/clk-provider.h>
 #include <linux/io.h>
@@ -776,12 +777,21 @@ static const struct of_device_id sky1_audss_clk_of_match[] = {
 };
 MODULE_DEVICE_TABLE(of, sky1_audss_clk_of_match);
 
+#ifdef CONFIG_ACPI
+static const struct acpi_device_id sky1_audss_clk_acpi_match[] = {
+	{ "CIXH6061", 0 },
+	{ }
+};
+MODULE_DEVICE_TABLE(acpi, sky1_audss_clk_acpi_match);
+#endif
+
 static struct platform_driver sky1_audss_clk_driver = {
 	.probe = sky1_audss_clk_probe,
 	.remove = sky1_audss_clk_remove,
 	.driver = {
 		.name = "sky1-audss-clk",
 		.of_match_table = sky1_audss_clk_of_match,
+		.acpi_match_table = ACPI_PTR(sky1_audss_clk_acpi_match),
 		.pm = &sky1_audss_clk_pm_ops,
 	},
 };
