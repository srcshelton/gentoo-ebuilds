diff --git a/drivers/soc/cix/cix-acpi-gpu-scan.c b/drivers/soc/cix/cix-acpi-gpu-scan.c
new file mode 100644
index 0000000..fc124ae
--- /dev/null
+++ b/drivers/soc/cix/cix-acpi-gpu-scan.c
@@ -0,0 +1,67 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * ACPI scan helper for the CIX Sky1 GPU coherency description.
+ *
+ * Sky1 firmware may report CIXH5000 as DMA coherent via _CCA even though the
+ * hardware model matches the non-coherent DT description. Correct the ACPI
+ * device flag early enough that the Panthor driver uses the non-coherent DMA
+ * path. Fixed firmware that already reports non-coherent DMA is left alone.
+ */
+
+#ifdef CONFIG_ACPI
+
+#include <linux/acpi.h>
+#include <linux/init.h>
+#include <linux/string.h>
+
+static bool sky1_gpu_acpi_detected;
+
+static int sky1_gpu_scan_attach(struct acpi_device *adev,
+				const struct acpi_device_id *id)
+{
+	if (!sky1_gpu_acpi_detected)
+		return 0;
+
+	if (!adev->flags.coherent_dma)
+		return 0;
+
+	dev_info(&adev->dev,
+		 "Sky1 GPU: overriding _CCA to non-coherent (DT parity)\n");
+	adev->flags.coherent_dma = 0;
+	return 0;
+}
+
+static const struct acpi_device_id sky1_gpu_scan_ids[] = {
+	{ "CIXH5000", 0 },
+	{ },
+};
+
+static struct acpi_scan_handler sky1_gpu_scan_handler = {
+	.ids = sky1_gpu_scan_ids,
+	.attach = sky1_gpu_scan_attach,
+};
+
+static int __init sky1_gpu_acpi_init(void)
+{
+	struct acpi_table_header *header;
+
+	if (acpi_disabled)
+		return 0;
+
+	if (ACPI_FAILURE(acpi_get_table(ACPI_SIG_MCFG, 0, &header)))
+		return 0;
+
+	sky1_gpu_acpi_detected = !memcmp(header->oem_id, "CIXTEK", 6) &&
+				 !memcmp(header->oem_table_id, "SKY1EDK2", 8);
+	acpi_put_table(header);
+
+	if (!sky1_gpu_acpi_detected)
+		return 0;
+
+	pr_info("Sky1 GPU: registering ACPI coherency scan handler\n");
+	return acpi_scan_add_handler(&sky1_gpu_scan_handler);
+}
+/* Must run before subsys_initcall(acpi_init) which creates platform devices */
+arch_initcall(sky1_gpu_acpi_init);
+
+#endif /* CONFIG_ACPI */
diff --git a/drivers/soc/cix/cix-acpi-pcie-scan.c b/drivers/soc/cix/cix-acpi-pcie-scan.c
new file mode 100644
index 0000000..78424da
--- /dev/null
+++ b/drivers/soc/cix/cix-acpi-pcie-scan.c
@@ -0,0 +1,104 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * ACPI scan handler to arbitrate between generic and vendor PCIe models on
+ * CIX Sky1.
+ *
+ * Vendor Sky1 firmware exposes both generic upstream PNP0A08 PCI root bridges
+ * and CIXH2020 vendor PCIe companion devices for the same hardware. When both
+ * models are present, prefer the generic path and suppress the overlapping
+ * vendor platform devices before the generic ACPI platform bus tries to claim
+ * their PCI window resources. Firmware that exposes only one model is left
+ * unchanged.
+ */
+
+#ifdef CONFIG_ACPI
+
+#include <linux/acpi.h>
+#include <linux/init.h>
+#include <linux/string.h>
+
+static bool sky1_pcie_acpi_detected;
+
+static acpi_status sky1_pcie_match_handle(acpi_handle handle, u32 level,
+					  void *context, void **ret)
+{
+	struct acpi_device *adev = acpi_fetch_acpi_dev(handle);
+	bool *present = context;
+
+	if (!adev)
+		return AE_OK;
+
+	if (!adev->status.present && !adev->status.functional)
+		return AE_OK;
+
+	*present = true;
+	return AE_CTRL_TERMINATE;
+}
+
+static bool sky1_pcie_acpi_id_present(const char *hid)
+{
+	bool present = false;
+
+	acpi_get_devices(hid, sky1_pcie_match_handle, &present, NULL);
+
+	return present;
+}
+
+static int sky1_pcie_scan_attach(struct acpi_device *adev,
+				 const struct acpi_device_id *id)
+{
+	if (!sky1_pcie_acpi_detected)
+		return 0;
+
+	if (!strcmp(id->id, "PNP0A08")) {
+		if (sky1_pcie_acpi_id_present("CIXH2020"))
+			dev_dbg(&adev->dev,
+				"Sky1 PCIe: keeping PNP0A08, suppressing CIXH2020 instead\n");
+		return 0;
+	}
+
+	if (sky1_pcie_acpi_id_present("PNP0A08")) {
+		dev_dbg(&adev->dev,
+			"Sky1 PCIe: suppressing %s because PNP0A08 is present\n",
+			id->id);
+		return 1;
+	}
+
+	return 0;
+}
+
+static const struct acpi_device_id sky1_pcie_scan_ids[] = {
+	{ "PNP0A08", 0 },
+	{ "CIXH2020", 0 },
+	{ },
+};
+
+static struct acpi_scan_handler sky1_pcie_scan_handler = {
+	.ids = sky1_pcie_scan_ids,
+	.attach = sky1_pcie_scan_attach,
+};
+
+static int __init sky1_pcie_acpi_init(void)
+{
+	struct acpi_table_header *header;
+
+	if (acpi_disabled)
+		return 0;
+
+	if (ACPI_FAILURE(acpi_get_table(ACPI_SIG_MCFG, 0, &header)))
+		return 0;
+
+	sky1_pcie_acpi_detected = !memcmp(header->oem_id, "CIXTEK", 6) &&
+				  !memcmp(header->oem_table_id, "SKY1EDK2", 8);
+	acpi_put_table(header);
+
+	if (!sky1_pcie_acpi_detected)
+		return 0;
+
+	pr_info("Sky1 PCIe: registering ACPI PCIe arbitration handler\n");
+	return acpi_scan_add_handler(&sky1_pcie_scan_handler);
+}
+/* Must run before subsys_initcall(acpi_init) which creates platform devices */
+arch_initcall(sky1_pcie_acpi_init);
+
+#endif /* CONFIG_ACPI */
diff --git a/drivers/soc/cix/cix-acpi-resource-lookup.c b/drivers/soc/cix/cix-acpi-resource-lookup.c
--- a/drivers/soc/cix/cix-acpi-resource-lookup.c
+++ b/drivers/soc/cix/cix-acpi-resource-lookup.c
@@ -111,7 +111,11 @@ static int reset_lookup_handle(acpi_handle handle,
 			devm_kstrdup(dev, el[3].string.pointer, GFP_KERNEL)
 			: NULL;
 
-		if (!lookup->provider || (!lookup->dev_id && !lookup->con_id))
+		/*
+		 * reset_controller_add_lookup() matches consumers by dev_name().
+		 * con_id is optional, but provider and dev_id are both required.
+		 */
+		if (!lookup->provider || !lookup->dev_id)
 			continue;
 
 		reset_controller_add_lookup(lookup, 1);
diff --git a/drivers/soc/cix/cix-acpi-usb-scan.c b/drivers/soc/cix/cix-acpi-usb-scan.c
--- a/drivers/soc/cix/cix-acpi-usb-scan.c
+++ b/drivers/soc/cix/cix-acpi-usb-scan.c
@@ -1,38 +1,102 @@
 // SPDX-License-Identifier: GPL-2.0
 /*
- * ACPI scan handler to block PNP0D10 (generic xHCI) on CIX Sky1.
+ * ACPI scan handler to arbitrate between generic and vendor USB models on
+ * CIX Sky1.
  *
- * The Sky1 DSDT defines both PNP0D10 (generic xHCI) and CIXH2030/CIXH2031
- * (vendor USB wrapper/controller) for each USB port, with overlapping MMIO
- * on the xHCI register block.  The vendor driver chain (cdnsp-sky1 for
- * CIXH2030 wrapper → cdnsp-plat for CIXH2031 controller) must own the
- * hardware for proper initialization including timing prescalers, APB
- * timeout chicken bits, and PHY lifecycle management.
- *
- * Block PNP0D10 platform device creation so xhci-plat doesn't race for
- * the same MMIO region.  Same pattern as pci-sky1-acpi.c blocking PNP0A08.
+ * Vendor Sky1 firmware exposes both generic upstream PNP0D10 (xHCI) and
+ * CIXH2030-CIXH2034 (vendor USB wrapper/controller/PHY companions) for the
+ * same hardware. Custom firmware may expose only one model. When both models
+ * are present, prefer the generic path and suppress the overlapping vendor
+ * USB devices. When only the vendor model is present, allow those vendor
+ * devices to enumerate unchanged.
  */
 
 #ifdef CONFIG_ACPI
 
 #include <linux/acpi.h>
 #include <linux/init.h>
+#include <linux/string.h>
 
 static bool sky1_usb_acpi_detected;
 
+static acpi_status sky1_usb_match_handle(acpi_handle handle, u32 level,
+					 void *context, void **ret)
+{
+	struct acpi_device *adev = acpi_fetch_acpi_dev(handle);
+	bool *present = context;
+
+	if (!adev)
+		return AE_OK;
+
+	if (!adev->status.present && !adev->status.functional)
+		return AE_OK;
+
+	*present = true;
+	return AE_CTRL_TERMINATE;
+}
+
+static bool sky1_usb_acpi_id_present(const char *hid)
+{
+	bool present = false;
+
+	acpi_get_devices(hid, sky1_usb_match_handle, &present, NULL);
+
+	return present;
+}
+
+static bool sky1_usb_vendor_present(void)
+{
+	return sky1_usb_acpi_id_present("CIXH2030") ||
+	       sky1_usb_acpi_id_present("CIXH2031") ||
+	       sky1_usb_acpi_id_present("CIXH2032") ||
+	       sky1_usb_acpi_id_present("CIXH2033") ||
+	       sky1_usb_acpi_id_present("CIXH2034");
+}
+
+static bool sky1_usb_id_is_non_overlapping_companion(const char *hid)
+{
+	return !strcmp(hid, "CIXH2033");
+}
+
 static int sky1_usb_scan_attach(struct acpi_device *adev,
 				const struct acpi_device_id *id)
 {
 	if (!sky1_usb_acpi_detected)
 		return 0;
 
-	dev_info(&adev->dev,
-		 "Sky1: blocking PNP0D10, CIXH2030/CIXH2031 will handle USB\n");
-	return 1;
+	if (!strcmp(id->id, "PNP0D10")) {
+		if (!sky1_usb_vendor_present())
+			return 0;
+
+		dev_dbg(&adev->dev,
+			"Sky1 USB: keeping PNP0D10, suppressing vendor USB model instead\n");
+		return 0;
+	}
+
+	if (sky1_usb_id_is_non_overlapping_companion(id->id)) {
+		dev_dbg(&adev->dev,
+			"Sky1 USB: keeping %s companion alongside PNP0D10\n",
+			id->id);
+		return 0;
+	}
+
+	if (sky1_usb_acpi_id_present("PNP0D10")) {
+		dev_dbg(&adev->dev,
+			"Sky1 USB: suppressing %s because PNP0D10 is present\n",
+			id->id);
+		return 1;
+	}
+
+	return 0;
 }
 
 static const struct acpi_device_id sky1_usb_scan_ids[] = {
 	{ "PNP0D10", 0 },
+	{ "CIXH2030", 0 },
+	{ "CIXH2031", 0 },
+	{ "CIXH2032", 0 },
+	{ "CIXH2033", 0 },
+	{ "CIXH2034", 0 },
 	{ },
 };
 
@@ -59,7 +123,7 @@ static int __init sky1_usb_acpi_init(void)
 	if (!sky1_usb_acpi_detected)
 		return 0;
 
-	pr_info("Sky1 USB: registering PNP0D10 scan handler\n");
+	pr_info("Sky1 USB: registering ACPI USB arbitration handler\n");
 	return acpi_scan_add_handler(&sky1_usb_scan_handler);
 }
 /* Must run before subsys_initcall(acpi_init) which creates platform devices */
