@@ -6,6 +6,7 @@
 // Copyright Intel Corporation (C) 2019-2020. All rights reserved.
 // Copyright (C) 2020 Texas Instruments Incorporated - http://www.ti.com
 
+#include <linux/acpi.h>
 #include <linux/clk.h>
 #include <linux/completion.h>
 #include <linux/delay.h>
@@ -24,6 +25,7 @@
 #include <linux/of.h>
 #include <linux/platform_device.h>
 #include <linux/pm_runtime.h>
+#include <linux/property.h>
 #include <linux/reset.h>
 #include <linux/sched.h>
 #include <linux/spi/spi.h>
@@ -49,6 +51,7 @@ static_assert(CQSPI_MAX_CHIPSELECT <= SPI_DEVICE_CS_CNT_MAX);
 #define CQSPI_DISABLE_RUNTIME_PM	BIT(10)
 #define CQSPI_NO_INDIRECT_MODE		BIT(11)
 #define CQSPI_HAS_WR_PROTECT		BIT(12)
+#define CQSPI_CIX_SKY1_NAMED_CLKS	BIT(13)
 
 /* Capabilities */
 #define CQSPI_SUPPORTS_OCTAL		BIT(0)
@@ -1812,7 +1815,7 @@ static int cqspi_probe(struct platform_device *pdev)
 
 	cqspi->pdev = pdev;
 	cqspi->host = host;
-	cqspi->ddata = ddata = of_device_get_match_data(dev);
+	cqspi->ddata = ddata = device_get_match_data(dev);
 	platform_set_drvdata(pdev, cqspi);
 
 	/* Obtain configuration from OF. */
@@ -1830,9 +1833,21 @@ static int cqspi_probe(struct platform_device *pdev)
 
 	/* Obtain QSPI clocks. */
 	memcpy(&cqspi->clks, &cqspi_clks, sizeof(cqspi->clks));
-	ret = devm_clk_bulk_get_optional(dev, CLK_QSPI_NUM, cqspi->clks);
