phy: cix: enable ACPI stub-FDT PHY enumeration

diff --git a/drivers/phy/cix/Kconfig b/drivers/phy/cix/Kconfig
--- a/drivers/phy/cix/Kconfig
+++ b/drivers/phy/cix/Kconfig
@@ -3,7 +3,7 @@
 config PHY_CIX_PCIE
 	bool "CIX Sky1 PCIe PHY driver"
 	depends on ARCH_CIX || COMPILE_TEST
-	depends on OF
+	depends on ACPI || OF
 	select REGMAP
 	select GENERIC_PHY
 	help
@@ -14,7 +14,7 @@ config PHY_CIX_PCIE
 config PHY_CIX_USB2
 	bool "CIX Sky1 USB2 PHY driver"
 	depends on ARCH_CIX || COMPILE_TEST
-	depends on OF
+	depends on ACPI || OF
 	select GENERIC_PHY
 	help
 	  Enable this to support the USB2 PHY on CIX Sky1 SoCs.
@@ -22,7 +22,7 @@ config PHY_CIX_USB2
 config PHY_CIX_USB3
 	bool "CIX Sky1 USB3 PHY driver"
 	depends on ARCH_CIX || COMPILE_TEST
-	depends on OF
+	depends on ACPI || OF
 	select REGMAP
 	select GENERIC_PHY
 	help
@@ -31,7 +31,7 @@ config PHY_CIX_USB3
 config PHY_CIX_USBDP
 	tristate "CIX Sky1 USB-DP combo PHY driver"
 	depends on ARCH_CIX || COMPILE_TEST
-	depends on OF
+	depends on ACPI || OF
 	depends on TYPEC || TYPEC=n
 	select REGMAP
 	select GENERIC_PHY
