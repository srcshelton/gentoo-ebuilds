edac: a72: skip OF CPU-node discovery on ACPI boots

The Cortex-A72 EDAC helper is DT-described and emits one warning per CPU
when loaded on ACPI-only Sky1 systems.  Stand down under ACPI instead of
probing for nonexistent OF CPU nodes.

---
diff --git a/drivers/edac/a72_edac.c b/drivers/edac/a72_edac.c
--- a/drivers/edac/a72_edac.c
+++ b/drivers/edac/a72_edac.c
@@ -13,6 +13,7 @@
 #include <linux/module.h>
 #include <linux/of.h>
 #include <linux/bitfield.h>
+#include <linux/acpi.h>
 #include <asm/smp_plat.h>
 
 #include "edac_module.h"
@@ -187,6 +188,9 @@ static int __init a72_edac_driver_init(void)
 {
 	int cpu;
 
+	if (!acpi_disabled)
+		return 0;
+
 	for_each_possible_cpu(cpu) {
 		struct device_node *np __free(device_node) = of_cpu_device_node_get(cpu);
 		if (np) {
