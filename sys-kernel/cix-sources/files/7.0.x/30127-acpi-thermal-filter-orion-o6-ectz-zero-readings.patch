On Radxa Orion O6 firmware, the stock ECTZ _TMP method intermittently returns 0 dK even though immediate follow-up reads usually recover a sane value. A raw 0 dK becomes -273200 mC in sysfs, which is physically impossible and confuses thermal consumers.

Scope the workaround to the Orion O6 ECTZ thermal zone: retry up to three immediate reads when _TMP returns 0 dK, cache successful readings for up to 60 seconds, and return either a fresh last-known-good value or an error instead of exposing -273 C. Successful use of a fresh cached value is debug-only; only an expired or missing fallback remains visible as an error. During initial thermal-zone probe only, synthesize a loud one-shot 2732 dK reading if no real last-known-good value exists yet, so an unlucky zero-read burst cannot prevent the zone from registering for the whole boot; this synthetic bootstrap value is not cached.

---
diff --git a/drivers/acpi/thermal.c b/drivers/acpi/thermal.c
--- a/drivers/acpi/thermal.c
+++ b/drivers/acpi/thermal.c
@@ -24,6 +24,7 @@
 #include <linux/jiffies.h>
 #include <linux/kmod.h>
 #include <linux/reboot.h>
+#include <linux/sched.h>
 #include <linux/device.h>
 #include <linux/platform_device.h>
 #include <linux/thermal.h>
@@ -55,6 +56,9 @@
 #else
 #define ACPI_THERMAL_MAX_NR_TRIPS	(ACPI_THERMAL_MAX_ACTIVE + 3)
 #endif
+#define ACPI_THERMAL_ORION_O6_ECTZ_ZERO_RETRIES	3
+#define ACPI_THERMAL_ORION_O6_ECTZ_LKG_TIMEOUT	(60 * HZ)
+#define ACPI_THERMAL_ORION_O6_ECTZ_PROBE_BOOTSTRAP_DK	2732
 
 /*
  * This exception is thrown out in two cases:
@@ -121,8 +125,12 @@ struct acpi_thermal {
 	acpi_bus_id name;
 	unsigned long temp_dk;
 	unsigned long last_temp_dk;
+	unsigned long last_good_temp_dk;
+	unsigned long last_good_temp_jiffies;
 	unsigned long polling_frequency;
 	volatile u8 zombie;
+	bool has_last_good_temp;
+	bool orion_o6_ectz;
 	struct acpi_thermal_trips trips;
 	struct thermal_zone_device *thermal_zone;
 	int kelvin_offset;	/* in millidegrees */
@@ -138,25 +146,156 @@ struct acpi_thermal {
                              Thermal Zone Management
    -------------------------------------------------------------------------- */
 
+static bool acpi_thermal_is_radxa_orion_o6_ectz(struct acpi_thermal *tz)
+{
+	const char *sys_vendor = dmi_get_system_info(DMI_SYS_VENDOR);
+	const char *product_name = dmi_get_system_info(DMI_PRODUCT_NAME);
+	const char *board_name = dmi_get_system_info(DMI_BOARD_NAME);
+	char name[ACPI_NAMESEG_SIZE + 1] = {};
+	struct acpi_buffer buffer = { sizeof(name), name };
+
+	if (!tz || !tz->device)
+		return false;
+
+	if (!sys_vendor || strcmp(sys_vendor, "Radxa Computer (Shenzhen) Co., Ltd."))
+		return false;
+
+	if ((!product_name || strcmp(product_name, "Radxa Orion O6")) &&
+	    (!board_name || strcmp(board_name, "Radxa Orion O6")))
+		return false;
+
+	if (ACPI_FAILURE(acpi_get_name(tz->device->handle, ACPI_SINGLE_NAME,
+				       &buffer)))
+		return false;
+
+	return !strcmp(name, "ECTZ");
+}
+
+static int acpi_thermal_read_tmp(struct acpi_thermal *tz,
+				 unsigned long long *tmp)
+{
+	acpi_status status;
+
+	status = acpi_evaluate_integer(tz->device->handle, "_TMP", NULL, tmp);
+	if (ACPI_FAILURE(status))
+		return -ENODEV;
+
+	return 0;
+}
+
+static void acpi_thermal_save_last_good_tmp(struct acpi_thermal *tz,
+					    unsigned long long tmp)
+{
+	tz->last_good_temp_dk = tmp;
+	tz->last_good_temp_jiffies = jiffies;
+	tz->has_last_good_temp = true;
+
+	acpi_handle_debug(tz->device->handle,
+			  "Saved ECTZ last-known-good temperature %llu dK for %s[%d]\n",
+			  tmp, current->comm, current->pid);
+}
+
+static bool acpi_thermal_last_good_tmp_fresh(struct acpi_thermal *tz)
+{
+	return tz->has_last_good_temp &&
+	       time_before_eq(jiffies, tz->last_good_temp_jiffies +
+			      ACPI_THERMAL_ORION_O6_ECTZ_LKG_TIMEOUT);
+}
+
+static int acpi_thermal_handle_orion_o6_ectz_zero(struct acpi_thermal *tz,
+						  unsigned long long *tmp,
+						  bool *skip_last_good_save)
+{
+	unsigned long age_ms = 0;
+	int ret;
+	int retry;
+
+	*skip_last_good_save = false;
+
+	for (retry = 1; retry <= ACPI_THERMAL_ORION_O6_ECTZ_ZERO_RETRIES; retry++) {
+		acpi_handle_debug(tz->device->handle,
+				  "ECTZ _TMP returned 0 dK for %s[%d]; retrying (%d/%d)\n",
+				  current->comm, current->pid, retry,
+				  ACPI_THERMAL_ORION_O6_ECTZ_ZERO_RETRIES);
+
+		ret = acpi_thermal_read_tmp(tz, tmp);
+		if (ret)
+			return ret;
+
+		if (*tmp)
+			return 0;
+	}
+
+	if (tz->has_last_good_temp)
+		age_ms = jiffies_to_msecs(jiffies - tz->last_good_temp_jiffies);
+
+	if (acpi_thermal_last_good_tmp_fresh(tz)) {
+		*tmp = tz->last_good_temp_dk;
+		*skip_last_good_save = true;
+		acpi_handle_debug(tz->device->handle,
+				  "ECTZ _TMP still returned 0 dK for %s[%d] after %d retries; using last-known-good %llu dK (%lu ms old)\n",
+				  current->comm, current->pid,
+				  ACPI_THERMAL_ORION_O6_ECTZ_ZERO_RETRIES,
+				  *tmp, age_ms);
+		return 0;
+	}
+
+	if (!tz->thermal_zone) {
+		*tmp = ACPI_THERMAL_ORION_O6_ECTZ_PROBE_BOOTSTRAP_DK;
+		*skip_last_good_save = true;
+		acpi_handle_err(tz->device->handle,
+				"ECTZ _TMP still returned 0 dK for %s[%d] after %d retries; using synthetic %llu dK once to allow thermal-zone probe\n",
+				current->comm, current->pid,
+				ACPI_THERMAL_ORION_O6_ECTZ_ZERO_RETRIES,
+				*tmp);
+		return 0;
+	}
+
+	if (tz->has_last_good_temp)
+		acpi_handle_err(tz->device->handle,
+				"ECTZ _TMP still returned 0 dK for %s[%d] after %d retries; last-known-good %lu dK expired (%lu ms old)\n",
+				current->comm, current->pid,
+				ACPI_THERMAL_ORION_O6_ECTZ_ZERO_RETRIES,
+				tz->last_good_temp_dk, age_ms);
+	else
+		acpi_handle_err(tz->device->handle,
+				"ECTZ _TMP still returned 0 dK for %s[%d] after %d retries; no last-known-good temperature is available\n",
+				current->comm, current->pid,
+				ACPI_THERMAL_ORION_O6_ECTZ_ZERO_RETRIES);
+
+	return -ENODATA;
+}
+
 static int acpi_thermal_get_temperature(struct acpi_thermal *tz)
 {
-	acpi_status status = AE_OK;
 	unsigned long long tmp;
+	bool skip_last_good_save = false;
+	int ret;
 
 	if (!tz)
 		return -EINVAL;
 
 	tz->last_temp_dk = tz->temp_dk;
 
-	status = acpi_evaluate_integer(tz->device->handle, "_TMP", NULL, &tmp);
-	if (ACPI_FAILURE(status))
-		return -ENODEV;
+	ret = acpi_thermal_read_tmp(tz, &tmp);
+	if (ret)
+		return ret;
+
+	if (tz->orion_o6_ectz && !tmp) {
+		ret = acpi_thermal_handle_orion_o6_ectz_zero(tz, &tmp,
+							     &skip_last_good_save);
+		if (ret)
+			return ret;
+	}
 
 	tz->temp_dk = tmp;
 
 	acpi_handle_debug(tz->device->handle, "Temperature is %lu dK\n",
 			  tz->temp_dk);
 
+	if (tz->orion_o6_ectz && !skip_last_good_save)
+		acpi_thermal_save_last_good_tmp(tz, tmp);
+
 	return 0;
 }
 
@@ -889,6 +1028,7 @@ static int acpi_thermal_probe(struct platform_device *pdev)
 	platform_set_drvdata(pdev, tz);
 
 	tz->device = device;
+	tz->orion_o6_ectz = acpi_thermal_is_radxa_orion_o6_ectz(tz);
 	strscpy(tz->name, device->pnp.bus_id);
 	strscpy(acpi_device_name(device), ACPI_THERMAL_DEVICE_NAME);
 	strscpy(acpi_device_class(device), ACPI_THERMAL_CLASS);
