hwmon: cix-fan: scale EC PWM duty codes to hwmon PWM range

The CIX EC reports automatic fan duty as raw setpoint codes rather than a
0..100 percentage.  Observed values form a 0..128 scale, with 0xff used
as the EC failure sentinel.  Accept the 0..128 EC range, round it to the
nearest 5 percent step for stable presentation, and convert to the hwmon
0..255 PWM range at the ABI boundary.

diff --git a/drivers/hwmon/cix-fan.c b/drivers/hwmon/cix-fan.c
--- a/drivers/hwmon/cix-fan.c
+++ b/drivers/hwmon/cix-fan.c
@@ -5,7 +5,7 @@
  * Copyright (C) 2024 CIX Technology Group Co., Ltd.
  *
  * Fan control is exposed by the CIXHA024 ACPI hardware-monitor wrapper:
- *   GFPW(type, index)       - get PWM duty percentage, 0xff on EC failure
+ *   GFPW(type, index)       - get EC PWM duty code, 0xff on EC failure
  *   SFPW(duty, type, index) - set PWM duty percentage
  *   SFMT/SFAT/SFPF          - mute, automatic, performance modes
  */
@@ -21,6 +21,8 @@
 
 #define CIX_FAN_EC_FAILURE	0xff
 #define CIX_FAN_EC_FAILURE_RETRIES	3
+#define CIX_FAN_EC_MAX_DUTY	128
+#define CIX_FAN_PERCENT_STEP	5
 #define CIX_FAN_LKG_TIMEOUT	(60 * HZ)
 #define CIX_FAN_EC0_GFPW_PATH	"\\_SB.EC0.GFPW"
 #define CIX_FAN_HWMN_PATH	"\\_SB.HWMN"
@@ -40,7 +42,7 @@ struct cix_fan_data {
 	bool pwm_get_needs_args;
 	struct mutex lock;	/* Protects ACPI fan methods and cached state. */
 	unsigned long last_good_pwm_jiffies;
-	unsigned long last_good_pwm_percent;
+	unsigned long last_good_pwm_raw;
 	int pwm_enable;
 	bool has_last_good_pwm;
 };
@@ -99,24 +101,46 @@ static int cix_fan_eval_object(struct cix_fan_data *data, const char *method,
 	return 0;
 }
 
-static int cix_fan_read_pwm_percent_raw(struct cix_fan_data *data,
-					struct acpi_object_list *args,
-					unsigned long long *duty)
+static int cix_fan_read_pwm_raw(struct cix_fan_data *data,
+				struct acpi_object_list *args,
+				unsigned long long *duty)
 {
 	return cix_fan_eval_integer(data, data->pwm_get_handle, NULL,
 				    data->pwm_get_label, args, duty);
 }
 
+static unsigned long cix_fan_raw_to_percent(unsigned long long duty)
+{
+	unsigned long percent;
+
+	percent = DIV_ROUND_CLOSEST((unsigned long)duty * 100,
+				    CIX_FAN_EC_MAX_DUTY);
+	percent = DIV_ROUND_CLOSEST(percent, CIX_FAN_PERCENT_STEP) *
+		  CIX_FAN_PERCENT_STEP;
+	if (percent > 100)
+		percent = 100;
+
+	return percent;
+}
+
+static long cix_fan_raw_to_hwmon_pwm(unsigned long long duty)
+{
+	unsigned long percent = cix_fan_raw_to_percent(duty);
+
+	return DIV_ROUND_CLOSEST(percent * 255, 100);
+}
+
