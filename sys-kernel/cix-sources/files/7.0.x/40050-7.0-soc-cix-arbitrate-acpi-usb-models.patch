soc: cix: arbitrate Sky1 ACPI USB generic and vendor models

CIX's 7.0 USB scan handler always blocks PNP0D10 on Sky1 so the vendor USB
model can bind. That is only appropriate for firmware that exposes the vendor
model alone. Vendor firmware exposes both generic PNP0D10 and CIXH2030-CIXH2034
nodes for overlapping hardware, and the deterministic fix is to prefer the
upstream generic model when both are present while leaving vendor-only firmware
unchanged.

Register the vendor IDs with the scan handler, keep PNP0D10 when any vendor
USB node is present, and suppress only the duplicate vendor model when PNP0D10
exists. Hide the helper Kconfig prompt because it is internal platform
arbitration rather than a user-selectable driver.

---
diff --git a/drivers/soc/cix/Kconfig b/drivers/soc/cix/Kconfig
--- a/drivers/soc/cix/Kconfig
+++ b/drivers/soc/cix/Kconfig
@@ -16,14 +16,15 @@ config CIX_ACPI_RESOURCE_LOOKUP
 	  platform_get_resource_byname() or devm_reset_control_get().
 
 config CIX_ACPI_USB_SCAN
-	bool "CIX ACPI USB scan handler"
+	bool
 	depends on ARCH_CIX || COMPILE_TEST
 	depends on ACPI
 	default ARCH_CIX
 	help
-	  Block PNP0D10 (generic xHCI) platform device creation on CIX Sky1
-	  so the vendor USB driver chain (cdnsp-sky1 + cdnsp-plat) can own
-	  the hardware instead of xhci-plat.
-
-	  Required for proper USB controller initialization under ACPI boot.
-
+	  Internal ACPI arbitration helper for vendor firmware that exposes
+	  both generic upstream PNP0D10 and vendor CIXH2030-CIXH2034 USB
+	  devices for the same Sky1 controller. When both models are present,
+	  the arbiter prefers the generic upstream PNP0D10 path and suppresses
+	  the overlapping vendor USB devices. With firmware that exposes only
+	  one model, the helper either stands down or allows the vendor-only
+	  devices to enumerate unchanged.
diff --git a/drivers/soc/cix/cix-acpi-usb-scan.c b/drivers/soc/cix/cix-acpi-usb-scan.c
--- a/drivers/soc/cix/cix-acpi-usb-scan.c
+++ b/drivers/soc/cix/cix-acpi-usb-scan.c
@@ -1,38 +1,83 @@
 // SPDX-License-Identifier: GPL-2.0
 /*
- * ACPI scan handler to block PNP0D10 (generic xHCI) on CIX Sky1.
+ * ACPI scan handler to arbitrate between generic and vendor USB models on
+ * CIX Sky1.
  *
- * The Sky1 DSDT defines both PNP0D10 (generic xHCI) and CIXH2030/CIXH2031
- * (vendor USB wrapper/controller) for each USB port, with overlapping MMIO
- * on the xHCI register block.  The vendor driver chain (cdnsp-sky1 for
- * CIXH2030 wrapper → cdnsp-plat for CIXH2031 controller) must own the
- * hardware for proper initialization including timing prescalers, APB
- * timeout chicken bits, and PHY lifecycle management.
- *
- * Block PNP0D10 platform device creation so xhci-plat doesn't race for
- * the same MMIO region.  Same pattern as pci-sky1-acpi.c blocking PNP0A08.
+ * Vendor Sky1 firmware exposes both generic upstream PNP0D10 (xHCI) and
+ * CIXH2030-CIXH2034 (vendor USB wrapper/controller/PHY companions) for the
+ * same hardware. Custom firmware may expose only one model. When both models
+ * are present, prefer the generic path and suppress the overlapping vendor
+ * USB devices. When only the vendor model is present, allow those vendor
+ * devices to enumerate unchanged.
  */
 
 #ifdef CONFIG_ACPI
 
 #include <linux/acpi.h>
 #include <linux/init.h>
+#include <linux/string.h>
 
 static bool sky1_usb_acpi_detected;
 
+static acpi_status sky1_usb_match_handle(acpi_handle handle, u32 level,
+					 void *context, void **ret)
+{
+	bool *present = context;
+
+	*present = true;
+	return AE_CTRL_TERMINATE;
+}
+
+static bool sky1_usb_acpi_id_present(const char *hid)
+{
+	bool present = false;
+
+	acpi_get_devices(hid, sky1_usb_match_handle, &present, NULL);
+
+	return present;
+}
+
+static bool sky1_usb_vendor_present(void)
+{
+	return sky1_usb_acpi_id_present("CIXH2030") ||
+	       sky1_usb_acpi_id_present("CIXH2031") ||
+	       sky1_usb_acpi_id_present("CIXH2032") ||
+	       sky1_usb_acpi_id_present("CIXH2033") ||
+	       sky1_usb_acpi_id_present("CIXH2034");
+}
+
 static int sky1_usb_scan_attach(struct acpi_device *adev,
 				const struct acpi_device_id *id)
 {
 	if (!sky1_usb_acpi_detected)
 		return 0;
 
-	dev_info(&adev->dev,
-		 "Sky1: blocking PNP0D10, CIXH2030/CIXH2031 will handle USB\n");
-	return 1;
+	if (!strcmp(id->id, "PNP0D10")) {
+		if (!sky1_usb_vendor_present())
+			return 0;
+
+		dev_info(&adev->dev,
+			 "Sky1 USB: keeping PNP0D10, suppressing vendor USB model instead\n");
+		return 0;
+	}
+
+	if (sky1_usb_acpi_id_present("PNP0D10")) {
+		dev_info(&adev->dev,
+			 "Sky1 USB: suppressing %s because PNP0D10 is present\n",
+			 id->id);
+		return 1;
+	}
+
+	return 0;
 }
 
 static const struct acpi_device_id sky1_usb_scan_ids[] = {
 	{ "PNP0D10", 0 },
+	{ "CIXH2030", 0 },
+	{ "CIXH2031", 0 },
+	{ "CIXH2032", 0 },
+	{ "CIXH2033", 0 },
+	{ "CIXH2034", 0 },
 	{ },
 };
 
@@ -59,7 +104,7 @@ static int __init sky1_usb_acpi_init(void)
 	if (!sky1_usb_acpi_detected)
 		return 0;
 
-	pr_info("Sky1 USB: registering PNP0D10 scan handler\n");
+	pr_info("Sky1 USB: registering ACPI USB arbitration handler\n");
 	return acpi_scan_add_handler(&sky1_usb_scan_handler);
 }
 /* Must run before subsys_initcall(acpi_init) which creates platform devices */
