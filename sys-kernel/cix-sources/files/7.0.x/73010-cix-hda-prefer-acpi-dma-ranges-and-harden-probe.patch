+static int cix_ipbloq_hda_alloc_stream_pages(struct cix_ipbloq_hda *hda)
+{
+	struct azx *chip = &hda->chip;
+	struct hdac_bus *bus = azx_bus(chip);
+	struct hdac_stream *s;
+	u8 *area;
+	dma_addr_t addr;
+	size_t offset = 0;
+	size_t posbuf_offset;
+	size_t rb_offset;
+	size_t alloc_size;
+	int dma_type = bus->dma_type ? bus->dma_type : SNDRV_DMA_TYPE_DEV;
+	int num_streams = 0;
+	int err;
+
+	list_for_each_entry(s, &bus->stream_list, list) {
+		offset = ALIGN(offset, SZ_4K);
+		offset += BDL_SIZE;
+		num_streams++;
+	}
+
+	if (WARN_ON(!num_streams))
+		return -EINVAL;
+
+	posbuf_offset = ALIGN(offset, SZ_4K);
+	offset = posbuf_offset + num_streams * 8;
+
+	rb_offset = ALIGN(offset, SZ_4K);
+	offset = rb_offset + PAGE_SIZE;
+
+	alloc_size = max_t(size_t, ALIGN(offset, SZ_4K),
+			   CIX_HDA_STREAM_DMA_MIN_ALLOC);
+
+	err = snd_dma_alloc_pages(dma_type, bus->dev, alloc_size,
+				  &hda->stream_dma);
+	if (err < 0)
+		return err;
+
+	area = hda->stream_dma.area;
+	addr = hda->stream_dma.addr;
+	offset = 0;
+
+	list_for_each_entry(s, &bus->stream_list, list) {
+		offset = ALIGN(offset, SZ_4K);
+		s->bdl.area = area + offset;
+		s->bdl.addr = addr + offset;
+		s->bdl.bytes = BDL_SIZE;
+		offset += BDL_SIZE;
+	}
+
+	bus->posbuf.area = area + posbuf_offset;
+	bus->posbuf.addr = addr + posbuf_offset;
+	bus->posbuf.bytes = num_streams * 8;
+	list_for_each_entry(s, &bus->stream_list, list)
+		s->posbuf = (__le32 *)(bus->posbuf.area + s->index * 8);
+
+	bus->rb.area = area + rb_offset;
+	bus->rb.addr = addr + rb_offset;
+	bus->rb.bytes = PAGE_SIZE;
+
+	return 0;
+}
+
+static void cix_ipbloq_hda_free_stream_pages(struct cix_ipbloq_hda *hda)
+{
+	struct hdac_bus *bus = azx_bus(&hda->chip);
+	struct hdac_stream *s;
+
+	if (!hda->stream_dma.area)
+		return;
+
+	list_for_each_entry(s, &bus->stream_list, list) {
+		s->bdl.area = NULL;
+		s->bdl.addr = 0;
+		s->bdl.bytes = 0;
+		s->posbuf = NULL;
+	}
+
+	bus->posbuf.area = NULL;
+	bus->posbuf.addr = 0;
+	bus->posbuf.bytes = 0;
+	bus->rb.area = NULL;
+	bus->rb.addr = 0;
+	bus->rb.bytes = 0;
+
+	snd_dma_free_pages(&hda->stream_dma);
+	memset(&hda->stream_dma, 0, sizeof(hda->stream_dma));
+}
