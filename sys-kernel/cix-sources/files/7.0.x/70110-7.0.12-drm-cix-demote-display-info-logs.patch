@@ -84,7 +84,7 @@ static int cix_display_probe(struct platform_device *pdev)
        base = ioremap(DISPLAY_RESET_REG, 0x4);
 
        value = readl(base);
-       dev_info(dev, "current reset value = 0x%x, reset-control=%d\n", value, control);
+       dev_dbg(dev, "current reset value = 0x%x, reset-control=%d\n", value, control);
 
        count = 0;
        for (i = 0; i < 5; i++) {
@@ -98,7 +98,7 @@ static int cix_display_probe(struct platform_device *pdev)
         if (count) {
                 value &= (~MMHUB_RESET_MASK);
                 writel(value, base);
-                dev_info(dev, "assert reset, value = 0x%x, count=%d\n", value, count);
+                dev_dbg(dev, "assert reset, value = 0x%x, count=%d\n", value, count);
         }
 
        for (i = 0; i < 5; i++) {
@@ -110,11 +110,11 @@ static int cix_display_probe(struct platform_device *pdev)
