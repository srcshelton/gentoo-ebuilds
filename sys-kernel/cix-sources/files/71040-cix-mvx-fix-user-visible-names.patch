@@ -38,7 +38,7 @@
 
 MODULE_LICENSE("GPL");
 MODULE_AUTHOR("ARMChina");
-MODULE_DESCRIPTION("Tiube VPU Driver.");
+MODULE_DESCRIPTION("CIX/ArmChina Linlon MVX VPU codec driver (amvx).");
 MODULE_IMPORT_NS("VFS_internal_I_am_really_a_filesystem_and_am_NOT_a_driver");
