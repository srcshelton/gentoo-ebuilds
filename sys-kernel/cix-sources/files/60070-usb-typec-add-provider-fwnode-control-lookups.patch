usb: typec: add provider-fwnode control lookup helpers

Allow ACPI graph consumers to acquire Type-C mux and orientation-switch controls by the provider fwnode registered by the provider driver.

---
diff --git a/drivers/usb/typec/mux.c b/drivers/usb/typec/mux.c
--- a/drivers/usb/typec/mux.c
+++ b/drivers/usb/typec/mux.c
@@ -117,6 +117,49 @@ struct typec_switch *fwnode_typec_switch_get(struct fwnode_handle *fwnode)
 }
 EXPORT_SYMBOL_GPL(fwnode_typec_switch_get);
 
+/**
+ * typec_switch_find_by_fwnode - Find USB Type-C orientation switch by provider
+ * @fwnode: The switch provider fwnode
+ *
+ * Finds a switch registered directly against @fwnode. This complements
+ * fwnode_typec_switch_get(), which looks for switches connected to a consumer
+ * fwnode.
+ */
+struct typec_switch *
+typec_switch_find_by_fwnode(const struct fwnode_handle *fwnode)
+{
+	struct typec_switch_dev *sw_dev;
+	struct typec_switch *sw;
+	struct device *dev;
+
+	if (!fwnode)
+		return NULL;
+
+	dev = class_find_device(&typec_mux_class, NULL, fwnode,
+				switch_fwnode_match);
+	if (!dev)
+		return NULL;
+
+	sw_dev = to_typec_switch_dev(dev);
+	sw = kzalloc(sizeof(*sw), GFP_KERNEL);
+	if (!sw) {
+		put_device(&sw_dev->dev);
+		return ERR_PTR(-ENOMEM);
+	}
+
+	if (!try_module_get(sw_dev->dev.parent->driver->owner)) {
+		put_device(&sw_dev->dev);
+		kfree(sw);
+		return ERR_PTR(-ENODEV);
+	}
+
+	sw->sw_devs[0] = sw_dev;
+	sw->num_sw_devs = 1;
+
+	return sw;
+}
+EXPORT_SYMBOL_GPL(typec_switch_find_by_fwnode);
+
 /**
  * typec_switch_put - Release USB Type-C orientation switch
  * @sw: USB Type-C orientation switch
@@ -342,6 +385,47 @@ struct typec_mux *fwnode_typec_mux_get(struct fwnode_handle *fwnode)
 }
 EXPORT_SYMBOL_GPL(fwnode_typec_mux_get);
 
+/**
+ * typec_mux_find_by_fwnode - Find USB Type-C Multiplexer by provider
+ * @fwnode: The mux provider fwnode
+ *
+ * Finds a mux registered directly against @fwnode. This complements
+ * fwnode_typec_mux_get(), which looks for muxes connected to a consumer fwnode.
+ */
+struct typec_mux *typec_mux_find_by_fwnode(const struct fwnode_handle *fwnode)
+{
+	struct typec_mux_dev *mux_dev;
+	struct typec_mux *mux;
+	struct device *dev;
+
+	if (!fwnode)
+		return NULL;
+
+	dev = class_find_device(&typec_mux_class, NULL, fwnode,
+				mux_fwnode_match);
+	if (!dev)
+		return NULL;
+
+	mux_dev = to_typec_mux_dev(dev);
+	mux = kzalloc(sizeof(*mux), GFP_KERNEL);
+	if (!mux) {
+		put_device(&mux_dev->dev);
+		return ERR_PTR(-ENOMEM);
+	}
+
+	if (!try_module_get(mux_dev->dev.parent->driver->owner)) {
+		put_device(&mux_dev->dev);
+		kfree(mux);
+		return ERR_PTR(-ENODEV);
+	}
+
+	mux->mux_devs[0] = mux_dev;
+	mux->num_mux_devs = 1;
+
+	return mux;
+}
+EXPORT_SYMBOL_GPL(typec_mux_find_by_fwnode);
+
 /**
  * typec_mux_put - Release handle to a Multiplexer
  * @mux: USB Type-C Connector Multiplexer/DeMultiplexer
diff --git a/include/linux/usb/typec_mux.h b/include/linux/usb/typec_mux.h
--- a/include/linux/usb/typec_mux.h
+++ b/include/linux/usb/typec_mux.h
@@ -28,6 +28,8 @@ struct typec_switch_desc {
 #if IS_ENABLED(CONFIG_TYPEC)
 
 struct typec_switch *fwnode_typec_switch_get(struct fwnode_handle *fwnode);
+struct typec_switch *
+typec_switch_find_by_fwnode(const struct fwnode_handle *fwnode);
 void typec_switch_put(struct typec_switch *sw);
 int typec_switch_set(struct typec_switch *sw,
 		     enum typec_orientation orientation);
@@ -48,6 +50,12 @@ fwnode_typec_switch_get(struct fwnode_handle *fwnode)
 	return NULL;
 }
 
+static inline struct typec_switch *
+typec_switch_find_by_fwnode(const struct fwnode_handle *fwnode)
+{
+	return NULL;
+}
+
 static inline void typec_switch_put(struct typec_switch *sw) {}
 
 static inline int typec_switch_set(struct typec_switch *sw,
@@ -97,6 +105,7 @@ struct typec_mux_desc {
 #if IS_ENABLED(CONFIG_TYPEC)
 
 struct typec_mux *fwnode_typec_mux_get(struct fwnode_handle *fwnode);
+struct typec_mux *typec_mux_find_by_fwnode(const struct fwnode_handle *fwnode);
 void typec_mux_put(struct typec_mux *mux);
 int typec_mux_set(struct typec_mux *mux, struct typec_mux_state *state);
 
@@ -114,6 +123,12 @@ static inline struct typec_mux *fwnode_typec_mux_get(struct fwnode_handle *fwnod
 	return NULL;
 }
 
+static inline struct typec_mux *
+typec_mux_find_by_fwnode(const struct fwnode_handle *fwnode)
+{
+	return NULL;
+}
+
 static inline void typec_mux_put(struct typec_mux *mux) {}
 
 static inline int typec_mux_set(struct typec_mux *mux, struct typec_mux_state *state)
