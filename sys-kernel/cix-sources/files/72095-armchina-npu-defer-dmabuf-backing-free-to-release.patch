misc: armchina-npu: fix dma-buf and device lifetime

Keep the dma-buf backing allocation and NPU private/MM state alive until all exported dma-bufs, imported dma-bufs, and open file users have released their references.

---
diff --git a/drivers/misc/armchina-npu/aipu.c b/drivers/misc/armchina-npu/aipu.c
--- a/drivers/misc/armchina-npu/aipu.c
+++ b/drivers/misc/armchina-npu/aipu.c
@@ -8,6 +8,7 @@
 #include <linux/mm_types.h>
 #include <linux/sched.h>
 #include <linux/fs.h>
+#include <linux/mutex.h>
 #include <linux/uaccess.h>
 #include <linux/poll.h>
 #include <linux/compat.h>
@@ -27,16 +28,45 @@
 #endif
 
 static struct aipu_priv *aipu;
+static DEFINE_MUTEX(aipu_lock);
+
+static struct aipu_priv *aipu_get_global(void)
+{
+	struct aipu_priv *priv;
+
+	mutex_lock(&aipu_lock);
+	priv = aipu;
+	if (!aipu_priv_get(priv))
+		priv = NULL;
+	mutex_unlock(&aipu_lock);
+
+	return priv;
+}
 
 static int aipu_open(struct inode *inode, struct file *filp)
 {
-	filp->private_data = aipu;
+	int ret;
+	struct aipu_priv *priv = aipu_get_global();
+
+	if (!priv)
+		return -ENODEV;
+
+	filp->private_data = priv;
 
 #ifdef CONFIG_SKY1
-	sky1_npu_pm_runtime_get_sync(aipu->dev);
+	sky1_npu_pm_runtime_get_sync(priv->dev);
 #endif
 
-	return aipu_priv_check_status(aipu);
+	ret = aipu_priv_check_status(priv);
+	if (ret) {
+#ifdef CONFIG_SKY1
+		sky1_npu_pm_runtime_put(priv->dev);
+#endif
+		filp->private_data = NULL;
+		aipu_priv_put(priv);
+	}
+
+	return ret;
 }
 
 static int aipu_release(struct inode *inode, struct file *filp)
@@ -44,24 +74,31 @@ static int aipu_release(struct inode *inode, struct file *filp)
 	int ret = 0;
 	struct aipu_priv *aipu = filp->private_data;
 
+	if (!aipu)
+		return 0;
+
 	ret = aipu_job_manager_cancel_jobs(&aipu->job_manager, filp);
 	if (ret)
-		return ret;
+		dev_warn(aipu->dev, "failed to cancel jobs during release: %d\n", ret);
 
+	aipu_detach_dma_bufs(&aipu->mm, filp);
 	aipu_mm_free_buffers(&aipu->mm, filp);
 
 #ifdef CONFIG_SKY1
 	sky1_npu_pm_runtime_put(aipu->dev);
 #endif
 
-	return 0;
+	filp->private_data = NULL;
+	aipu_priv_put(aipu);
+
+	return ret;
 }
 
 static long aipu_ioctl(struct file *filp, unsigned int cmd, unsigned long arg)
 {
 	int ret = 0;
 	struct aipu_priv *aipu = filp->private_data;
-	struct aipu_job_manager *manager = &aipu->job_manager;
+	struct aipu_job_manager *manager = NULL;
 
 	u32 partition_cnt = 0;
 	struct aipu_partition_cap *partition_cap = NULL;
@@ -80,6 +117,11 @@ static long aipu_ioctl(struct file *filp, unsigned int cmd, unsigned long arg)
 
 	u64 job_id;
 
+	if (aipu_priv_is_removing(aipu))
+		return -ENODEV;
+
+	manager = &aipu->job_manager;
+
 	switch (cmd) {
 	case AIPU_IOCTL_QUERY_CAP:
 		ret = aipu_priv_query_capability(aipu, &cap);
@@ -183,7 +225,7 @@ static long aipu_ioctl(struct file *filp, unsigned int cmd, unsigned long arg)
 	case AIPU_IOCTL_ALLOC_DMA_BUF:
 		if (!copy_from_user(&dmabuf_req, (struct aipu_dma_buf_request __user *)arg,
 				    sizeof(dmabuf_req))) {
-			ret = aipu_alloc_dma_buf(&aipu->mm, &dmabuf_req);
+			ret = aipu_alloc_dma_buf(aipu, &dmabuf_req);
 			if (!ret && copy_to_user((struct aipu_dma_buf_request __user *)arg,
 						 &dmabuf_req, sizeof(dmabuf_req)))
 				ret = -EINVAL;
@@ -193,7 +235,7 @@ static long aipu_ioctl(struct file *filp, unsigned int cmd, unsigned long arg)
 		break;
 	case AIPU_IOCTL_FREE_DMA_BUF:
 		if (!copy_from_user(&fd, (int __user *)arg, sizeof(fd)))
-			ret = aipu_free_dma_buf(&aipu->mm, fd);
+			ret = aipu_free_dma_buf(aipu, fd);
 		else
 			ret = -EINVAL;
 		break;
@@ -211,7 +253,7 @@ static long aipu_ioctl(struct file *filp, unsigned int cmd, unsigned long arg)
 	case AIPU_IOCTL_ATTACH_DMA_BUF:
 		if (!copy_from_user(&dmabuf_info, (struct aipu_dma_buf __user *)arg,
 				    sizeof(dmabuf_info))) {
-			ret = aipu_attach_dma_buf(&aipu->mm, &dmabuf_info);
+			ret = aipu_attach_dma_buf(&aipu->mm, &dmabuf_info, filp);
 			if (!ret && copy_to_user((struct aipu_dma_buf __user *)arg,
 						 &dmabuf_info, sizeof(dmabuf_info)))
 				ret = -EINVAL;
@@ -221,7 +263,7 @@ static long aipu_ioctl(struct file *filp, unsigned int cmd, unsigned long arg)
 		break;
 	case AIPU_IOCTL_DETACH_DMA_BUF:
 		if (!copy_from_user(&fd, (int __user *)arg, sizeof(fd)))
-			ret = aipu_detach_dma_buf(&aipu->mm, fd);
+			ret = aipu_detach_dma_buf(&aipu->mm, fd, filp);
 		else
 			ret = -EINVAL;
 		break;
@@ -284,6 +326,9 @@ static int aipu_mmap(struct file *filp, struct vm_area_struct *vma)
 {
 	struct aipu_priv *aipu = filp->private_data;
 
+	if (aipu_priv_is_removing(aipu))
+		return -ENODEV;
+
 	return aipu_mm_mmap_buf(&aipu->mm, vma, filp);
 }
 
@@ -292,6 +337,9 @@ static unsigned int aipu_poll(struct file *filp, struct poll_table_struct *wait)
 	unsigned int mask = 0;
 	struct aipu_priv *aipu = filp->private_data;
 
+	if (aipu_priv_is_removing(aipu))
+		return POLLERR | POLLHUP;
+
 	if (aipu_job_manager_has_end_job(&aipu->job_manager, filp, wait, task_pid_nr(current)))
 		mask |= POLLIN | POLLRDNORM;
 
@@ -330,33 +378,45 @@ int armchina_aipu_probe(struct platform_device *p_dev, struct aipu_soc *soc,
 {
 	int ret = 0;
 	struct device *dev = &p_dev->dev;
+	struct aipu_priv *priv = NULL;
 	struct aipu_partition *partition = NULL;
 	u32 id = 0;
 
 	/* create & init aipu priv struct shared by all clusters/cores */
 	if (!aipu) {
-		aipu = devm_kzalloc(dev, sizeof(*aipu), GFP_KERNEL);
-		if (!aipu)
+		priv = kzalloc(sizeof(*priv), GFP_KERNEL);
+		if (!priv)
 			return -ENOMEM;
 
 		dev_info(dev, "AIPU KMD (v%s) probe start...\n", KMD_VERSION);
 
-		ret = init_aipu_priv(aipu, p_dev, &aipu_fops, soc, ops);
+		ret = init_aipu_priv(priv, p_dev, &aipu_fops, soc, ops);
 		if (ret) {
 			dev_err(dev, "FAIL TO INIT AIPU.\n");
-			aipu = NULL;
+			kfree(priv);
 			return ret;
 		}
+
+		mutex_lock(&aipu_lock);
+		aipu = priv;
+		mutex_unlock(&aipu_lock);
 	}
 
 	device_property_read_u32(dev, "core-id", &id);
+	priv = aipu;
 
-	WARN_ON(!aipu->ops);
-	partition = aipu->ops->create_partitions(aipu, id, p_dev);
+	WARN_ON(!priv->ops);
+	partition = priv->ops->create_partitions(priv, id, p_dev);
 	if (IS_ERR(partition)) {
 		dev_err(dev, "FAIL TO CREATE PARTITION.\n");
-		deinit_aipu_priv(aipu);
-		aipu = NULL;
+		aipu_priv_begin_remove(priv);
+		mutex_lock(&aipu_lock);
+		if (aipu == priv)
+			aipu = NULL;
+		mutex_unlock(&aipu_lock);
+		aipu_priv_drop_driver_ref_and_wait(priv);
+		deinit_aipu_priv(priv);
+		kfree(priv);
 		ret = -EIO;
 	} else {
 		platform_set_drvdata(p_dev, partition);
@@ -378,9 +438,29 @@ EXPORT_SYMBOL(armchina_aipu_probe);
  */
 int armchina_aipu_remove(struct platform_device *p_dev)
 {
-	if (!aipu || !aipu->is_init)
+	struct aipu_priv *priv;
+
+	mutex_lock(&aipu_lock);
+	priv = aipu;
+	if (!priv || !priv->is_init) {
+		mutex_unlock(&aipu_lock);
 		return 0;
-	return deinit_aipu_priv(aipu);
+	}
+
+	aipu = NULL;
+	aipu_priv_begin_remove(priv);
+	mutex_unlock(&aipu_lock);
+
+	/*
+	 * Existing file descriptors and exported dma-bufs can still need the
+	 * MM/DMA state for cleanup. Drain those references before devres and
+	 * platform removal can invalidate the backing device state.
+	 */
+	aipu_priv_drop_driver_ref_and_wait(priv);
+	deinit_aipu_priv(priv);
+	kfree(priv);
+
+	return 0;
 }
 EXPORT_SYMBOL(armchina_aipu_remove);
 
@@ -437,7 +517,16 @@ EXPORT_SYMBOL(armchina_aipu_resume);
  */
 int armchina_aipu_alloc_dma_buf(struct aipu_dma_buf_request *request)
 {
-	return aipu_alloc_dma_buf(&aipu->mm, request);
+	int ret;
+	struct aipu_priv *priv = aipu_get_global();
+
+	if (!priv)
+		return -ENODEV;
+
+	ret = aipu_alloc_dma_buf(priv, request);
+	aipu_priv_put(priv);
+
+	return ret;
 }
 EXPORT_SYMBOL(armchina_aipu_alloc_dma_buf);
 
@@ -448,7 +537,16 @@ EXPORT_SYMBOL(armchina_aipu_alloc_dma_buf);
  */
 int armchina_aipu_free_dma_buf(int fd)
 {
-	return aipu_free_dma_buf(&aipu->mm, fd);
+	int ret;
+	struct aipu_priv *priv = aipu_get_global();
+
+	if (!priv)
+		return -ENODEV;
+
+	ret = aipu_free_dma_buf(priv, fd);
+	aipu_priv_put(priv);
+
+	return ret;
 }
 EXPORT_SYMBOL(armchina_aipu_free_dma_buf);
 
diff --git a/drivers/misc/armchina-npu/aipu_dma_buf.c b/drivers/misc/armchina-npu/aipu_dma_buf.c
--- a/drivers/misc/armchina-npu/aipu_dma_buf.c
+++ b/drivers/misc/armchina-npu/aipu_dma_buf.c
@@ -3,9 +3,11 @@
 
 #include <linux/version.h>
 #include <linux/module.h>
+#include <linux/err.h>
 #include <linux/scatterlist.h>
 #include <linux/slab.h>
 #include "aipu_dma_buf.h"
+#include "aipu_priv.h"
 
 #if KERNEL_VERSION(4, 19, 0) > LINUX_VERSION_CODE
 static int aipu_dma_buf_attach(struct dma_buf *dmabuf, struct device *dev,
@@ -14,6 +16,11 @@ static int aipu_dma_buf_attach(struct dma_buf *dmabuf, struct device *dev,
 static int aipu_dma_buf_attach(struct dma_buf *dmabuf, struct dma_buf_attachment *attach)
 #endif
 {
+	struct aipu_dma_buf_priv *priv = (struct aipu_dma_buf_priv *)dmabuf->priv;
+
+	if (aipu_priv_is_removing(priv->aipu))
+		return -ENODEV;
+
 	return 0;
 }
 
@@ -29,6 +36,9 @@ static struct sg_table *aipu_map_dma_buf(struct dma_buf_attachment *attach,
 	struct aipu_dma_buf_priv *priv = (struct aipu_dma_buf_priv *)attach->dmabuf->priv;
 	struct device *npu = priv->mm->dev;
 
+	if (aipu_priv_is_removing(priv->aipu))
+		return NULL;
+
 	sgt = kzalloc(sizeof(*sgt), GFP_KERNEL);
 	if (!sgt)
 		return NULL;
@@ -80,6 +90,9 @@ static int aipu_dma_buf_mmap(struct dma_buf *dmabuf, struct vm_area_struct *vma)
 	unsigned long vm_pgoff = 0;
 	struct aipu_dma_buf_priv *priv = (struct aipu_dma_buf_priv *)dmabuf->priv;
 
+	if (aipu_priv_is_removing(priv->aipu))
+		return -ENODEV;
+
 	vm_pgoff = vma->vm_pgoff;
 	vma->vm_pgoff = priv->dev_pa >> PAGE_SHIFT;
 	ret = aipu_mm_mmap_buf(priv->mm, vma, NULL);
@@ -96,6 +109,14 @@ static int aipu_dma_vmap(struct dma_buf *dmabuf, struct iosys_map *map)
 #endif
 {
 	struct aipu_dma_buf_priv *priv = (struct aipu_dma_buf_priv *)dmabuf->priv;
+	if (aipu_priv_is_removing(priv->aipu)) {
+#if KERNEL_VERSION(5, 11, 0) > LINUX_VERSION_CODE
+		return NULL;
+#else
+		return -ENODEV;
+#endif
+	}
+
 #if KERNEL_VERSION(5, 11, 0) > LINUX_VERSION_CODE
 	return priv->va;
 #else
@@ -117,6 +138,25 @@ static void aipu_dma_vunmap(struct dma_buf *dmabuf, struct iosys_map *map)
 
 static void aipu_dma_release(struct dma_buf *dmabuf)
 {
+	struct aipu_dma_buf_priv *priv = (struct aipu_dma_buf_priv *)dmabuf->priv;
+	struct aipu_buf_desc buf;
+	int ret;
+
+	if (!priv)
+		return;
+
+	buf.pa = priv->dev_pa;
+	buf.dev_offset = priv->dev_pa;
+	buf.bytes = priv->bytes;
+	buf.region = AIPU_BUF_REGION_DEFAULT;
+	buf.asid = AIPU_BUF_ASID_0;
+	ret = aipu_mm_free(priv->mm, &buf, NULL, true);
+	if (ret)
+		dev_warn(priv->mm->dev, "failed to release exported dma-buf backing store: %d\n", ret);
+
+	aipu_priv_put(priv->aipu);
+	kfree(priv);
+	dmabuf->priv = NULL;
 }
 
 #if ((KERNEL_VERSION(5, 6, 0) > LINUX_VERSION_CODE) && \
@@ -154,9 +194,25 @@ static struct dma_buf_ops aipu_dma_buf_ops = {
 #endif
 };
 
-int aipu_alloc_dma_buf(struct aipu_memory_manager *mm, struct aipu_dma_buf_request *request)
+static struct dma_buf *aipu_exported_dma_buf_get(int fd)
+{
+	struct dma_buf *dmabuf = dma_buf_get(fd);
+
+	if (IS_ERR(dmabuf))
+		return dmabuf;
+
+	if (dmabuf->ops != &aipu_dma_buf_ops) {
+		dma_buf_put(dmabuf);
+		return ERR_PTR(-EINVAL);
+	}
+
+	return dmabuf;
+}
+
+int aipu_alloc_dma_buf(struct aipu_priv *aipu, struct aipu_dma_buf_request *request)
 {
 	int ret = 0;
+	struct aipu_memory_manager *mm = NULL;
 	struct aipu_buf_request inter_req;
 	struct aipu_dma_buf_priv *priv = NULL;
 	char *va = NULL;
@@ -164,9 +220,13 @@ int aipu_alloc_dma_buf(struct aipu_memory_manager *mm, struct aipu_dma_buf_reque
 
 	DEFINE_DMA_BUF_EXPORT_INFO(exp);
 
-	if (!mm || !request || !request->bytes)
+	if (!aipu || !request || !request->bytes)
 		return -EINVAL;
 
+	if (!aipu_priv_get(aipu))
+		return -ENODEV;
+
+	mm = &aipu->mm;
 	memset(&inter_req, 0, sizeof(struct aipu_buf_request));
 	inter_req.bytes = request->bytes;
 	inter_req.align_in_page = 1;
@@ -175,7 +235,7 @@ int aipu_alloc_dma_buf(struct aipu_memory_manager *mm, struct aipu_dma_buf_reque
 
 	ret = aipu_mm_alloc(mm, &inter_req, NULL);
 	if (ret)
-		return ret;
+		goto put_aipu;
 
 	va = aipu_mm_get_va(mm, inter_req.desc.pa);
 	if (!va) {
@@ -183,13 +243,14 @@ int aipu_alloc_dma_buf(struct aipu_memory_manager *mm, struct aipu_dma_buf_reque
 		goto fail;
 	}
 
-	priv = devm_kzalloc(mm->dev, sizeof(*priv), GFP_KERNEL);
+	priv = kzalloc(sizeof(*priv), GFP_KERNEL);
 	if (!priv) {
 		ret = -ENOMEM;
 		goto fail;
 	}
 
 	priv->mm = mm;
+	priv->aipu = aipu;
 	priv->dev_pa = inter_req.desc.pa;
 	priv->dma_pa = inter_req.desc.pa;
 	priv->bytes = inter_req.desc.bytes;
@@ -202,44 +263,45 @@ int aipu_alloc_dma_buf(struct aipu_memory_manager *mm, struct aipu_dma_buf_reque
 
 	dmabuf = dma_buf_export(&exp);
 	if (IS_ERR(dmabuf)) {
