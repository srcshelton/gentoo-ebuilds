+	}
 
 	im_buf->fd = dmabuf_info->fd;
+	im_buf->filp = filp;
+	im_buf->dmabuf = dmabuf;
 	im_buf->attach = attach;
 	im_buf->table = table;
 	mutex_lock(&mm->lock);
 	list_add(&im_buf->node, &mm->importer_bufs->node);
 	mutex_unlock(&mm->lock);
 
-	dma_buf_put(dmabuf);
 	return 0;
+
+unmap_attachment:
+	dma_buf_unmap_attachment(attach, table, DMA_BIDIRECTIONAL);
+detach_dmabuf:
+	dma_buf_detach(dmabuf, attach);
+put_dmabuf:
+	dma_buf_put(dmabuf);
+	return ret;
+}
+
+static void aipu_detach_imported_dma_buf(struct aipu_dma_buf_importer *im_buf)
+{
+	struct dma_buf *dmabuf = im_buf->dmabuf;
+
+	dma_buf_unmap_attachment(im_buf->attach, im_buf->table, DMA_BIDIRECTIONAL);
+	dma_buf_detach(dmabuf, im_buf->attach);
+	dma_buf_put(dmabuf);
