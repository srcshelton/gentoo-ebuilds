backlight: pwm: parse firmware properties without CONFIG_OF

CIXH5041 is matched through ACPI and describes its PWM, enable GPIO, and
brightness table in _DSD.  The CIX ACPI port converted the DT parser to
device_property_*() calls but left it under CONFIG_OF, so ACPI-only kernels
compile a stub which rejects the device with -ENODEV.

Build the generic firmware-property parser and default brightness-table
helper unconditionally. Retain the OF match table's CONFIG_OF guard.

diff --git a/drivers/video/backlight/pwm_bl.c b/drivers/video/backlight/pwm_bl.c
--- a/drivers/video/backlight/pwm_bl.c
+++ b/drivers/video/backlight/pwm_bl.c
@@ -139,7 +139,6 @@ static const struct backlight_ops pwm_backlight_ops = {
 	.get_brightness = bd_get_brightness,
 };
 
-#ifdef CONFIG_OF
 #define PWM_LUMINANCE_SHIFT	16
 #define PWM_LUMINANCE_SCALE	(1 << PWM_LUMINANCE_SHIFT) /* luminance scale */
 
@@ -223,8 +222,8 @@ int pwm_backlight_brightness_default(struct device *dev,
 	return 0;
 }
 
-static int pwm_backlight_parse_dt(struct device *dev,
-				  struct platform_pwm_backlight_data *data)
+static int pwm_backlight_parse_fwnode(struct device *dev,
+				      struct platform_pwm_backlight_data *data)
 {
 	unsigned int num_levels;
 	unsigned int num_steps = 0;
@@ -254,7 +253,7 @@ static int pwm_backlight_parse_dt(struct device *dev,
 
 	num_levels = device_property_count_u32(dev, "brightness-levels");
 
-	/* read brightness levels from DT property */
+	/* Read brightness levels from a firmware property. */
 	if (num_levels > 0) {
 		data->levels = devm_kcalloc(dev, num_levels,
 					    sizeof(*data->levels), GFP_KERNEL);
@@ -351,26 +350,13 @@ static int pwm_backlight_parse_dt(struct device *dev,
 	return 0;
 }
 
+#ifdef CONFIG_OF
 static const struct of_device_id pwm_backlight_of_match[] = {
 	{ .compatible = "pwm-backlight" },
 	{ }
 };
 
 MODULE_DEVICE_TABLE(of, pwm_backlight_of_match);
-#else
-static int pwm_backlight_parse_dt(struct device *dev,
-				  struct platform_pwm_backlight_data *data)
-{
-	return -ENODEV;
-}
-
-static
-int pwm_backlight_brightness_default(struct device *dev,
-				     struct platform_pwm_backlight_data *data,
-				     unsigned int period)
-{
-	return -ENODEV;
-}
 #endif
 
 static const struct acpi_device_id pwm_backlight_acpi_match[] = {
@@ -496,7 +482,7 @@ static int pwm_backlight_probe(struct platform_device *pdev)
 	int ret;
 
 	if (!data) {
-		ret = pwm_backlight_parse_dt(&pdev->dev, &defdata);
+		ret = pwm_backlight_parse_fwnode(&pdev->dev, &defdata);
 		if (ret < 0)
 			return dev_err_probe(&pdev->dev, ret,
 					     "failed to find platform data\n");
@@ -557,10 +543,9 @@ static int pwm_backlight_probe(struct platform_device *pdev)
 	pwm_init_state(pb->pwm, &state);
 
 	/*
-	 * The DT case will set the pwm_period_ns field to 0 and store the
-	 * period, parsed from the DT, in the PWM device. For the non-DT case,
-	 * set the period from platform data if it has not already been set
-	 * via the PWM lookup table.
+	 * Firmware properties set pwm_period_ns to 0 and store the parsed
+	 * period in the PWM device. For platform data, set the period here if
+	 * a PWM lookup table has not already supplied one.
 	 */
 	if (!state.period && (data->pwm_period_ns > 0))
 		state.period = data->pwm_period_ns;
@@ -578,9 +563,9 @@ static int pwm_backlight_probe(struct platform_device *pdev)
 		pb->levels = data->levels;
 
 		/*
-		 * For the DT case, only when brightness levels is defined
-		 * data->levels is filled. For the non-DT case, data->levels
-		 * can come from platform data, however is not usual.
+		 * Firmware properties fill data->levels only when brightness
+		 * levels are defined. Platform data can also supply levels,
+		 * although that is unusual.
 		 */
 		for (i = 0; i <= data->max_brightness; i++)
 			if (data->levels[i] > pb->scale)
@@ -593,10 +578,9 @@ static int pwm_backlight_probe(struct platform_device *pdev)
 	} else if (!data->max_brightness) {
 		/*
 		 * If no brightness levels are provided and max_brightness is
-		 * not set, use the default brightness table. For the DT case,
-		 * max_brightness is set to 0 when brightness levels is not
-		 * specified. For the non-DT case, max_brightness is usually
-		 * set to some value.
+		 * not set, use the default brightness table. Firmware parsing
+		 * leaves max_brightness at 0 when brightness levels are absent;
+		 * platform data usually supplies a value.
 		 */
 
 		/* Get the PWM period (in nanoseconds) */
